<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Envox Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="top-bar"></div>
  
  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-logo">
        <span class="brand-env">env</span><span class="brand-ox">ox</span>
        <div class="brand-tagline">ADMIN</div>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-item active"><span class="nav-icon">📊</span> Dashboard</a>
        <a href="/admin/leads/new" class="nav-item"><span class="nav-icon">➕</span> Novo Lead</a>
        <a href="/admin/planejamentos" class="nav-item"><span class="nav-icon">📋</span> Planejamentos</a>
        <a href="/admin/planejamentos/new" class="nav-item"><span class="nav-icon">📤</span> Novo Planejamento</a>
      </nav>
      <div class="sidebar-footer">
        <a href="/admin/logout" class="nav-item logout"><span class="nav-icon">🚪</span> Sair</a>
      </div>
    </aside>
    
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>Dashboard</h1>
          <p class="page-subtitle">Gerencie seus leads e acompanhe o engajamento</p>
        </div>
        <div class="header-actions">
          <a href="/admin/leads/new" class="btn-primary">➕ Novo Lead</a>
          <a href="/admin/planejamentos/new" class="btn-outline">📤 Novo Planejamento</a>
        </div>
      </div>
      
      <% if (success) { %>
        <div class="alert alert-success"><span>✅</span> <%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><span>⚠️</span> <%= error %></div>
      <% } %>
      
      <!-- Stats Cards -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon">👥</div>
          <div class="stat-value"><%= leads.length %></div>
          <div class="stat-label">Total de Leads</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">✅</div>
          <div class="stat-value"><%= leads.filter(l => l.status === 'viewed').length %></div>
          <div class="stat-label">Visualizaram</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🔴</div>
          <div class="stat-value"><%= leads.filter(l => l.status === 'not_viewed').length %></div>
          <div class="stat-label">Não Visualizaram</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">📋</div>
          <div class="stat-value"><%= planejamentos ? planejamentos.length : 0 %></div>
          <div class="stat-label">Planejamentos</div>
        </div>
      </div>
      
      <!-- Leads Table -->
      <div class="table-card">
        <div class="table-header">
          <h2>Leads Cadastrados</h2>
          <span class="table-count"><%= leads.length %> leads</span>
        </div>
        
        <% if (leads.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">📋</div>
            <p>Nenhum lead cadastrado ainda.</p>
            <a href="/admin/leads/new" class="btn-primary">Cadastrar Primeiro Lead</a>
          </div>
        <% } else { %>
          <div class="table-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>WhatsApp</th>
                  <th>Status</th>
                  <th>Acessos</th>
                  <th>Tempo</th>
                  <th>Interesse</th>
                  <th>Link</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody>
                <% leads.forEach(lead => { %>
                  <tr onclick="window.location='/admin/leads/<%= lead.id %>'" style="cursor:pointer">
                    <td class="td-name">
                      <strong><%= lead.name %></strong>
                      <div style="font-size:0.78rem;color:#999"><%= lead.email %></div>
                    </td>
                    <td><%= lead.whatsapp %></td>
                    <td>
                      <% if (lead.status === 'viewed') { %>
                        <span class="badge badge-success">✅ Visualizou</span>
                      <% } else if (lead.status === 'viewing') { %>
                        <span class="badge badge-warning">👁️ Vendo agora</span>
                      <% } else { %>
                        <span class="badge badge-danger">❌ Não visualizou</span>
                      <% } %>
                    </td>
                    <td class="td-center"><%= lead.total_accesses || 0 %></td>
                    <td class="td-center">
                      <% const mins = Math.floor((lead.total_duration || 0) / 60); %>
                      <% const secs = (lead.total_duration || 0) % 60; %>
                      <%= mins %>m<%= secs %>s
                    </td>
                    <td class="td-center">
                      <% if (lead.interestLevel > 0) { %>
                        <span class="interest-badge badge-<%= lead.interestInfo.color %>"><%= lead.interestLevel %>/10</span>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td onclick="event.stopPropagation()">
                      <button class="btn-copy-link btn-sm" data-url="<%= baseUrl %>/proposta/<%= lead.token %>" title="Copiar link">
                        📋
                      </button>
                    </td>
                    <td onclick="event.stopPropagation()" style="white-space:nowrap">
                      <a href="/admin/leads/<%= lead.id %>" class="btn-sm btn-outline">Ver</a>
                      <% if (lead.status === 'not_viewed') { %>
                        <form action="/admin/leads/<%= lead.id %>/invite" method="POST" style="display:inline">
                          <button type="submit" class="btn-sm" style="background:#25D366;color:#fff;border:none;padding:4px 8px;border-radius:4px;cursor:pointer" title="Enviar convite WA">
                            📲 Convidar
                          </button>
                        </form>
                      <% } else if (lead.status === 'viewed') { %>
                        <button class="btn-sm" style="background:#1a73e8;color:#fff;border:none;padding:4px 8px;border-radius:4px;cursor:pointer" onclick="event.stopPropagation();showFollowup(<%= lead.id %>, '<%= lead.name.split(' ')[0] %>')">
                          🔄 Follow-up
                        </button>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <!-- Planejamentos recentes -->
      <% if (planejamentos && planejamentos.length > 0) { %>
      <div class="table-card">
        <div class="table-header">
          <h2>Planejamentos Recentes</h2>
          <a href="/admin/planejamentos" class="btn-sm btn-outline">Ver todos</a>
        </div>
        <div class="table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Título</th>
                <th>Cliente</th>
                <th>Status</th>
                <th>Slides</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% planejamentos.slice(0,5).forEach(plan => { %>
              <tr onclick="window.location='/admin/planejamentos/<%= plan.id %>'" style="cursor:pointer">
                <td><strong><%= plan.title %></strong></td>
                <td><%= plan.client_name || '<span class="text-muted">—</span>' %></td>
                <td>
                  <% if (plan.status === 'reviewed') { %><span class="badge badge-success">✅ Revisado</span>
                  <% } else if (plan.status === 'sent') { %><span class="badge badge-warning">📤 Enviado</span>
                  <% } else { %><span class="badge badge-secondary">✏️ Rascunho</span><% } %>
                </td>
                <td class="td-center"><%= plan.total_slides || 0 %></td>
                <td onclick="event.stopPropagation()">
                  <a href="/admin/planejamentos/<%= plan.id %>" class="btn-sm btn-outline">Ver</a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>
    </main>
  </div>
  
  <!-- Toast notification -->
  <div id="toast" class="toast hidden">Link copiado!</div>

  <!-- Follow-up Modal -->
  <div id="followupModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:12px;padding:24px;max-width:380px;width:90%">
      <h3 style="margin-bottom:4px">Follow-up para <span id="fupName"></span></h3>
      <p style="color:#666;font-size:0.85rem;margin-bottom:16px">Escolha a categoria da mensagem:</p>
      <div style="display:flex;flex-direction:column;gap:10px">
        <button onclick="sendFollowup('article')" style="background:#1a73e8;color:#fff;border:none;padding:12px;border-radius:8px;font-size:0.9rem;cursor:pointer;text-align:left">
          📰 Artigo / Conteúdo relevante
        </button>
        <button onclick="sendFollowup('result')" style="background:#4caf50;color:#fff;border:none;padding:12px;border-radius:8px;font-size:0.9rem;cursor:pointer;text-align:left">
          🏆 Resultado / Case de sucesso
        </button>
        <button onclick="sendFollowup('urgency')" style="background:#ff9800;color:#fff;border:none;padding:12px;border-radius:8px;font-size:0.9rem;cursor:pointer;text-align:left">
          ⏰ Urgência / Escassez
        </button>
      </div>
      <button onclick="closeFollowup()" style="margin-top:12px;width:100%;background:#f0f0f0;border:none;padding:10px;border-radius:8px;cursor:pointer">Cancelar</button>
    </div>
  </div>
  
  <script>
    let currentLeadId = null;

    document.querySelectorAll('.btn-copy-link').forEach(btn => {
      btn.addEventListener('click', function() {
        navigator.clipboard.writeText(this.dataset.url).then(() => {
          const toast = document.getElementById('toast');
          toast.classList.remove('hidden');
          setTimeout(() => toast.classList.add('hidden'), 2500);
        });
      });
    });

    function showFollowup(leadId, name) {
      currentLeadId = leadId;
      document.getElementById('fupName').textContent = name;
      const modal = document.getElementById('followupModal');
      modal.style.display = 'flex';
    }

    function closeFollowup() {
      document.getElementById('followupModal').style.display = 'none';
      currentLeadId = null;
    }

    function sendFollowup(category) {
      if (!currentLeadId) return;
      // Submeter form para redirect ao WA
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = `/admin/leads/${currentLeadId}/followup`;
      const input = document.createElement('input');
      input.type = 'hidden'; input.name = 'category'; input.value = category;
      form.appendChild(input);
      document.body.appendChild(form);
      form.submit();
    }
  </script>
</body>
</html>
