<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Novo Lead — Envox Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="top-bar"></div>
  
  <div class="admin-layout">
    <%- include('./_sidebar', { active: 'new-lead' }) %>
    
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>Novo Lead</h1>
          <p class="page-subtitle">Cadastre um lead e gere o link personalizado da proposta</p>
        </div>
        <a href="/admin" class="btn-outline">← Voltar</a>
      </div>
      
      <% if (error) { %>
        <div class="alert alert-error"><span>⚠️</span> <%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><span>✅</span> <%= success %></div>
      <% } %>
      
      <div class="form-card">
        <form action="/admin/leads" method="POST" class="lead-form">
          <div class="form-section-title" style="margin-bottom:0.75rem;font-size:0.8rem;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.5px;padding-bottom:0.5rem;border-bottom:1px solid #eee">
            Empresa
          </div>
          <div class="form-row form-row-2">
            <div class="form-group">
              <label for="company_name">Nome da Empresa *</label>
              <input type="text" id="company_name" name="company_name" 
                placeholder="Ex: Mazu Restaurante" required>
            </div>
            <div class="form-group">
              <label for="cargo">Cargo do Contato</label>
              <input type="text" id="cargo" name="cargo" 
                placeholder="Ex: Diretor, Sócio, Gerente...">
            </div>
          </div>

          <div class="form-section-title" style="margin-top:1rem;margin-bottom:0.75rem;font-size:0.8rem;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.5px;padding-top:1rem;border-top:1px solid #eee">
            Contato / Lead
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Nome Completo *</label>
              <input type="text" id="name" name="name" 
                placeholder="Ex: João Silva" required>
            </div>
          </div>
          
          <div class="form-row form-row-2">
            <div class="form-group">
              <label for="whatsapp">WhatsApp *</label>
              <input type="text" id="whatsapp" name="whatsapp" 
                placeholder="(41) 9 9999-9999" required maxlength="16">
              <small class="form-hint">Com DDD. Ex: (41) 9 9999-9999</small>
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" 
                placeholder="email@empresa.com.br" required>
            </div>
          </div>
          
          <!-- DESCONTO E PRAZO -->
          <div class="form-section-title" style="margin-top:1.25rem;margin-bottom:0.75rem;font-size:0.8rem;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.5px;padding-top:1rem;border-top:1px solid #eee">
            Condições Especiais (opcional)
          </div>
          <div class="form-row form-row-3">
            <div class="form-group">
              <label for="discount_monthly">Desconto Recorrentes (%)</label>
              <input type="number" id="discount_monthly" name="discount_monthly" 
                placeholder="Ex: 15" min="0" max="100" step="1">
              <small class="form-hint">Serviços mensais (Social Media, Ads, SDR)</small>
            </div>
            <div class="form-group">
              <label for="discount_onetime">Desconto Pontuais (%)</label>
              <input type="number" id="discount_onetime" name="discount_onetime" 
                placeholder="Ex: 10" min="0" max="100" step="1">
              <small class="form-hint">Trabalhos únicos (Website, Identidade Visual)</small>
            </div>
            <div class="form-group">
              <label for="discount_expires">Prazo da Proposta (Validade)</label>
              <input type="date" id="discount_expires" name="discount_expires">
              <small class="form-hint">O desconto some após esta data</small>
            </div>
          </div>

          <div class="form-actions">
            <a href="/admin" class="btn-outline">Cancelar</a>
            <button type="submit" class="btn-primary">
              🔗 Cadastrar e Gerar Link
            </button>
          </div>
        </form>
      </div>
      
      <div class="info-card">
        <h3>ℹ️ Como funciona?</h3>
        <ol>
          <li>Cadastre o lead com nome, WhatsApp e email</li>
          <li>O sistema gera um <strong>link único e exclusivo</strong> para esse lead</li>
          <li>Envie o link via WhatsApp ou email para o lead</li>
          <li>O lead acessa o link e se autentica com os dados cadastrados</li>
          <li>Se definir desconto e prazo, o slide 12 e o montador exibem a condição especial</li>
          <li>Você recebe um alerta no WhatsApp quando ele visualizar a proposta</li>
          <li>Acompanhe o engajamento em tempo real no painel</li>
        </ol>
      </div>
    </main>
  </div>
  
  <script>
    // Máscara WhatsApp
    const waInput = document.getElementById('whatsapp');
    waInput.addEventListener('input', function() {
      let v = this.value.replace(/\D/g, '');
      if (v.length > 11) v = v.slice(0, 11);
      if (v.length >= 11) {
        this.value = `(${v.slice(0,2)}) ${v.slice(2,3)} ${v.slice(3,7)}-${v.slice(7)}`;
      } else if (v.length >= 7) {
        this.value = `(${v.slice(0,2)}) ${v.slice(2,6)}-${v.slice(6)}`;
      } else if (v.length >= 3) {
        this.value = `(${v.slice(0,2)}) ${v.slice(2)}`;
      } else if (v.length >= 1) {
        this.value = `(${v}`;
      }
    });
  </script>
</body>
</html>
