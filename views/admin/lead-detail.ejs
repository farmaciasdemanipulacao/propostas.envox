<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= stats.lead.name %> — Envox Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <div class="top-bar"></div>
  
  <div class="admin-layout">
    <%- include('./_sidebar', { active: 'leads' }) %>
    
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1><%= stats.lead.name %></h1>
          <p class="page-subtitle">Análise de engajamento com a proposta</p>
        </div>
        <div class="header-actions">
          <button class="btn-copy-link btn-outline" data-url="<%= baseUrl %>/proposta/<%= stats.lead.token %>">
            📋 Copiar Link
          </button>
          <form action="/admin/leads/<%= stats.lead.id %>/resend-alert" method="POST" style="display:inline">
            <button type="submit" class="btn-whatsapp">📲 Reenviar Alerta</button>
          </form>
          <a href="/admin/leads/<%= stats.lead.id %>/edit" class="btn-outline">✏️ Editar Lead</a>
          <a href="/admin/proposals/<%= stats.lead.id %>/edit" class="btn-outline">📝 Editar Proposta</a>
          <a href="/admin/leads" class="btn-outline">← Leads</a>
        </div>
      </div>
      
      <% if (success) { %><div class="alert alert-success"><span>✅</span> <%= success %></div><% } %>
      <% if (error) { %><div class="alert alert-error"><span>⚠️</span> <%= error %></div><% } %>
      
      <!-- Lead Info + Metrics + Interest -->
      <div class="detail-top-grid">
        <div class="detail-card">
          <h3 class="card-title">📋 Informações do Lead</h3>
          <div class="info-list">
            <div class="info-row">
              <span class="info-label">Nome</span>
              <span class="info-value"><%= stats.lead.name %></span>
            </div>
            <div class="info-row">
              <span class="info-label">WhatsApp</span>
              <span class="info-value">
                <a href="https://wa.me/55<%= stats.lead.whatsapp.replace(/\D/g,'') %>" target="_blank" class="wa-link">
                  📱 <%= stats.lead.whatsapp %>
                </a>
              </span>
            </div>
            <div class="info-row">
              <span class="info-label">Email</span>
              <span class="info-value"><%= stats.lead.email %></span>
            </div>
            <div class="info-row">
              <span class="info-label">Cadastrado em</span>
              <span class="info-value"><%= new Date(stats.lead.created_at).toLocaleDateString('pt-BR') %></span>
            </div>
            <div class="info-row">
              <span class="info-label">Link da Proposta</span>
              <span class="info-value">
                <button class="btn-copy-link btn-sm" data-url="<%= baseUrl %>/proposta/<%= stats.lead.token %>">📋 Copiar</button>
              </span>
            </div>
            <% if (stats.lead.discount_monthly > 0 || stats.lead.discount_onetime > 0) { %>
            <div class="info-row" style="background:rgba(233,30,99,0.04);border-radius:8px;padding:0.5rem 0.75rem;margin-top:0.5rem">
              <span class="info-label">🎉 Condição Especial</span>
              <span class="info-value" style="font-size:0.82rem">
                <% if (stats.lead.discount_monthly > 0) { %><span style="color:#E91E63;font-weight:700"><%= stats.lead.discount_monthly %>% recorrentes</span><% } %>
                <% if (stats.lead.discount_onetime > 0) { %><% if (stats.lead.discount_monthly > 0) { %> · <% } %><span style="color:#E91E63;font-weight:700"><%= stats.lead.discount_onetime %>% pontuais</span><% } %>
                <% if (stats.lead.discount_expires) { %><br><small style="color:#666">Prazo: <%= new Date(stats.lead.discount_expires + 'T12:00:00').toLocaleDateString('pt-BR') %></small><% } %>
              </span>
            </div>
            <% } %>
          </div>
          <!-- Editar descontos inline -->
          <details style="margin-top:0.75rem">
            <summary style="font-size:0.78rem;color:#E91E63;cursor:pointer;font-weight:600">✏️ Editar condições especiais</summary>
            <form action="/admin/leads/<%= stats.lead.id %>/discount" method="POST" style="margin-top:0.75rem;display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;align-items:end">
              <div>
                <label style="font-size:0.72rem;font-weight:600;color:#666;display:block;margin-bottom:3px">Desc. Recorrentes (%)</label>
                <input type="number" name="discount_monthly" value="<%= stats.lead.discount_monthly || 0 %>" min="0" max="100" style="width:100%;padding:6px 10px;border:1px solid #ddd;border-radius:6px;font-size:0.82rem">
              </div>
              <div>
                <label style="font-size:0.72rem;font-weight:600;color:#666;display:block;margin-bottom:3px">Desc. Pontuais (%)</label>
                <input type="number" name="discount_onetime" value="<%= stats.lead.discount_onetime || 0 %>" min="0" max="100" style="width:100%;padding:6px 10px;border:1px solid #ddd;border-radius:6px;font-size:0.82rem">
              </div>
              <div>
                <label style="font-size:0.72rem;font-weight:600;color:#666;display:block;margin-bottom:3px">Prazo</label>
                <input type="date" name="discount_expires" value="<%= stats.lead.discount_expires || '' %>" style="width:100%;padding:6px 10px;border:1px solid #ddd;border-radius:6px;font-size:0.82rem">
              </div>
              <div style="grid-column:1/-1">
                <button type="submit" style="background:#E91E63;color:#fff;border:none;padding:8px 16px;border-radius:8px;font-size:0.8rem;cursor:pointer;font-weight:600;width:100%">💾 Salvar condições</button>
              </div>
            </form>
          </details>
        </div>
        
        <div class="detail-card">
          <h3 class="card-title">📊 Métricas Gerais</h3>
          <div class="metrics-grid">
            <div class="metric-item">
              <div class="metric-value"><%= stats.totalAccesses %></div>
              <div class="metric-label">Acessos</div>
            </div>
            <div class="metric-item">
              <div class="metric-value"><%= stats.totalSlidesSeen %>/12</div>
              <div class="metric-label">Slides Vistos</div>
            </div>
            <div class="metric-item">
              <% const m = Math.floor(stats.totalDuration/60); const s = stats.totalDuration%60; %>
              <div class="metric-value"><%= m %>m<%= s %>s</div>
              <div class="metric-label">Tempo Total</div>
            </div>
            <div class="metric-item">
              <% const revisitCount = stats.slideStats ? stats.slideStats.filter(s => s.revisit_count > 0).length : 0; %>
              <div class="metric-value"><%= revisitCount %></div>
              <div class="metric-label">Slides Revisitados</div>
            </div>
            <div class="metric-item">
              <div class="metric-value"><%= inviteHistory ? inviteHistory.length : 0 %></div>
              <div class="metric-label">Convites Enviados</div>
            </div>
            <div class="metric-item">
              <div class="metric-value"><%= followupHistory ? followupHistory.length : 0 %></div>
              <div class="metric-label">Follow-ups</div>
            </div>
          </div>
        </div>
        
        <div class="detail-card interest-card">
          <h3 class="card-title">🎯 Nível de Interesse</h3>
          <div class="interest-display">
            <div class="interest-number interest-<%= interestInfo.color %>"><%= interestLevel %></div>
            <div class="interest-label-big">/ 10</div>
          </div>
          <div class="interest-bar-wrap">
            <div class="interest-bar">
              <div class="interest-fill" style="width: <%= interestLevel * 10 %>%"></div>
            </div>
          </div>
          <div class="interest-tag badge-<%= interestInfo.color %>"><%= interestInfo.label %></div>
          <div class="interest-hint">
            <small>Baseado em: tempo de visualização, slides visitados, revisitas e interesse em slides de preço</small>
          </div>
        </div>
      </div>

      <!-- Ações de Comunicação -->
      <div class="detail-card full-width-card">
        <h3 class="card-title">📲 Comunicação com o Lead</h3>
        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
          <% if (stats.totalAccesses === 0) { %>
            <!-- Ainda não visualizou - mostrar convite -->
            <form action="/admin/leads/<%= stats.lead.id %>/invite" method="POST">
              <button type="submit" class="btn-whatsapp">
                📲 Enviar Convite WhatsApp
              </button>
            </form>
            <span style="font-size:0.82rem;color:#666">
              <% if (inviteHistory && inviteHistory.length > 0) { %>
                Último convite: <%= new Date(inviteHistory[0].sent_at).toLocaleString('pt-BR') %>
              <% } else { %>
                Nenhum convite enviado ainda
              <% } %>
            </span>
          <% } else { %>
            <!-- Já visualizou - mostrar follow-up -->
            <form action="/admin/leads/<%= stats.lead.id %>/followup" method="POST" style="display:inline">
              <input type="hidden" name="category" value="article">
              <button type="submit" class="btn-sm" style="background:#1a73e8;color:#fff;border:none;padding:10px 16px;border-radius:8px;font-size:0.85rem;cursor:pointer">
                📰 Follow-up: Artigo
              </button>
            </form>
            <form action="/admin/leads/<%= stats.lead.id %>/followup" method="POST" style="display:inline">
              <input type="hidden" name="category" value="result">
              <button type="submit" class="btn-sm" style="background:#4caf50;color:#fff;border:none;padding:10px 16px;border-radius:8px;font-size:0.85rem;cursor:pointer">
                🏆 Follow-up: Resultado
              </button>
            </form>
            <form action="/admin/leads/<%= stats.lead.id %>/followup" method="POST" style="display:inline">
              <input type="hidden" name="category" value="urgency">
              <button type="submit" class="btn-sm" style="background:#ff9800;color:#fff;border:none;padding:10px 16px;border-radius:8px;font-size:0.85rem;cursor:pointer">
                ⏰ Follow-up: Urgência
              </button>
            </form>
            <form action="/admin/leads/<%= stats.lead.id %>/resend-alert" method="POST" style="display:inline">
              <button type="submit" class="btn-sm" style="background:#E91E63;color:#fff;border:none;padding:10px 16px;border-radius:8px;font-size:0.85rem;cursor:pointer">
                🔔 Reenviar Alerta
              </button>
            </form>
          <% } %>
        </div>

        <% if (nextInviteMsg) { %>
        <div style="margin-top:12px;padding:12px;background:#f8f9fa;border-radius:8px;font-size:0.82rem;color:#555;border-left:3px solid #E91E63">
          <strong>Próxima mensagem de convite:</strong><br>
          <em><%= nextInviteMsg %></em>
        </div>
        <% } %>
      </div>
      
      <!-- Gráfico de Slides -->
      <div class="detail-card full-width-card">
        <h3 class="card-title">📈 Tempo por Slide (segundos)</h3>
        <div class="chart-wrap">
          <canvas id="slideChart" height="100"></canvas>
        </div>
      </div>
      
      <!-- Mapa de Calor -->
      <div class="detail-card full-width-card">
        <h3 class="card-title">🔥 Mapa de Calor — Engajamento por Slide</h3>
        <div class="heatmap-grid">
          <% 
          const slideNamesList = ['','Capa','O Problema','Nossa Solução','Plano Crescimento',
            'Plano Presença Forte','Plano Performance','Comparativo','Monte seu Plano',
            'Adicionais','Separados','Por que Envox?','Encerramento'];
          for (let i = 1; i <= 12; i++) {
            const slideStat = stats.slideStats.find(s => s.slide_number === i);
            const dur = slideStat ? Math.round(slideStat.total_duration || 0) : 0;
            const views = slideStat ? slideStat.view_count : 0;
            let heatClass = 'heat-none';
            if (dur > 0 && dur < 20) heatClass = 'heat-low';
            else if (dur >= 20 && dur < 60) heatClass = 'heat-medium';
            else if (dur >= 60) heatClass = 'heat-high';
          %>
            <div class="heatmap-cell <%= heatClass %>">
              <div class="heat-number"><%= i %></div>
              <div class="heat-name"><%= slideNamesList[i] %></div>
              <div class="heat-time"><%= dur %>s</div>
              <div class="heat-views"><%= views %> viz.</div>
            </div>
          <% } %>
        </div>
        <div class="heatmap-legend">
          <span class="legend-item heat-none">⬜ Não visto</span>
          <span class="legend-item heat-low">🟩 Pouco (&lt;20s)</span>
          <span class="legend-item heat-medium">🟨 Médio (20-60s)</span>
          <span class="legend-item heat-high">🟥 Alto (&gt;60s)</span>
        </div>
      </div>

      <!-- Decisões da Proposta -->
      <% if (typeof proposalActions !== 'undefined' && proposalActions && proposalActions.length > 0) { %>
      <div class="detail-card full-width-card">
        <h3 class="card-title">⚖️ Decisões do Lead sobre a Proposta</h3>
        <table class="data-table">
          <thead>
            <tr><th>Data</th><th>Decisão</th><th>Valor (Contra-proposta)</th><th>Comentário</th></tr>
          </thead>
          <tbody>
            <% proposalActions.forEach(action => { %>
            <% const actionColors = { accept: '#16a34a', counter: '#1565c0', reject: '#dc2626' }; %>
            <% const actionLabels = { accept: '✅ Aceita', counter: '🔄 Contra-proposta', reject: '❌ Rejeitada' }; %>
            <tr>
              <td><small><%= new Date(action.created_at).toLocaleString('pt-BR') %></small></td>
              <td>
                <span style="font-weight:700;color:<%= actionColors[action.action_type] || '#666' %>">
                  <%= actionLabels[action.action_type] || action.action_type %>
                </span>
              </td>
              <td>
                <% if (action.counter_value) { %>
                  <strong style="color:#1565c0">R$ <%= Number(action.counter_value).toLocaleString('pt-BR') %></strong>
                <% } else { %>
                  <span style="color:#bbb">—</span>
                <% } %>
              </td>
              <td style="font-size:0.82rem;color:#555;max-width:300px">
                <%= action.comment || '—' %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

      <!-- Planos customizados -->
      <% if (stats.customPlans && stats.customPlans.length > 0) { %>
      <div class="detail-card full-width-card">
        <h3 class="card-title">🛒 Planos Customizados</h3>
        <table class="data-table">
          <thead><tr><th>Data</th><th>Mensal</th><th>Único</th><th>Enviou WA</th></tr></thead>
          <tbody>
            <% stats.customPlans.forEach(plan => { %>
            <tr>
              <td><small><%= new Date(plan.created_at).toLocaleString('pt-BR') %></small></td>
              <td>R$ <%= (plan.monthly_total||0).toLocaleString('pt-BR') %></td>
              <td>R$ <%= (plan.onetime_total||0).toLocaleString('pt-BR') %></td>
              <td><%= plan.sent_via_whatsapp ? '✅ Sim' : '❌ Não' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
      
      <!-- Histórico de Sessões -->
      <% if (stats.sessions && stats.sessions.length > 0) { %>
      <div class="detail-card full-width-card">
        <h3 class="card-title">🕐 Histórico de Acessos</h3>
        <table class="data-table">
          <thead>
            <tr><th>#</th><th>Início</th><th>Fim</th><th>Duração</th><th>Alerta WA</th></tr>
          </thead>
          <tbody>
            <% stats.sessions.forEach((sess, idx) => { %>
            <tr>
              <td><%= stats.sessions.length - idx %></td>
              <td><small><%= new Date(sess.started_at).toLocaleString('pt-BR') %></small></td>
              <td>
                <% if (sess.ended_at) { %>
                  <small><%= new Date(sess.ended_at).toLocaleString('pt-BR') %></small>
                <% } else { %><span class="badge badge-warning">Em andamento</span><% } %>
              </td>
              <td>
                <% const dm = Math.floor((sess.total_duration_seconds||0)/60); %>
                <% const ds = (sess.total_duration_seconds||0)%60; %>
                <%= dm %>m<%= ds %>s
              </td>
              <td><%= sess.alert_sent ? '✅' : '—' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

      <!-- Histórico de Convites -->
      <% if ((inviteHistory && inviteHistory.length > 0) || (followupHistory && followupHistory.length > 0)) { %>
      <div class="detail-card full-width-card">
        <h3 class="card-title">📲 Histórico de Mensagens Enviadas</h3>
        <table class="data-table">
          <thead><tr><th>Tipo</th><th>Mensagem</th><th>Enviado em</th></tr></thead>
          <tbody>
            <% const allMessages = [...(inviteHistory||[]), ...(followupHistory||[])].sort((a,b) => new Date(b.sent_at) - new Date(a.sent_at)); %>
            <% allMessages.forEach(inv => { %>
            <tr>
              <td>
                <% if (inv.invite_type === 'invite') { %>
                  <span class="badge badge-success">📲 Convite</span>
                <% } else if (inv.invite_type === 'followup_article') { %>
                  <span class="badge" style="background:#e3f2fd;color:#1a73e8">📰 Artigo</span>
                <% } else if (inv.invite_type === 'followup_result') { %>
                  <span class="badge" style="background:#e8f5e9;color:#4caf50">🏆 Resultado</span>
                <% } else { %>
                  <span class="badge badge-warning">⏰ Urgência</span>
                <% } %>
              </td>
              <td><small style="color:#666"><%= inv.message_text.substring(0, 80) %>...</small></td>
              <td><small><%= new Date(inv.sent_at).toLocaleString('pt-BR') %></small></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
      
      <!-- Log de Eventos -->
      <div class="detail-card full-width-card">
        <h3 class="card-title">📋 Log de Eventos</h3>
        <% if (eventLog && eventLog.length > 0) { %>
          <div class="event-log">
            <% eventLog.forEach(ev => { %>
              <div class="event-item event-<%= ev.event_type %>">
                <div class="event-time">
                  <%= new Date(ev.timestamp).toLocaleString('pt-BR') %>
                </div>
                <div class="event-dot"></div>
                <div class="event-text">
                  <% if (ev.event_type === 'proposal_opened') { %>
                    🔓 Abriu a proposta
                  <% } else if (ev.event_type === 'proposal_closed') { %>
                    🔒 Fechou a proposta
                    <% if (ev.parsedDetails && ev.parsedDetails.total_duration) { %>
                      <small>(duração: <%= Math.round(ev.parsedDetails.total_duration) %>s)</small>
                    <% } %>
                  <% } else if (ev.event_type === 'slide_viewed') { %>
                    👁️ <%= ev.parsedDetails ? ev.parsedDetails.message : 'Visualizou slide' %>
                    <% if (ev.parsedDetails && ev.parsedDetails.duration_seconds > 0) { %>
                      <small>(<%= Math.round(ev.parsedDetails.duration_seconds) %>s)</small>
                    <% } %>
                  <% } else if (ev.event_type === 'slide_revisited') { %>
                    🔄 <%= ev.parsedDetails ? ev.parsedDetails.message : 'Revisitou slide' %>
                  <% } else if (ev.event_type === 'custom_plan_saved') { %>
                    🛒 Montou plano customizado
                    <% if (ev.parsedDetails && ev.parsedDetails.monthly) { %>
                      <small>(R$ <%= ev.parsedDetails.monthly %>/ mês)</small>
                    <% } %>
                  <% } else if (ev.event_type === 'custom_plan_sent') { %>
                    ✅ Enviou plano pelo WhatsApp
                  <% } else if (ev.event_type === 'invite_sent') { %>
                    📲 Convite enviado
                  <% } else if (ev.event_type === 'followup_sent') { %>
                    🔄 Follow-up enviado
                    <% if (ev.parsedDetails && ev.parsedDetails.category) { %>
                      <small>(<%= ev.parsedDetails.category %>)</small>
                    <% } %>
                  <% } else { %>
                    ℹ️ <%= ev.event_type %>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-muted">Nenhum evento registrado ainda.</p>
        <% } %>
      </div>
      
    </main>
  </div>
  
  <div id="toast" class="toast hidden">Link copiado!</div>
  
  <script>
    const ctx = document.getElementById('slideChart').getContext('2d');
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: <%- slideLabels %>,
        datasets: [{
          label: 'Tempo (segundos)',
          data: <%- slideDurations %>,
          backgroundColor: <%- slideColors %>,
          borderRadius: 6,
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: ctx => `${ctx.raw}s de visualização` } }
        },
        scales: {
          y: { beginAtZero: true, grid: { color: '#f0f0f0' }, ticks: { callback: v => v + 's' } },
          x: { grid: { display: false } }
        }
      }
    });
    
    document.querySelectorAll('.btn-copy-link').forEach(btn => {
      btn.addEventListener('click', function() {
        navigator.clipboard.writeText(this.dataset.url).then(() => {
          const toast = document.getElementById('toast');
          toast.classList.remove('hidden');
          setTimeout(() => toast.classList.add('hidden'), 2500);
        });
      });
    });
  </script>
</body>
</html>
