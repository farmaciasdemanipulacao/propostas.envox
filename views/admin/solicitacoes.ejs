<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solicitações de Acesso — Envox Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="top-bar"></div>

  <div class="admin-layout">
    <%- include('./_sidebar', { active: 'solicitacoes' }) %>

    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>🔔 Solicitações de Acesso</h1>
          <p class="page-subtitle">Pessoas que solicitaram acesso pelo site — analise e aprove ou rejeite</p>
        </div>
        <div class="header-actions">
          <a href="/admin" class="btn-outline">← Dashboard</a>
        </div>
      </div>

      <% if (success) { %><div class="alert alert-success"><span>✅</span> <%= success %></div><% } %>
      <% if (error)   { %><div class="alert alert-error"><span>⚠️</span> <%= error %></div><% } %>

      <%
        const pending  = requests.filter(r => r.status === 'pending');
        const approved = requests.filter(r => r.status === 'approved');
        const rejected = requests.filter(r => r.status === 'rejected');
      %>

      <!-- Contador rápido -->
      <div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap">
        <div style="background:rgba(251,191,36,0.12);border:1px solid rgba(251,191,36,0.3);border-radius:12px;padding:14px 20px;display:flex;align-items:center;gap:10px">
          <span style="font-size:1.4rem">⏳</span>
          <div><div style="font-size:1.4rem;font-weight:800;color:#b45309"><%= pending.length %></div><div style="font-size:0.75rem;color:#92400e">Pendentes</div></div>
        </div>
        <div style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);border-radius:12px;padding:14px 20px;display:flex;align-items:center;gap:10px">
          <span style="font-size:1.4rem">✅</span>
          <div><div style="font-size:1.4rem;font-weight:800;color:#2e7d32"><%= approved.length %></div><div style="font-size:0.75rem;color:#4caf50">Aprovadas</div></div>
        </div>
        <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);border-radius:12px;padding:14px 20px;display:flex;align-items:center;gap:10px">
          <span style="font-size:1.4rem">❌</span>
          <div><div style="font-size:1.4rem;font-weight:800;color:#c62828"><%= rejected.length %></div><div style="font-size:0.75rem;color:#ef9a9a">Rejeitadas</div></div>
        </div>
      </div>

      <% if (!requests || requests.length === 0) { %>
        <div style="background:var(--white);border-radius:14px;padding:3rem;text-align:center;color:var(--gray-400)">
          <div style="font-size:3rem;margin-bottom:1rem">📭</div>
          <p style="font-size:0.95rem;font-weight:600">Nenhuma solicitação recebida ainda.</p>
          <p style="font-size:0.82rem;margin-top:0.5rem;color:var(--gray-300)">
            Quando alguém preencher o formulário em <strong>proposta.envox.com.br</strong>, aparecerá aqui.
          </p>
        </div>
      <% } else { %>

        <div class="table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Nome / Empresa</th>
                <th>Contato</th>
                <th>Cargo</th>
                <th>Data</th>
                <th>Status</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% requests.forEach(function(r) { %>
                <tr style="<%= r.status === 'pending' ? 'background:rgba(251,191,36,0.04)' : '' %>">
                  <td><span style="font-size:0.75rem;color:var(--gray-400)">#<%= r.id %></span></td>

                  <td>
                    <div style="font-weight:700;font-size:0.9rem"><%= r.name %></div>
                    <div style="font-size:0.78rem;color:var(--gray-500);margin-top:2px">🏢 <%= r.company %></div>
                  </td>

                  <td>
                    <div style="font-size:0.82rem">
                      <div>📧 <%= r.email %></div>
                      <div style="margin-top:3px">
                        📱 <a href="https://wa.me/<%= r.whatsapp %>" target="_blank"
                              style="color:var(--primary);text-decoration:none;font-weight:600">
                          <%= r.whatsapp %>
                        </a>
                      </div>
                    </div>
                  </td>

                  <td style="font-size:0.82rem;color:var(--gray-600)"><%= r.cargo || '—' %></td>

                  <td style="font-size:0.78rem;color:var(--gray-500);white-space:nowrap">
                    <%= new Date(r.created_at).toLocaleDateString('pt-BR', {day:'2-digit',month:'2-digit',year:'numeric'}) %>
                    <br><small><%= new Date(r.created_at).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %></small>
                  </td>

                  <td>
                    <% if (r.status === 'approved') { %>
                      <span class="status-badge status-approved">✅ Aprovado</span>
                    <% } else if (r.status === 'rejected') { %>
                      <span class="status-badge status-rejected">❌ Rejeitado</span>
                    <% } else { %>
                      <span class="status-badge status-pending">⏳ Pendente</span>
                    <% } %>
                    <% if (r.admin_notes) { %>
                      <div style="font-size:0.72rem;color:var(--gray-400);margin-top:4px;max-width:120px">
                        <%= r.admin_notes %>
                      </div>
                    <% } %>
                  </td>

                  <td>
                    <% if (r.status === 'pending') { %>
                      <div style="display:flex;gap:6px;flex-direction:column">
                        <!-- Aprovar -->
                        <form action="/admin/solicitacoes/<%= r.id %>/aprovar" method="POST">
                          <button type="submit"
                            onclick="return confirm('Aprovar solicitação de <%= r.name %>?\nIsso criará o lead automaticamente no sistema.')"
                            style="width:100%;font-size:0.78rem;padding:0.4rem 0.8rem;background:#2e7d32;color:#fff;border:none;border-radius:7px;cursor:pointer;font-weight:600;font-family:inherit">
                            ✅ Aprovar
                          </button>
                        </form>
                        <!-- Rejeitar -->
                        <button onclick="openRejectModal(<%= r.id %>, '<%= r.name.replace(/'/g, '') %>')"
                          style="width:100%;font-size:0.78rem;padding:0.4rem 0.8rem;background:rgba(198,40,40,0.12);color:#c62828;border:1px solid rgba(198,40,40,0.3);border-radius:7px;cursor:pointer;font-weight:600;font-family:inherit">
                          ❌ Rejeitar
                        </button>
                      </div>
                    <% } else if (r.status === 'approved') { %>
                      <a href="/admin/proposals/new?lead_email=<%= encodeURIComponent(r.email) %>"
                         style="font-size:0.78rem;padding:0.4rem 0.8rem;background:var(--primary);color:#fff;border-radius:7px;text-decoration:none;font-weight:600;display:inline-block">
                        📋 Criar Proposta
                      </a>
                    <% } else { %>
                      <span style="font-size:0.75rem;color:var(--gray-400)">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </main>
  </div>

  <!-- Modal rejeitar -->
  <div id="rejectModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;padding:1rem">
    <div style="background:#fff;border-radius:16px;padding:2rem;max-width:460px;width:100%">
      <h3 style="font-size:1rem;margin-bottom:6px">❌ Rejeitar Solicitação</h3>
      <p id="rejectName" style="font-size:0.85rem;color:#666;margin-bottom:16px"></p>
      <form id="rejectForm" method="POST">
        <div style="margin-bottom:14px">
          <label style="font-size:0.78rem;font-weight:600;color:#555;display:block;margin-bottom:6px">
            Motivo / Observação (opcional)
          </label>
          <textarea name="notes" rows="3" placeholder="Ex: Fora do perfil de cliente..."
            style="width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;font-family:inherit;font-size:0.85rem;resize:vertical;outline:none"></textarea>
        </div>
        <div style="display:flex;gap:10px;justify-content:flex-end">
          <button type="button" onclick="closeRejectModal()"
            style="padding:0.5rem 1.2rem;border:1px solid #ddd;border-radius:8px;background:#fff;cursor:pointer;font-family:inherit">
            Cancelar
          </button>
          <button type="submit"
            style="padding:0.5rem 1.2rem;background:#c62828;color:#fff;border:none;border-radius:8px;cursor:pointer;font-weight:600;font-family:inherit">
            Confirmar Rejeição
          </button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .status-badge { padding:0.3rem 0.85rem;border-radius:20px;font-size:0.75rem;font-weight:600;display:inline-block }
    .status-pending  { background:rgba(251,191,36,0.15);color:#b45309 }
    .status-approved { background:rgba(34,197,94,0.12);color:#2e7d32 }
    .status-rejected { background:rgba(239,68,68,0.1);color:#c62828 }
  </style>

  <script>
    function openRejectModal(id, name) {
      document.getElementById('rejectForm').action = '/admin/solicitacoes/' + id + '/rejeitar';
      document.getElementById('rejectName').textContent = 'Solicitação de: ' + name;
      document.getElementById('rejectModal').style.display = 'flex';
    }
    function closeRejectModal() {
      document.getElementById('rejectModal').style.display = 'none';
    }
    document.getElementById('rejectModal').addEventListener('click', function(e) {
      if (e.target === this) closeRejectModal();
    });
  </script>
</body>
</html>
