<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Criar Proposta — Envox Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <!-- Quill rich text editor -->
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet">
  <style>
    /* ── Quill editor overrides ── */
    .ql-toolbar.ql-snow {
      border: 1px solid #ddd;
      border-bottom: none;
      border-radius: 8px 8px 0 0;
      background: #fafafa;
      padding: 6px 8px;
      font-family: 'Poppins', sans-serif;
    }
    .ql-container.ql-snow {
      border: 1px solid #ddd;
      border-radius: 0 0 8px 8px;
      font-family: 'Poppins', sans-serif;
      font-size: 0.85rem;
      color: #1a1a2e;
    }
    .ql-container.ql-snow:focus-within {
      border-color: #E91E63;
    }
    .ql-toolbar.ql-snow:has(+ .ql-container.ql-snow:focus-within) {
      border-color: #E91E63;
    }
    .ql-editor {
      min-height: 110px;
      max-height: 320px;
      overflow-y: auto;
      line-height: 1.6;
    }
    .ql-editor p { margin: 0 0 0.35em; }
    /* Make toolbar buttons match Poppins feel */
    .ql-snow .ql-picker { font-family: 'Poppins', sans-serif; font-size: 0.78rem; }
    .ql-snow.ql-toolbar button:hover,
    .ql-snow .ql-toolbar button:hover,
    .ql-snow.ql-toolbar button.ql-active,
    .ql-snow .ql-toolbar button.ql-active { color: #E91E63; }
    .ql-snow.ql-toolbar button:hover .ql-stroke,
    .ql-snow .ql-toolbar button:hover .ql-stroke,
    .ql-snow.ql-toolbar button.ql-active .ql-stroke { stroke: #E91E63; }
    .ql-snow.ql-toolbar button:hover .ql-fill,
    .ql-snow .ql-toolbar button:hover .ql-fill,
    .ql-snow.ql-toolbar button.ql-active .ql-fill { fill: #E91E63; }

    /* ── Proposal Builder Extras ──────────────────────────────── */
    .proposal-builder-grid {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 1.5rem;
      align-items: start;
    }
    @media (max-width: 900px) {
      .proposal-builder-grid { grid-template-columns: 1fr; }
    }

    /* Services catalog */
    .services-catalog {
      background: #fff;
      border-radius: 12px;
      border: 1px solid #eee;
      overflow: hidden;
    }
    .catalog-header {
      padding: 1rem 1.25rem;
      background: #f8f9fa;
      border-bottom: 1px solid #eee;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .catalog-header h3 {
      font-size: 0.9rem;
      font-weight: 700;
      color: #1a1a2e;
      margin: 0;
    }
    .catalog-filter {
      display: flex;
      gap: 0.5rem;
    }
    .filter-btn {
      padding: 0.25rem 0.75rem;
      border: 1px solid #ddd;
      border-radius: 20px;
      background: #fff;
      font-size: 0.72rem;
      font-weight: 600;
      color: #666;
      cursor: pointer;
      transition: all 0.15s;
      font-family: Poppins, sans-serif;
    }
    .filter-btn.active, .filter-btn:hover {
      background: #1a1a2e;
      color: #fff;
      border-color: #1a1a2e;
    }

    .catalog-body {
      padding: 0.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    /* Service row */
    .svc-row {
      display: grid;
      grid-template-columns: 24px 1fr auto auto auto;
      align-items: center;
      gap: 0.75rem;
      padding: 0.65rem 0.75rem;
      border-radius: 8px;
      border: 1.5px solid #eee;
      background: #fafafa;
      transition: all 0.15s;
    }
    .svc-row:hover { border-color: #E91E63; background: #fff; }
    .svc-row.selected { border-color: #E91E63; background: #fff9fb; }
    .svc-row.hidden-filter { display: none; }

    .svc-check {
      width: 18px; height: 18px;
      accent-color: #E91E63;
      cursor: pointer;
      flex-shrink: 0;
    }
    .svc-info { min-width: 0; }
    .svc-name {
      font-size: 0.82rem;
      font-weight: 600;
      color: #1a1a2e;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .svc-desc {
      font-size: 0.7rem;
      color: #888;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .svc-badge {
      font-size: 0.65rem;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 10px;
      flex-shrink: 0;
    }
    .svc-badge.monthly { background: #e8f5e9; color: #2e7d32; }
    .svc-badge.onetime { background: #e3f2fd; color: #1565c0; }

    /* Editable price & qty in row */
    .svc-price-field, .svc-qty-field {
      width: 72px;
      padding: 0.3rem 0.45rem;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 0.75rem;
      font-family: Poppins, sans-serif;
      text-align: right;
      background: #fff;
      color: #1a1a2e;
      outline: none;
      transition: border-color 0.15s;
    }
    .svc-price-field:focus, .svc-qty-field:focus { border-color: #E91E63; }
    .svc-qty-field { width: 46px; text-align: center; }
    .svc-price-field:disabled, .svc-qty-field:disabled {
      background: #f5f5f5; color: #bbb; cursor: not-allowed;
    }

    /* Budget preview sidebar */
    .budget-preview-anchor { align-self: start; }
    .budget-preview {
      background: #fff;
      border-radius: 12px;
      border: 1px solid #eee;
      width: 300px;
      transition: box-shadow 0.3s, border-color 0.3s;
    }
    .budget-preview.bp-fixed {
      position: fixed;
      top: 24px;
      box-shadow: 0 8px 32px rgba(233,30,99,0.18);
      border-color: rgba(233,30,99,0.3);
      z-index: 100;
    }
    @keyframes floatPulse{0%{transform:translateY(0)}40%{transform:translateY(-6px)}70%{transform:translateY(3px)}100%{transform:translateY(0)}}
    .budget-preview.float-bounce { animation: floatPulse 0.45s ease; }
    .budget-preview-header {
      padding: 0.9rem 1.1rem;
      background: #1a1a2e;
      color: #fff;
      border-radius: 12px 12px 0 0;
      font-size: 0.82rem;
      font-weight: 700;
    }
    .budget-preview-body {
      padding: 0.75rem 1rem;
      min-height: 120px;
    }
    .preview-empty {
      color: #bbb;
      font-size: 0.78rem;
      text-align: center;
      padding: 2rem 0;
    }
    .preview-item {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.5rem;
      padding: 0.4rem 0;
      border-bottom: 1px solid #f5f5f5;
      font-size: 0.78rem;
    }
    .preview-item-name { color: #333; font-weight: 500; flex: 1; min-width: 0; }
    .preview-item-price { color: #E91E63; font-weight: 700; white-space: nowrap; }
    .preview-total-block {
      padding: 0.75rem 0 0.25rem;
      border-top: 2px solid #eee;
      margin-top: 0.25rem;
    }
    .preview-total-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.8rem;
      padding: 0.2rem 0;
    }
    .preview-total-row.main {
      font-weight: 800;
      font-size: 0.9rem;
      color: #1a1a2e;
    }
    .preview-total-row.onetime { color: #1565c0; }
    .preview-total-row .t-val { color: #E91E63; }

    /* Content sections */
    .content-sections-card {
      background: #fff;
      border-radius: 12px;
      border: 1px solid #eee;
      padding: 1.25rem;
      margin-top: 1.25rem;
    }
    .content-sections-card h3 {
      font-size: 0.85rem;
      font-weight: 700;
      color: #1a1a2e;
      margin: 0 0 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #eee;
    }
    .content-field { margin-bottom: 1.1rem; }
    .content-field label {
      display: block;
      font-size: 0.78rem;
      font-weight: 700;
      color: #555;
      margin-bottom: 0.35rem;
      text-transform: uppercase;
      letter-spacing: 0.4px;
    }
    .content-field textarea {
      width: 100%;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 0.6rem 0.8rem;
      font-size: 0.83rem;
      font-family: Poppins, sans-serif;
      color: #1a1a2e;
      resize: vertical;
      outline: none;
      transition: border-color 0.15s;
      box-sizing: border-box;
    }
    .content-field textarea:focus { border-color: #E91E63; }
    .content-field small { font-size: 0.7rem; color: #999; }

    /* Lead selector multi-chip */
    .lead-select-card {
      background: #fff;
      border-radius: 12px;
      border: 1px solid #eee;
      padding: 1.25rem;
      margin-bottom: 1.25rem;
    }
    .lead-select-card h3 {
      font-size: 0.85rem;
      font-weight: 700;
      color: #1a1a2e;
      margin: 0 0 0.35rem;
    }
    .lead-multi-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.75rem;
      border: 1.5px solid #ddd;
      border-radius: 20px;
      background: #fafafa;
      cursor: pointer;
      font-size: 0.78rem;
      transition: all 0.15s;
      user-select: none;
    }
    .lead-multi-chip:hover { border-color: #E91E63; background: #fff9fb; }
    .lead-multi-chip.checked { border-color: #E91E63; background: #fff0f5; }
    .lead-multi-chip input[type="checkbox"] { display: none; }
    .chip-name { font-weight: 600; color: #1a1a2e; }
    .chip-company { font-size: 0.7rem; color: #888; }
    .lead-multi-chip.checked .chip-name { color: #E91E63; }

    select.form-control {
      width: 100%;
      padding: 0.55rem 0.8rem;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 0.83rem;
      font-family: Poppins, sans-serif;
      color: #1a1a2e;
      background: #fff;
      outline: none;
      cursor: pointer;
      transition: border-color 0.15s;
    }
    select.form-control:focus { border-color: #E91E63; }

    /* Discount preview inside sidebar */
    .disc-preview {
      font-size: 0.72rem;
      color: #2e7d32;
      background: #e8f5e9;
      border-radius: 6px;
      padding: 0.4rem 0.7rem;
      margin-top: 0.5rem;
    }

    /* Form actions */
    .form-actions-sticky {
      position: sticky;
      bottom: 0;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(6px);
      border-top: 1px solid #eee;
      padding: 0.9rem 0;
      margin-top: 1.5rem;
      display: flex;
      gap: 0.75rem;
      align-items: center;
      justify-content: flex-end;
      z-index: 10;
    }

    /* Category section label in catalog */
    .catalog-category-label {
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #999;
      padding: 0.5rem 0.25rem 0.2rem;
    }
  </style>
</head>
<body>
  <div class="top-bar"></div>

  <div class="admin-layout">
    <%- include('../_sidebar', { active: 'new-proposal' }) %>

    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>Criar Proposta</h1>
          <p class="page-subtitle">Selecione os serviços, ajuste valores e adicione conteúdo para o cliente</p>
        </div>
        <a href="/admin" class="btn-outline">← Voltar</a>
      </div>

      <% if (error) { %>
        <div class="alert alert-error"><span>⚠️</span> <%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><span>✅</span> <%= success %></div>
      <% } %>

      <form id="proposalForm" action="/admin/proposals" method="POST">

        <!-- ── Lead selector (multi) ── -->
        <div class="lead-select-card">
          <h3>👥 Leads vinculados à proposta <span style="font-size:0.72rem;font-weight:400;color:#888">(mínimo 1, obrigatório)</span></h3>
          <p style="font-size:0.78rem;color:#888;margin:0 0 0.75rem">Marque todos os leads que terão acesso a esta proposta. O primeiro marcado será o lead primário.</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.75rem">
            <% leads.forEach(lead => { %>
              <label class="lead-multi-chip <%= (selectedLeadId && selectedLeadId == lead.id) ? 'checked' : '' %>" id="chip-<%= lead.id %>">
                <input type="checkbox"
                       name="lead_ids[]"
                       value="<%= lead.id %>"
                       class="lead-chip-check"
                       onchange="onLeadChipChange()"
                       <%= (selectedLeadId && selectedLeadId == lead.id) ? 'checked' : '' %>>
                <span class="chip-name"><%= lead.name %></span>
                <% if (lead.company_name) { %>
                  <span class="chip-company"><%= lead.company_name %></span>
                <% } %>
              </label>
            <% }) %>
            <% if (leads.length === 0) { %>
              <p style="color:#bbb;font-size:0.8rem">Nenhum lead cadastrado. <a href="/admin/leads/new" style="color:#E91E63">Criar lead →</a></p>
            <% } %>
          </div>
          <div id="leadSelInfo" style="display:none;padding:0.5rem 0.75rem;background:#f0fff4;border-radius:8px;border:1px solid #c8e6c9;font-size:0.78rem;color:#2e7d32"></div>
          <!-- Campo hidden para validação obrigatória -->
          <input type="hidden" id="leadIdsValidation" value="">
        </div>

        <!-- ── Proposal Mode Selector ── -->
        <div class="lead-select-card" style="margin-bottom:1.25rem">
          <h3>🎛️ Tipo de Proposta</h3>
          <p style="font-size:0.78rem;color:#888;margin:0 0 1rem">Define quais abas o cliente verá na página de orçamento.</p>
          <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <label style="display:flex;align-items:center;gap:0.6rem;cursor:pointer;padding:0.75rem 1rem;border:2px solid #eee;border-radius:10px;flex:1;min-width:140px;transition:border-color 0.15s" id="mode-label-ready">
              <input type="radio" name="proposal_mode" value="ready" onchange="updateModeLabel()" style="accent-color:#E91E63">
              <div>
                <div style="font-size:0.83rem;font-weight:700;color:#1a1a2e">📋 Proposta Pronta</div>
                <div style="font-size:0.7rem;color:#888">Mostra somente a proposta que você montou aqui</div>
              </div>
            </label>
            <label style="display:flex;align-items:center;gap:0.6rem;cursor:pointer;padding:0.75rem 1rem;border:2px solid #eee;border-radius:10px;flex:1;min-width:140px;transition:border-color 0.15s" id="mode-label-build">
              <input type="radio" name="proposal_mode" value="build" onchange="updateModeLabel()">
              <div>
                <div style="font-size:0.83rem;font-weight:700;color:#1a1a2e">🔧 Montar Proposta</div>
                <div style="font-size:0.7rem;color:#888">Cliente monta a própria proposta (interativo)</div>
              </div>
            </label>
            <label style="display:flex;align-items:center;gap:0.6rem;cursor:pointer;padding:0.75rem 1rem;border:2px solid #E91E63;border-radius:10px;flex:1;min-width:140px;background:rgba(233,30,99,0.04);transition:border-color 0.15s" id="mode-label-both">
              <input type="radio" name="proposal_mode" value="both" checked onchange="updateModeLabel()">
              <div>
                <div style="font-size:0.83rem;font-weight:700;color:#1a1a2e">✨ As 2 Opções</div>
                <div style="font-size:0.7rem;color:#888">Exibe proposta pronta + opção de montar (recomendado)</div>
              </div>
            </label>
          </div>
        </div>

        <!-- ── Builder grid: catalog + preview ── -->
        <div class="proposal-builder-grid">

          <!-- LEFT: Services catalog + content sections -->
          <div>
            <!-- Services catalog -->
            <div class="services-catalog">
              <div class="catalog-header">
                <h3>🛒 Catálogo de Serviços</h3>
                <div class="catalog-filter">
                  <button type="button" class="filter-btn active" onclick="filterCatalog('all', this)">Todos</button>
                  <button type="button" class="filter-btn" onclick="filterCatalog('monthly', this)">Recorrentes</button>
                  <button type="button" class="filter-btn" onclick="filterCatalog('onetime', this)">Pontuais</button>
                </div>
              </div>

              <div class="catalog-body" id="catalogBody">

                <!-- Monthly services header -->
                <% const monthlyServices = services.filter(s => s.category === 'monthly' && s.active); %>
                <% const onetimeServices = services.filter(s => s.category === 'onetime' && s.active); %>

                <% if (monthlyServices.length > 0) { %>
                  <div class="catalog-category-label" data-cat="monthly">📅 Serviços Recorrentes (mensais)</div>
                  <% monthlyServices.forEach((svc, i) => { %>
                    <div class="svc-row" id="svc-row-<%= svc.id %>" data-id="<%= svc.id %>" data-cat="monthly">
                      <input type="checkbox"
                             class="svc-check"
                             id="svc-<%= svc.id %>"
                             onchange="onSvcToggle(<%= svc.id %>)"
                             data-name="<%= svc.name.replace(/"/g, '&quot;') %>"
                             data-desc="<%= (svc.description||'').replace(/"/g, '&quot;') %>"
                             data-default-price="<%= svc.price %>"
                             data-unit="<%= svc.unit || '/mês' %>"
                             data-cat="<%= svc.category %>">
                      <div class="svc-info">
                        <div class="svc-name"><%= svc.name %></div>
                        <% if (svc.description) { %>
                          <div class="svc-desc"><%= svc.description %></div>
                        <% } %>
                      </div>
                      <span class="svc-badge monthly">mensal</span>
                      <input type="number"
                             class="svc-qty-field"
                             id="qty-<%= svc.id %>"
                             value="1"
                             min="1" max="99"
                             disabled
                             title="Quantidade"
                             onchange="updatePreview()"
                             oninput="updatePreview()">
                      <input type="number"
                             class="svc-price-field"
                             id="price-<%= svc.id %>"
                             value="<%= svc.price %>"
                             min="0" step="1"
                             disabled
                             title="Preço unitário (R$)"
                             onchange="updatePreview()"
                             oninput="updatePreview()">
                    </div>
                  <% }) %>
                <% } %>

                <% if (onetimeServices.length > 0) { %>
                  <div class="catalog-category-label" data-cat="onetime">💳 Serviços Pontuais (pagamento único)</div>
                  <% onetimeServices.forEach((svc, i) => { %>
                    <div class="svc-row" id="svc-row-<%= svc.id %>" data-id="<%= svc.id %>" data-cat="onetime">
                      <input type="checkbox"
                             class="svc-check"
                             id="svc-<%= svc.id %>"
                             onchange="onSvcToggle(<%= svc.id %>)"
                             data-name="<%= svc.name.replace(/"/g, '&quot;') %>"
                             data-desc="<%= (svc.description||'').replace(/"/g, '&quot;') %>"
                             data-default-price="<%= svc.price %>"
                             data-unit="<%= svc.unit || 'único' %>"
                             data-cat="<%= svc.category %>">
                      <div class="svc-info">
                        <div class="svc-name"><%= svc.name %></div>
                        <% if (svc.description) { %>
                          <div class="svc-desc"><%= svc.description %></div>
                        <% } %>
                      </div>
                      <span class="svc-badge onetime">único</span>
                      <input type="number"
                             class="svc-qty-field"
                             id="qty-<%= svc.id %>"
                             value="1"
                             min="1" max="99"
                             disabled
                             title="Quantidade"
                             onchange="updatePreview()"
                             oninput="updatePreview()">
                      <input type="number"
                             class="svc-price-field"
                             id="price-<%= svc.id %>"
                             value="<%= svc.price %>"
                             min="0" step="1"
                             disabled
                             title="Preço unitário (R$)"
                             onchange="updatePreview()"
                             oninput="updatePreview()">
                    </div>
                  <% }) %>
                <% } %>

                <% if (services.length === 0) { %>
                  <div style="text-align:center;padding:2rem;color:#bbb;font-size:0.82rem">
                    Nenhum serviço cadastrado.<br>
                    <a href="/admin/services" style="color:#E91E63">Cadastrar serviços →</a>
                  </div>
                <% } %>
              </div>
            </div>

            <!-- Content sections -->
            <div class="content-sections-card">
              <h3>📝 Conteúdo da Proposta (opcional)</h3>

              <!-- hidden inputs que o form envia -->
              <input type="hidden" id="proposal_description" name="proposal_description" value="<%= formData ? (formData.proposal_description || '') : '' %>">
              <input type="hidden" id="proposal_scope"       name="proposal_scope"       value="<%= formData ? (formData.proposal_scope || '') : '' %>">
              <input type="hidden" id="proposal_timeline"    name="proposal_timeline"    value="<%= formData ? (formData.proposal_timeline || '') : '' %>">

              <div class="content-field">
                <label>📄 Descrição</label>
                <div id="editor-description"></div>
                <small>Apresentação geral da proposta para o cliente — aceita formatação colada do Word</small>
              </div>

              <div class="content-field">
                <label>🎯 Escopo</label>
                <div id="editor-scope"></div>
                <small>O que está incluído no escopo desta proposta</small>
              </div>

              <div class="content-field">
                <label>📅 Cronograma</label>
                <div id="editor-timeline"></div>
                <small>Prazos, etapas e cronograma de entrega</small>
              </div>
            </div>
          </div>

          <!-- RIGHT: Budget preview sidebar -->
          <div class="budget-preview-anchor" id="budgetAnchor">
            <div class="budget-preview" id="budgetPreview">
              <div class="budget-preview-header">
                📊 Resumo do Orçamento
              </div>
              <div class="budget-preview-body" id="budgetPreviewBody">
                <p class="preview-empty">Selecione serviços ao lado para montar o orçamento</p>
              </div>
              <div style="padding:0 1rem 1rem">
                <div id="discountPreviewBlock" style="display:none">
                  <div class="disc-preview" id="discountPreviewText"></div>
                </div>
              </div>
            </div>

            <!-- Hidden inputs will be injected here by JS before submit -->
            <div id="hiddenItemsContainer"></div>
          </div>
        </div>

        <!-- Sticky footer actions -->
        <div class="form-actions-sticky">
          <a href="/admin" class="btn-outline">Cancelar</a>
          <button type="button" class="btn-outline" onclick="previewProposal()" id="btnPreview" style="display:none">
            👁️ Ver Proposta
          </button>
          <button type="submit" class="btn-primary" id="btnSave">
            💾 Salvar Proposta
          </button>
        </div>

      </form>
    </main>
  </div>

  <!-- DATA from server -->
  <script>
    // Services data from DB (for JS use)
    const SERVICES_DATA = <%- JSON.stringify(services) %>;
    const LEADS_DATA    = <%- JSON.stringify(leads) %>;
    let currentLeadDiscount = { monthly: 0, onetime: 0, expires: '' };
    // Initial content for rich editors (empty on new form)
    const EDITOR_INIT = {
      description: <%- JSON.stringify(formData ? formData.proposal_description || '' : '') %>,
      scope:       <%- JSON.stringify(formData ? formData.proposal_scope       || '' : '') %>,
      timeline:    <%- JSON.stringify(formData ? formData.proposal_timeline    || '' : '') %>
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>

  <script>
    // ── Multi Lead selector ───────────────────────────────────────────
    function onLeadChipChange() {
      const checked = document.querySelectorAll('.lead-chip-check:checked');
      // Update chip visual
      document.querySelectorAll('.lead-multi-chip').forEach(chip => {
        const chk = chip.querySelector('input[type="checkbox"]');
        chip.classList.toggle('checked', chk.checked);
      });

      const infoEl = document.getElementById('leadSelInfo');
      const valEl  = document.getElementById('leadIdsValidation');

      if (checked.length === 0) {
        infoEl.style.display = 'none';
        valEl.value = '';
        document.getElementById('btnPreview').style.display = 'none';
        return;
      }

      const names = Array.from(checked).map(c => {
        const chip = c.closest('.lead-multi-chip');
        return chip.querySelector('.chip-name').textContent;
      });
      infoEl.style.display = 'block';
      infoEl.textContent = `✅ ${checked.length} lead(s) selecionado(s): ${names.join(', ')}. O primeiro será o lead primário.`;
      valEl.value = '1'; // marca como válido

      document.getElementById('btnPreview').style.display = 'inline-flex';
      updatePreview();
    }

    // ── Toggle service checkbox ───────────────────────────────────────
    function onSvcToggle(svcId) {
      const chk   = document.getElementById('svc-' + svcId);
      const row   = document.getElementById('svc-row-' + svcId);
      const priceF = document.getElementById('price-' + svcId);
      const qtyF   = document.getElementById('qty-' + svcId);

      const checked = chk.checked;
      row.classList.toggle('selected', checked);
      priceF.disabled = !checked;
      qtyF.disabled   = !checked;

      if (checked) {
        // Reset price to default when first checked
        priceF.value = chk.dataset.defaultPrice;
        qtyF.value   = 1;
        priceF.focus();
      }
      updatePreview();
    }

    // ── Catalog filter ────────────────────────────────────────────────
    function filterCatalog(cat, btn) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      document.querySelectorAll('.svc-row').forEach(row => {
        if (cat === 'all' || row.dataset.cat === cat) {
          row.classList.remove('hidden-filter');
        } else {
          row.classList.add('hidden-filter');
        }
      });
      // Show/hide category labels
      document.querySelectorAll('.catalog-category-label').forEach(lbl => {
        if (cat === 'all' || lbl.dataset.cat === cat) {
          lbl.style.display = '';
        } else {
          lbl.style.display = 'none';
        }
      });
    }

    // ── Update budget preview ─────────────────────────────────────────
    function fmtBRL(v) {
      return 'R$ ' + Number(v).toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    function updatePreview() {
      const previewBody = document.getElementById('budgetPreviewBody');
      const checkedBoxes = document.querySelectorAll('.svc-check:checked');

      if (checkedBoxes.length === 0) {
        previewBody.innerHTML = '<p class="preview-empty">Selecione serviços ao lado para montar o orçamento</p>';
        return;
      }

      let monthlyTotal = 0;
      let onetimeTotal = 0;
      let html = '';

      checkedBoxes.forEach(chk => {
        const svcId = chk.id.replace('svc-', '');
        const priceF = document.getElementById('price-' + svcId);
        const qtyF   = document.getElementById('qty-' + svcId);
        const price  = parseFloat(priceF?.value) || 0;
        const qty    = parseInt(qtyF?.value) || 1;
        const total  = price * qty;
        const cat    = chk.dataset.cat;
        const name   = chk.dataset.name;
        const unit   = chk.dataset.unit;

        if (cat === 'onetime') onetimeTotal += total;
        else monthlyTotal += total;

        html += `<div class="preview-item">
          <span class="preview-item-name">${name}${qty > 1 ? ' ×' + qty : ''}</span>
          <span class="preview-item-price">${fmtBRL(total)}</span>
        </div>`;
      });

      // Totals
      const discM = currentLeadDiscount.monthly || 0;
      const discO = currentLeadDiscount.onetime  || 0;
      let discActive = (discM > 0 || discO > 0);
      if (currentLeadDiscount.expires) {
        const exp = new Date(currentLeadDiscount.expires + 'T23:59:59');
        if (exp < new Date()) discActive = false;
      }

      html += '<div class="preview-total-block">';
      if (monthlyTotal > 0) {
        html += `<div class="preview-total-row main">
          <span>Mensal</span>
          <span class="t-val">${fmtBRL(monthlyTotal)}<span style="font-size:0.65rem;opacity:0.6">/mês</span></span>
        </div>`;
        if (discActive && discM > 0) {
          const after = Math.round(monthlyTotal * (1 - discM / 100));
          html += `<div class="preview-total-row" style="font-size:0.72rem;color:#2e7d32">
            <span>Com ${discM}% desc.</span>
            <span>${fmtBRL(after)}/mês</span>
          </div>`;
        }
      }
      if (onetimeTotal > 0) {
        html += `<div class="preview-total-row onetime main">
          <span>Único</span>
          <span class="t-val" style="color:#1565c0">${fmtBRL(onetimeTotal)}</span>
        </div>`;
        if (discActive && discO > 0) {
          const after = Math.round(onetimeTotal * (1 - discO / 100));
          html += `<div class="preview-total-row" style="font-size:0.72rem;color:#2e7d32">
            <span>Com ${discO}% desc.</span>
            <span>${fmtBRL(after)}</span>
          </div>`;
        }
      }
      html += '</div>';

      previewBody.innerHTML = html;
    }

    // ── Inject hidden fields for selected items before submit ─────────
    document.getElementById('proposalForm').addEventListener('submit', function(e) {
      const checked = document.querySelectorAll('.lead-chip-check:checked');
      if (checked.length === 0) {
        e.preventDefault();
        alert('Por favor, selecione pelo menos 1 lead.');
        return;
      }

      // Build items JSON
      const items = [];
      document.querySelectorAll('.svc-check:checked').forEach(chk => {
        const svcId = chk.id.replace('svc-', '');
        const priceF = document.getElementById('price-' + svcId);
        const qtyF   = document.getElementById('qty-' + svcId);
        const svc = SERVICES_DATA.find(s => s.id == svcId);

        items.push({
          service_id: parseInt(svcId),
          name: chk.dataset.name,
          description: chk.dataset.desc,
          price: parseFloat(priceF?.value) || 0,
          qty: parseInt(qtyF?.value) || 1,
          unit: chk.dataset.unit,
          category: chk.dataset.cat,
          sort_order: items.length
        });
      });

      // Inject as hidden input
      const container = document.getElementById('hiddenItemsContainer');
      container.innerHTML = '';
      const hiddenItems = document.createElement('input');
      hiddenItems.type  = 'hidden';
      hiddenItems.name  = 'proposal_items';
      hiddenItems.value = JSON.stringify(items);
      container.appendChild(hiddenItems);
    });

    // ── Preview button: disponível somente após salvar ────────────────
    function previewProposal() {
      alert('Salve a proposta primeiro para pré-visualizar.');
    }

    // ── Mode label highlight ──────────────────────────────────────────
    function updateModeLabel() {
      const radios = document.querySelectorAll('input[name="proposal_mode"]');
      radios.forEach(r => {
        const lbl = document.getElementById('mode-label-' + r.value);
        if (lbl) {
          lbl.style.borderColor = r.checked ? '#E91E63' : '#eee';
          lbl.style.background  = r.checked ? 'rgba(233,30,99,0.04)' : '';
        }
      });
    }

    // ── Rich text editors (Quill) ─────────────────────────────────
    const QUILL_TOOLBAR = [
      [{ header: [1, 2, 3, false] }],
      ['bold', 'italic', 'underline'],
      [{ list: 'ordered' }, { list: 'bullet' }],
      ['clean']
    ];
    const quillDesc     = new Quill('#editor-description', { theme: 'snow', modules: { toolbar: QUILL_TOOLBAR }, placeholder: 'Descreva a proposta de forma geral...' });
    const quillScope    = new Quill('#editor-scope',       { theme: 'snow', modules: { toolbar: QUILL_TOOLBAR }, placeholder: 'Liste o que está incluído no escopo...' });
    const quillTimeline = new Quill('#editor-timeline',    { theme: 'snow', modules: { toolbar: QUILL_TOOLBAR }, placeholder: 'Descreva o cronograma ou prazos...' });

    // Populate with server-side values if editing (e.g. form re-render on error)
    if (EDITOR_INIT.description) quillDesc.clipboard.dangerouslyPasteHTML(EDITOR_INIT.description);
    if (EDITOR_INIT.scope)       quillScope.clipboard.dangerouslyPasteHTML(EDITOR_INIT.scope);
    if (EDITOR_INIT.timeline)    quillTimeline.clipboard.dangerouslyPasteHTML(EDITOR_INIT.timeline);

    // Sync Quill HTML → hidden inputs before submit
    document.getElementById('proposalForm').addEventListener('submit', function syncQuill() {
      document.getElementById('proposal_description').value = quillDesc.getSemanticHTML();
      document.getElementById('proposal_scope').value       = quillScope.getSemanticHTML();
      document.getElementById('proposal_timeline').value    = quillTimeline.getSemanticHTML();
    }, true); // capture phase — runs BEFORE the existing submit handler

    // Init: trigger chip update if pre-selected
    onLeadChipChange();

    // ── Budget preview fixed ao rolar ─────────────────────────
    (function() {
      const bp     = document.getElementById('budgetPreview');
      const anchor = document.getElementById('budgetAnchor');
      if (!bp || !anchor) return;
      let wasFixed = false;
      function syncFixed() {
        const ar = anchor.getBoundingClientRect();
        const shouldFix = ar.top < 24;
        if (shouldFix === wasFixed) return;
        wasFixed = shouldFix;
        if (shouldFix) {
          bp.style.left  = ar.left + 'px';
          bp.style.width = ar.width + 'px';
          bp.classList.add('bp-fixed');
          bp.classList.remove('float-bounce');
          void bp.offsetWidth;
          bp.classList.add('float-bounce');
        } else {
          bp.classList.remove('bp-fixed', 'float-bounce');
          bp.style.left = bp.style.width = '';
        }
      }
      window.addEventListener('scroll',  syncFixed, { passive: true });
      window.addEventListener('resize',  syncFixed, { passive: true });
      syncFixed();
    })();
  </script>
</body>
</html>
