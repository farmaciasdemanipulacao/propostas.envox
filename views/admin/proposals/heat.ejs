<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calor — Proposta #<%= proposal.id %> — Envox Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    /* ── Heatmap ─────────────────────────────────────────────────── */
    .heatmap-grid { display:grid;grid-template-columns:repeat(5,1fr);gap:0.5rem;margin-bottom:1rem; }
    @media(max-width:700px){ .heatmap-grid { grid-template-columns:repeat(2,1fr); } }
    .heatmap-cell { border-radius:8px;padding:0.65rem 0.4rem;text-align:center;border:2px solid #eee;transition:transform 0.1s; }
    .heatmap-cell:hover { transform:scale(1.03); }
    .heat-none { background:#f0f0f2;border-color:#ddd;color:#999; }
    .heat-1    { background:#dbeafe;border-color:#93c5fd;color:#1e40af; }
    .heat-2    { background:#d1fae5;border-color:#6ee7b7;color:#065f46; }
    .heat-3    { background:#fef9c3;border-color:#fde047;color:#713f12; }
    .heat-4    { background:#ffedd5;border-color:#fb923c;color:#7c2d12; }
    .heat-5    { background:#fee2e2;border-color:#f87171;color:#7f1d1d; }
    .heat-number { font-size:0.65rem;font-weight:700;opacity:0.6;margin-bottom:2px; }
    .heat-name   { font-size:0.62rem;font-weight:600;line-height:1.2;margin-bottom:6px;min-height:26px; }
    .heat-stats  { display:flex;flex-direction:column;gap:2px; }
    .heat-stat   { font-size:0.78rem;font-weight:800; }
    .heat-stat-label { font-size:0.58rem;font-weight:600;opacity:0.65;letter-spacing:0.02em;text-transform:uppercase; }
    .heat-divider { height:1px;background:currentColor;opacity:0.15;margin:3px 0; }
    .heatmap-legend { display:flex;gap:0.75rem;flex-wrap:wrap;font-size:0.72rem;color:#444;align-items:center;margin-top:0.75rem; }
    .legend-dot { width:12px;height:12px;border-radius:3px;display:inline-block;margin-right:3px;vertical-align:middle; }
    .ld-none { background:#f0f0f2;border:1.5px solid #ddd; }
    .ld-1    { background:#dbeafe;border:1.5px solid #93c5fd; }
    .ld-2    { background:#d1fae5;border:1.5px solid #6ee7b7; }
    .ld-3    { background:#fef9c3;border:1.5px solid #fde047; }
    .ld-4    { background:#ffedd5;border:1.5px solid #fb923c; }
    .ld-5    { background:#fee2e2;border:1.5px solid #f87171; }

    /* ── Report lead selector ─────────────────────────────────────── */
    .report-lead-selector { display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;align-items:center; }
    .rls-btn {
      padding:0.3rem 0.75rem;border:1.5px solid #ddd;border-radius:20px;
      background:#fff;font-size:0.75rem;font-weight:600;color:#555;
      cursor:pointer;font-family:Poppins,sans-serif;transition:all 0.15s;
    }
    .rls-btn:hover { border-color:#E91E63;color:#E91E63; }
    .rls-btn.active { border-color:#E91E63;background:#fff0f5;color:#E91E63; }

    /* ── Metrics ─────────────────────────────────────────────────── */
    .metrics-grid { display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem; }
    @media(max-width:700px){ .metrics-grid { grid-template-columns:repeat(2,1fr); } }
    .metric-item { background:#f8f9fa;border-radius:10px;padding:1rem;text-align:center; }
    .metric-value { font-size:1.6rem;font-weight:800;color:#1a1a2e;line-height:1; }
    .metric-label { font-size:0.72rem;color:#888;font-weight:600;margin-top:4px; }

    /* ── Chart ───────────────────────────────────────────────────── */
    .chart-wrap { position:relative;height:240px; }

    /* ── Event log ───────────────────────────────────────────────── */
    .event-log { display:flex;flex-direction:column;gap:0; }
    .event-item { display:grid;grid-template-columns:160px 20px 1fr;align-items:center;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid #f5f5f5;font-size:0.8rem; }
    .event-time { color:#888;font-size:0.72rem; }
    .event-dot  { width:8px;height:8px;border-radius:50%;background:#E91E63;justify-self:center; }
    .event-text { color:#333; }

    /* ── Badges ───────────────────────────────────────────────────── */
    .badge { display:inline-block;padding:3px 10px;border-radius:20px;font-size:0.72rem;font-weight:700; }
    .badge-success { background:rgba(46,125,50,0.1);color:#2e7d32; }
    .badge-warning { background:rgba(245,124,0,0.1);color:#f57c00; }

    /* ── Header breadcrumb ─────────────────────────────────────────── */
    .heat-header {
      display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;
      gap:1rem;margin-bottom:1.5rem;
    }
    .heat-title { font-size:1.3rem;font-weight:800;color:#1a1a2e; }
    .heat-subtitle { font-size:0.82rem;color:#888;margin-top:2px; }
    .heat-breadcrumb { display:flex;align-items:center;gap:0.5rem;font-size:0.8rem;color:#888; }
    .heat-breadcrumb a { color:#E91E63;text-decoration:none;font-weight:600; }
    .heat-breadcrumb a:hover { text-decoration:underline; }
    .btn-sm-heat {
      padding:0.35rem 0.85rem;border:1.5px solid #E91E63;border-radius:8px;
      background:#fff0f5;color:#E91E63;font-size:0.78rem;font-weight:700;
      text-decoration:none;font-family:Poppins,sans-serif;
      display:inline-flex;align-items:center;gap:0.35rem;
    }
    .btn-sm-heat:hover { background:#E91E63;color:#fff; }
  </style>
</head>
<body>
  <div class="top-bar"></div>
  <div class="admin-layout">
    <%- include('../_sidebar', { active: 'proposals' }) %>
    <main class="main-content">

      <!-- Header -->
      <div class="heat-header">
        <div>
          <div class="heat-breadcrumb">
            <a href="/admin/proposals">← Propostas</a>
            <span>/</span>
            <a href="/admin/proposals/<%= proposal.id %>/edit">Proposta #<%= proposal.id %></a>
            <span>/</span>
            <span>Calor</span>
          </div>
          <div class="heat-title">🌡️ Relatório de Calor</div>
          <div class="heat-subtitle">
            <% const primaryLead = (proposal.leads || []).find(l => l.is_primary) || (proposal.leads || [])[0]; %>
            <% if (primaryLead) { %>
              <%= primaryLead.name %><% if (primaryLead.company_name) { %> — <%= primaryLead.company_name %><% } %>
            <% } %>
            · Proposta #<%= proposal.id %>
          </div>
        </div>
        <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap">
          <a href="/admin/proposals/<%= proposal.id %>/edit" class="btn-sm-heat">✏️ Editar Proposta</a>
          <a href="/admin/proposals/<%= proposal.id %>/view" class="btn-sm-heat" style="border-color:#1565c0;background:#e3f2fd;color:#1565c0" target="_blank">👁️ Ver Proposta</a>
        </div>
      </div>

      <!-- ══ 1. RELATÓRIO DE ENGAJAMENTO ══ -->
      <div class="detail-card full-width-card">
        <h3 class="card-title">📊 Relatório de Engajamento</h3>

        <!-- Seletor de lead -->
        <div class="report-lead-selector">
          <span style="font-size:0.75rem;color:#888;font-weight:600">Ver:</span>
          <button class="rls-btn active" onclick="switchReport('all', this)">
            Todos os leads (<%= stats.totalAccesses %> acessos)
          </button>
          <% (proposal.leads || []).forEach(lead => { %>
            <button class="rls-btn" onclick="switchReport(<%= lead.id %>, this)">
              <%= lead.name %><% if (lead.is_primary) { %> ⭐<% } %>
            </button>
          <% }) %>
        </div>

        <!-- Métricas -->
        <div class="metrics-grid" id="reportMetrics">
          <div class="metric-item">
            <div class="metric-value" id="metricAccesses"><%= stats.totalAccesses %></div>
            <div class="metric-label">Acessos</div>
          </div>
          <div class="metric-item">
            <%
              const tm = Math.floor(stats.totalDuration/60);
              const ts = stats.totalDuration % 60;
            %>
            <div class="metric-value" id="metricDuration"><%= tm %>m<%= ts %>s</div>
            <div class="metric-label">Tempo Total</div>
          </div>
          <div class="metric-item">
            <div class="metric-value" id="metricSlides"><%= stats.totalSlidesSeen %>/10</div>
            <div class="metric-label">Slides Vistos</div>
          </div>
          <div class="metric-item">
            <% const revisitsAll = stats.slideStats ? stats.slideStats.filter(s => s.revisit_count > 0).length : 0; %>
            <div class="metric-value" id="metricRevisits"><%= revisitsAll %></div>
            <div class="metric-label">Slides Revisitados</div>
          </div>
        </div>
      </div>

      <!-- ══ 2. GRÁFICO TEMPO POR SLIDE ══ -->
      <div class="detail-card full-width-card">
        <h3 class="card-title">📈 Tempo por Slide (segundos)</h3>
        <div class="chart-wrap">
          <canvas id="slideChart"></canvas>
        </div>
      </div>

      <!-- ══ 3. MAPA DE CALOR ══ -->
      <div class="detail-card full-width-card">
        <h3 class="card-title">🔥 Mapa de Calor — Engajamento por Slide</h3>
        <div class="heatmap-grid" id="heatmapGrid">
          <%
          const _slideNames = ['','Capa','O Problema','A Solução','SDR + Ads',
            'Clientes','Como Trabalhamos','Orçamento','Solicitar Proposta',
            'FAQ','Agradecimento'];
          function _heatClass(dur) {
            if (dur <= 0)   return 'heat-none';
            if (dur < 15)   return 'heat-1';
            if (dur < 45)   return 'heat-2';
            if (dur < 120)  return 'heat-3';
            if (dur < 300)  return 'heat-4';
            return 'heat-5';
          }
          for (let _i = 1; _i <= 10; _i++) {
            const _ss = (stats.slideStats || []).find(s => s.slide_number === _i);
            const _dur = _ss ? Math.round(_ss.total_duration || 0) : 0;
            const _views = _ss ? (_ss.view_count || 0) : 0;
            const _avg = _views > 0 ? Math.round(_dur / _views) : 0;
            const _hc = _heatClass(_dur);
          %>
            <div class="heatmap-cell <%= _hc %>" id="hcell-<%= _i %>">
              <div class="heat-number"><%= _i %></div>
              <div class="heat-name"><%= _slideNames[_i] %></div>
              <div class="heat-stats">
                <div class="heat-stat" id="hcell-<%= _i %>-dur"><%= _dur %>s</div>
                <div class="heat-stat-label">tempo total</div>
                <div class="heat-divider"></div>
                <div class="heat-stat" id="hcell-<%= _i %>-views"><%= _views %> viz.</div>
                <div class="heat-stat-label">visualizações</div>
                <div class="heat-divider"></div>
                <div class="heat-stat" id="hcell-<%= _i %>-avg"><%= _avg %>s/viz</div>
                <div class="heat-stat-label">média</div>
              </div>
            </div>
          <% } %>
        </div>
        <div class="heatmap-legend">
          <span><span class="legend-dot ld-none"></span> Não visto</span>
          <span><span class="legend-dot ld-1"></span> Frio (&lt;15s)</span>
          <span><span class="legend-dot ld-2"></span> Baixo (15–44s)</span>
          <span><span class="legend-dot ld-3"></span> Médio (45–119s)</span>
          <span><span class="legend-dot ld-4"></span> Quente (120–299s)</span>
          <span><span class="legend-dot ld-5"></span> Muito Quente (300s+)</span>
        </div>
      </div>

      <!-- Histórico de Sessões -->
      <% if (stats.sessions && stats.sessions.length > 0) { %>
      <div class="detail-card full-width-card">
        <h3 class="card-title">🕐 Histórico de Acessos</h3>
        <table class="data-table">
          <thead>
            <tr><th>Lead</th><th>#</th><th>Início</th><th>Fim</th><th>Duração</th><th>Alerta WA</th></tr>
          </thead>
          <tbody>
            <% stats.sessions.forEach((sess, idx) => { %>
            <tr>
              <td style="font-size:0.8rem;font-weight:600;color:#555"><%= sess.lead_name || '—' %></td>
              <td><%= stats.sessions.length - idx %></td>
              <td><small><%= new Date(sess.started_at).toLocaleString('pt-BR') %></small></td>
              <td>
                <% if (sess.ended_at) { %>
                  <small><%= new Date(sess.ended_at).toLocaleString('pt-BR') %></small>
                <% } else { %><span class="badge badge-warning">Em andamento</span><% } %>
              </td>
              <td>
                <% const _dm = Math.floor((sess.total_duration_seconds||0)/60); %>
                <% const _ds = (sess.total_duration_seconds||0)%60; %>
                <%= _dm %>m<%= _ds %>s
              </td>
              <td><%= sess.alert_sent ? '✅' : '—' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

      <!-- ══ 4. LOG DE EVENTOS ══ -->
      <div class="detail-card full-width-card">
        <h3 class="card-title">📋 Log de Eventos</h3>
        <% if (eventLog && eventLog.length > 0) { %>
          <div class="event-log">
            <% eventLog.slice(0, 100).forEach(ev => { %>
              <div class="event-item event-<%= ev.event_type %>">
                <div class="event-time"><%= new Date(ev.timestamp).toLocaleString('pt-BR') %></div>
                <div class="event-dot"></div>
                <div class="event-text">
                  <% if (ev.lead_name) { %><span style="font-weight:600;color:#E91E63"><%= ev.lead_name %>:</span> <% } %>
                  <% if (ev.event_type === 'proposal_opened') { %>🔓 Abriu a proposta
                  <% } else if (ev.event_type === 'proposal_closed') { %>🔒 Fechou a proposta
                    <% if (ev.parsedDetails && ev.parsedDetails.total_duration) { %><small>(<%= Math.round(ev.parsedDetails.total_duration) %>s)</small><% } %>
                  <% } else if (ev.event_type === 'slide_viewed') { %>👁️ Visualizou slide
                    <% if (ev.parsedDetails && ev.parsedDetails.slide_number) { %><small>slide <%= ev.parsedDetails.slide_number %></small><% } %>
                    <% if (ev.parsedDetails && ev.parsedDetails.duration_seconds > 0) { %><small>(<%= Math.round(ev.parsedDetails.duration_seconds) %>s)</small><% } %>
                  <% } else if (ev.event_type === 'slide_revisited') { %>🔄 Revisitou slide
                    <% if (ev.parsedDetails && ev.parsedDetails.slide_number) { %><small>slide <%= ev.parsedDetails.slide_number %></small><% } %>
                  <% } else if (ev.event_type === 'proposal_shared') { %>📤 Compartilhou com <%= ev.parsedDetails ? ev.parsedDetails.shared_with : '' %>
                  <% } else if (ev.event_type === 'proposal_action') { %>⚖️ <%= ev.parsedDetails ? ev.parsedDetails.action_type : 'ação' %>
                  <% } else if (ev.event_type === 'shared_view') { %>🔗 Acesso via link compartilhado
                  <% } else { %>ℹ️ <%= ev.event_type %><% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div style="text-align:center;padding:2.5rem;color:#bbb">
            <div style="font-size:2rem;margin-bottom:0.5rem">📭</div>
            <p style="font-size:0.85rem">Nenhum evento registrado ainda.<br>Os dados aparecerão aqui após o lead acessar a proposta.</p>
          </div>
        <% } %>
      </div>

    </main>
  </div>

  <script>
    // ── Report data from server ────────────────────────────────────────
    const SLIDE_LABELS   = <%- slideLabels %>;
    const ALL_DURATIONS  = <%- slideDurationsAll %>;
    const ALL_COLORS     = <%- slideColorsAll %>;
    const PER_LEAD_STATS = <%- perLeadStats %>;
    const ALL_VIEW_COUNTS = <%- JSON.stringify(Array.from({length:10},(_,i)=>{ const s=(stats.slideStats||[]).find(x=>x.slide_number===i+1); return s ? (s.view_count||0) : 0; })) %>;

    // ── Chart.js ──────────────────────────────────────────────────────
    const ctx = document.getElementById('slideChart').getContext('2d');
    let chart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: SLIDE_LABELS,
        datasets: [{
          label: 'Tempo (segundos)',
          data: ALL_DURATIONS,
          backgroundColor: ALL_COLORS,
          borderRadius: 6,
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: ctx => `${ctx.raw}s de visualização` } }
        },
        scales: {
          y: { beginAtZero: true, grid: { color: '#f0f0f0' }, ticks: { callback: v => v + 's' } },
          x: { grid: { display: false } }
        }
      }
    });

    // ── Heatmap colour scale (frio → quente) ──────────────────────────
    function heatClass(dur) {
      if (dur <= 0)  return 'heat-none';
      if (dur < 15)  return 'heat-1';
      if (dur < 45)  return 'heat-2';
      if (dur < 120) return 'heat-3';
      if (dur < 300) return 'heat-4';
      return 'heat-5';
    }

    // ── Heatmap renderer ──────────────────────────────────────────────
    function renderHeatmap(durations, viewCounts) {
      const vc = viewCounts || new Array(10).fill(0);
      for (let i = 1; i <= 10; i++) {
        const cell = document.getElementById('hcell-' + i);
        if (!cell) continue;
        const dur   = Math.round(durations[i - 1] || 0);
        const views = vc[i - 1] || 0;
        const avg   = views > 0 ? Math.round(dur / views) : 0;
        cell.className = 'heatmap-cell ' + heatClass(dur);
        const durEl   = document.getElementById('hcell-' + i + '-dur');
        const viewsEl = document.getElementById('hcell-' + i + '-views');
        const avgEl   = document.getElementById('hcell-' + i + '-avg');
        if (durEl)   durEl.textContent   = dur + 's';
        if (viewsEl) viewsEl.textContent = views + ' viz.';
        if (avgEl)   avgEl.textContent   = avg + 's/viz';
      }
    }

    // Init
    renderHeatmap(ALL_DURATIONS, ALL_VIEW_COUNTS);

    // ── Switch report lead selector ────────────────────────────────────
    function switchReport(leadId, btn) {
      document.querySelectorAll('.rls-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      let durations, colors, viewCounts, accesses, totalDur, slidesSeen, revisits;

      if (leadId === 'all') {
        durations  = ALL_DURATIONS;
        colors     = ALL_COLORS;
        viewCounts = ALL_VIEW_COUNTS;
        accesses   = <%= stats.totalAccesses %>;
        totalDur   = <%= stats.totalDuration %>;
        slidesSeen = <%= stats.totalSlidesSeen %>;
        revisits   = <%= stats.slideStats ? stats.slideStats.filter(s => s.revisit_count > 0).length : 0 %>;
      } else {
        const perLead = PER_LEAD_STATS.find(p => p.lead_id == leadId);
        durations  = perLead ? perLead.durations  : new Array(10).fill(0);
        colors     = perLead ? perLead.colors      : new Array(10).fill('#e0e0e0');
        viewCounts = perLead ? (perLead.viewCounts || new Array(10).fill(0)) : new Array(10).fill(0);
        accesses   = perLead ? (perLead.accesses   || 0) : 0;
        totalDur   = perLead ? (perLead.totalDur   || 0) : 0;
        slidesSeen = perLead ? (perLead.slidesSeen || 0) : 0;
        revisits   = perLead ? (perLead.revisits   || 0) : 0;
      }

      // Atualizar gráfico
      chart.data.datasets[0].data = durations;
      chart.data.datasets[0].backgroundColor = colors;
      chart.update();

      // Atualizar heatmap
      renderHeatmap(durations, viewCounts);

      // Atualizar métricas
      document.getElementById('metricAccesses').textContent = accesses;
      const mm = Math.floor(totalDur / 60), ms = totalDur % 60;
      document.getElementById('metricDuration').textContent = mm + 'm' + ms + 's';
      document.getElementById('metricSlides').textContent   = slidesSeen + '/10';
      document.getElementById('metricRevisits').textContent = revisits;
    }
  </script>
</body>
</html>
