<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Proposta #<%= proposal.id %> — Envox Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .proposal-builder-grid { display:grid;grid-template-columns:1fr 300px;gap:1.5rem;align-items:start; }
    @media(max-width:900px){.proposal-builder-grid{grid-template-columns:1fr;}}
    .services-catalog{background:#fff;border-radius:12px;border:1px solid #eee;overflow:hidden;}
    .catalog-header{padding:1rem 1.25rem;background:#f8f9fa;border-bottom:1px solid #eee;display:flex;align-items:center;justify-content:space-between;gap:1rem;}
    .catalog-header h3{font-size:0.9rem;font-weight:700;color:#1a1a2e;margin:0;}
    .catalog-filter{display:flex;gap:0.5rem;}
    .filter-btn{padding:0.25rem 0.75rem;border:1px solid #ddd;border-radius:20px;background:#fff;font-size:0.72rem;font-weight:600;color:#666;cursor:pointer;transition:all 0.15s;font-family:Poppins,sans-serif;}
    .filter-btn.active,.filter-btn:hover{background:#1a1a2e;color:#fff;border-color:#1a1a2e;}
    .catalog-body{padding:0.75rem;display:flex;flex-direction:column;gap:0.5rem;}
    .svc-row{display:grid;grid-template-columns:24px 1fr auto auto auto;align-items:center;gap:0.75rem;padding:0.65rem 0.75rem;border-radius:8px;border:1.5px solid #eee;background:#fafafa;transition:all 0.15s;}
    .svc-row:hover{border-color:#E91E63;background:#fff;}
    .svc-row.selected{border-color:#E91E63;background:#fff9fb;}
    .svc-row.hidden-filter{display:none;}
    .svc-check{width:18px;height:18px;accent-color:#E91E63;cursor:pointer;flex-shrink:0;}
    .svc-info{min-width:0;}
    .svc-name{font-size:0.82rem;font-weight:600;color:#1a1a2e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .svc-desc{font-size:0.7rem;color:#888;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .svc-badge{font-size:0.65rem;font-weight:700;padding:2px 7px;border-radius:10px;flex-shrink:0;}
    .svc-badge.monthly{background:#e8f5e9;color:#2e7d32;}
    .svc-badge.onetime{background:#e3f2fd;color:#1565c0;}
    .svc-price-field,.svc-qty-field{width:72px;padding:0.3rem 0.45rem;border:1px solid #ddd;border-radius:6px;font-size:0.75rem;font-family:Poppins,sans-serif;text-align:right;background:#fff;color:#1a1a2e;outline:none;transition:border-color 0.15s;}
    .svc-price-field:focus,.svc-qty-field:focus{border-color:#E91E63;}
    .svc-qty-field{width:46px;text-align:center;}
    .svc-price-field:disabled,.svc-qty-field:disabled{background:#f5f5f5;color:#bbb;cursor:not-allowed;}
    .budget-preview-anchor { align-self: start; } /* ancora no grid */
    .budget-preview{
      background:#fff;border-radius:12px;border:1px solid #eee;
      transition:box-shadow 0.3s,border-color 0.3s;
      width:300px;
    }
    .budget-preview.bp-fixed{
      position:fixed;top:24px;
      box-shadow:0 8px 32px rgba(233,30,99,0.18);
      border-color:rgba(233,30,99,0.3);
      z-index:100;
    }
    @keyframes floatPulse{0%{transform:translateY(0)}40%{transform:translateY(-6px)}70%{transform:translateY(3px)}100%{transform:translateY(0)}}
    .budget-preview.float-bounce{animation:floatPulse 0.45s ease;}
    .budget-preview-header{padding:0.9rem 1.1rem;background:#1a1a2e;color:#fff;border-radius:12px 12px 0 0;font-size:0.82rem;font-weight:700;}
    .budget-preview-body{padding:0.75rem 1rem;min-height:100px;}
    .preview-empty{color:#bbb;font-size:0.78rem;text-align:center;padding:2rem 0;}
    .preview-item{display:flex;justify-content:space-between;align-items:baseline;gap:0.5rem;padding:0.4rem 0;border-bottom:1px solid #f5f5f5;font-size:0.78rem;}
    .preview-item-name{color:#333;font-weight:500;flex:1;min-width:0;}
    .preview-item-price{color:#E91E63;font-weight:700;white-space:nowrap;}
    .preview-total-block{padding:0.75rem 0 0.25rem;border-top:2px solid #eee;margin-top:0.25rem;}
    .preview-total-row{display:flex;justify-content:space-between;font-size:0.8rem;padding:0.2rem 0;}
    .preview-total-row.main{font-weight:800;font-size:0.9rem;color:#1a1a2e;}
    .content-sections-card{background:#fff;border-radius:12px;border:1px solid #eee;padding:1.25rem;margin-top:1.25rem;}
    .content-sections-card h3{font-size:0.85rem;font-weight:700;color:#1a1a2e;margin:0 0 1rem;padding-bottom:0.75rem;border-bottom:1px solid #eee;}
    .content-field{margin-bottom:1.1rem;}
    .content-field label{display:block;font-size:0.78rem;font-weight:700;color:#555;margin-bottom:0.35rem;text-transform:uppercase;letter-spacing:0.4px;}
    .content-field textarea{width:100%;border:1px solid #ddd;border-radius:8px;padding:0.6rem 0.8rem;font-size:0.83rem;font-family:Poppins,sans-serif;color:#1a1a2e;resize:vertical;outline:none;transition:border-color 0.15s;box-sizing:border-box;}
    .content-field textarea:focus{border-color:#E91E63;}
    .form-actions-sticky{position:sticky;bottom:0;background:rgba(255,255,255,0.95);backdrop-filter:blur(6px);border-top:1px solid #eee;padding:0.9rem 0;margin-top:1.5rem;display:flex;gap:0.75rem;align-items:center;justify-content:flex-end;z-index:10;}
    .catalog-category-label{font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#999;padding:0.5rem 0.25rem 0.2rem;}

    /* Leads vinculados */
    .lead-chips-row { display:flex;flex-wrap:wrap;gap:0.4rem;margin:0.5rem 0; }
    .lead-chip {
      display:inline-flex;align-items:center;gap:0.35rem;
      padding:0.3rem 0.65rem;border-radius:20px;
      background:#fff;border:1.5px solid #ddd;font-size:0.75rem;
      font-family:Poppins,sans-serif;
    }
    .lead-chip.primary { border-color:#E91E63;background:#fff0f5;color:#E91E63;font-weight:700; }
    .lead-chip .chip-del { cursor:pointer;color:#aaa;font-size:0.8rem;margin-left:4px; }
    .lead-chip .chip-del:hover { color:#dc2626; }

    /* Relatório */
    .report-lead-selector {
      display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;align-items:center;
    }
    .rls-btn {
      padding:0.3rem 0.75rem;border:1.5px solid #ddd;border-radius:20px;
      background:#fff;font-size:0.75rem;font-weight:600;color:#555;
      cursor:pointer;font-family:Poppins,sans-serif;transition:all 0.15s;
    }
    .rls-btn:hover { border-color:#E91E63;color:#E91E63; }
    .rls-btn.active { border-color:#E91E63;background:#fff0f5;color:#E91E63; }

    /* Heatmap */
    .heatmap-grid { display:grid;grid-template-columns:repeat(5,1fr);gap:0.5rem;margin-bottom:1rem; }
    @media(max-width:700px){ .heatmap-grid { grid-template-columns:repeat(2,1fr); } }
    .heatmap-cell { border-radius:10px;padding:0.75rem 0.4rem 0.6rem;text-align:center;border:1.5px solid transparent;transition:transform 0.15s; }
    .heatmap-cell:hover { transform:translateY(-2px); }
    /* Escala fria→quente */
    .heat-none   { background:#f0f0f2;border-color:#ddd;color:#999; }
    .heat-1      { background:#dbeafe;border-color:#93c5fd;color:#1e40af; }  /* azul frio */
    .heat-2      { background:#d1fae5;border-color:#6ee7b7;color:#065f46; }  /* verde-azul */
    .heat-3      { background:#fef9c3;border-color:#fde047;color:#713f12; }  /* amarelo */
    .heat-4      { background:#ffedd5;border-color:#fb923c;color:#7c2d12; }  /* laranja */
    .heat-5      { background:#fee2e2;border-color:#f87171;color:#7f1d1d; }  /* vermelho */
    .heat-number { font-size:0.62rem;font-weight:700;opacity:0.55;margin-bottom:3px; }
    .heat-name   { font-size:0.6rem;font-weight:600;line-height:1.25;margin-bottom:6px;min-height:28px;display:flex;align-items:center;justify-content:center; }
    .heat-stats  { display:flex;flex-direction:column;gap:3px;margin-top:2px; }
    .heat-stat   { font-size:0.72rem;font-weight:700;line-height:1; }
    .heat-stat-label { font-size:0.55rem;font-weight:500;opacity:0.65;margin-top:1px;letter-spacing:0.3px;text-transform:uppercase; }
    .heat-divider { height:1px;background:currentColor;opacity:0.15;margin:4px 8px; }
    .heatmap-legend { display:flex;gap:0.6rem;flex-wrap:wrap;font-size:0.7rem;color:#666;align-items:center; }
    .legend-dot { display:inline-flex;align-items:center;gap:0.3rem;padding:3px 9px;border-radius:20px;border:1.5px solid transparent; }

    /* Metrics grid */
    .metrics-grid { display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-bottom:1rem; }
    @media(max-width:700px){ .metrics-grid { grid-template-columns:repeat(2,1fr); } }
    .metric-item { background:#f8f9fa;border-radius:10px;padding:0.75rem;text-align:center; }
    .metric-value { font-size:1.4rem;font-weight:800;color:#1a1a2e; }
    .metric-label { font-size:0.65rem;color:#888;font-weight:500;margin-top:2px; }

    /* Vincular lead adicional */
    .link-lead-form { display:flex;gap:0.5rem;align-items:center;margin-top:0.75rem; }
    .link-lead-form select { flex:1;padding:0.45rem 0.7rem;border:1px solid #ddd;border-radius:8px;font-size:0.8rem;font-family:Poppins,sans-serif;outline:none; }
    .link-lead-form select:focus { border-color:#E91E63; }

    /* Extras panel inside budget-preview */
    .extras-panel-wrap { border-top:1px solid #eee;margin-top:0.5rem; }
    .extras-toggle-btn { width:100%;display:flex;align-items:center;justify-content:space-between;padding:0.6rem 1rem;background:none;border:none;color:#1a1a2e;font-family:Poppins,sans-serif;font-size:0.75rem;font-weight:700;cursor:pointer;transition:background 0.15s; }
    .extras-toggle-btn:hover { background:#f8f9fa; }
    .extras-panel-body { padding:0 0.85rem 0.85rem; }
    .extras-label { display:block;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:#888;margin-bottom:0.35rem; }
    .extras-textarea { width:100%;padding:0.5rem 0.6rem;border:1px solid #ddd;border-radius:7px;background:#fff;color:#1a1a2e;font-family:Poppins,sans-serif;font-size:0.78rem;resize:vertical;outline:none;box-sizing:border-box;transition:border-color 0.15s; }
    .extras-textarea:focus { border-color:#E91E63; }
    .extras-save-btn { width:100%;padding:0.5rem;background:#E91E63;color:#fff;border:none;border-radius:7px;font-family:Poppins,sans-serif;font-size:0.78rem;font-weight:700;cursor:pointer;transition:background 0.15s;margin-top:0.6rem; }
    .extras-save-btn:hover { background:#c2185b; }
    .extras-save-msg { display:none;margin-top:0.35rem;text-align:center;font-size:0.72rem;color:#2e7d32; }
  </style>
</head>
<body>
  <div class="top-bar"></div>
  <div class="admin-layout">
    <%- include('../_sidebar', { active: 'proposals' }) %>
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>Proposta #<%= proposal.id %></h1>
          <p class="page-subtitle">
            <% if (proposal.leads && proposal.leads.length > 0) { %>
              <%= proposal.leads.map(l => l.company_name || l.name).filter(Boolean).join(' · ') %>
            <% } %>
          </p>
        </div>
        <div class="header-actions">
          <a href="/admin/proposals/<%= proposal.id %>/view" class="btn-outline">👁️ Ver Proposta</a>
          <form action="/admin/proposals/<%= proposal.id %>/resend-emails" method="POST" style="display:inline">
            <button type="submit" class="btn-outline">📧 Reenviar Emails</button>
          </form>
          <% if (proposal.proposal_status === 'archived') { %>
            <form action="/admin/proposals/<%= proposal.id %>/archive" method="POST" style="display:inline">
              <input type="hidden" name="archived" value="0">
              <input type="hidden" name="redirect_to" value="edit">
              <button type="submit" class="btn-outline">♻️ Reativar</button>
            </form>
          <% } else { %>
            <form action="/admin/proposals/<%= proposal.id %>/archive" method="POST" style="display:inline"
                  onsubmit="return confirm('Arquivar esta proposta? Ela ficará oculta da lista principal.')">
              <input type="hidden" name="archived" value="1">
              <input type="hidden" name="redirect_to" value="edit">
              <button type="submit" class="btn-outline" style="color:#e53935;border-color:#e53935">🗃️ Arquivar</button>
            </form>
          <% } %>
          <a href="/admin/proposals" class="btn-outline">← Propostas</a>
        </div>
      </div>

      <% if (success) { %><div class="alert alert-success"><span>✅</span> <%= success %></div><% } %>
      <% if (error) { %><div class="alert alert-error"><span>⚠️</span> <%= error %></div><% } %>

      <!-- ── Leads vinculados ── -->
      <div class="detail-card full-width-card" style="margin-bottom:1.25rem">
        <h3 class="card-title">👥 Leads vinculados a esta proposta</h3>
        <div class="lead-chips-row">
          <% (proposal.leads || []).forEach(lead => { %>
            <span class="lead-chip <%= lead.is_primary ? 'primary' : '' %>">
              <% if (lead.is_primary) { %><span title="Lead primário">⭐</span><% } %>
              <%= lead.name %>
              <% if (lead.company_name) { %><span style="opacity:0.6;font-size:0.68rem">· <%= lead.company_name %></span><% } %>
              <% if (!lead.is_primary) { %>
                <form action="/admin/proposals/<%= proposal.id %>/unlink-lead" method="POST" style="display:inline" onsubmit="return confirm('Desvincular <%= lead.name %>?')">
                  <input type="hidden" name="lead_id" value="<%= lead.id %>">
                  <button type="submit" class="chip-del" title="Desvincular">✕</button>
                </form>
              <% } %>
            </span>
          <% }) %>
        </div>
        <!-- Vincular lead adicional -->
        <form action="/admin/proposals/<%= proposal.id %>/link-lead" method="POST" class="link-lead-form">
          <select name="lead_id" required>
            <option value="">+ Vincular outro lead...</option>
            <% const linkedIds = (proposal.leads || []).map(l => l.id); %>
            <% allLeads.filter(l => !linkedIds.includes(l.id)).forEach(lead => { %>
              <option value="<%= lead.id %>"><%= lead.name %><% if (lead.company_name) { %> — <%= lead.company_name %><% } %></option>
            <% }) %>
          </select>
          <button type="submit" class="btn-primary" style="padding:0.45rem 1rem;font-size:0.8rem">Vincular</button>
        </form>
      </div>

      <!-- ── Engajamento resumido (atalho para relatório completo) ── -->
      <% if (stats && stats.totalAccesses > 0) { %>
      <div class="detail-card full-width-card" style="margin-bottom:1.25rem;background:linear-gradient(135deg,#f8f9fa,#fff)">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.75rem">
          <div style="display:flex;align-items:center;gap:0.6rem">
            <span style="font-size:1.1rem">📊</span>
            <h3 class="card-title" style="margin:0">Engajamento desta Proposta</h3>
          </div>
          <a href="/admin/proposals/<%= proposal.id %>/view" class="btn-outline" style="font-size:0.78rem;padding:0.35rem 0.9rem">
            Ver relatório completo →
          </a>
        </div>
        <div style="display:flex;gap:1.5rem;flex-wrap:wrap;margin-top:0.85rem">
          <div style="text-align:center">
            <div style="font-size:1.5rem;font-weight:800;color:#1a1a2e"><%= stats.totalAccesses %></div>
            <div style="font-size:0.7rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.4px">Acessos</div>
          </div>
          <div style="text-align:center">
            <div style="font-size:1.5rem;font-weight:800;color:#1a1a2e"><%= stats.totalSlidesSeen %><span style="font-size:0.85rem;color:#aaa">/12</span></div>
            <div style="font-size:0.7rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.4px">Slides vistos</div>
          </div>
          <div style="text-align:center">
            <%
              const engDur = stats.totalDuration || 0;
              const engMm  = Math.floor(engDur / 60);
              const engSs  = Math.round(engDur % 60);
            %>
            <div style="font-size:1.5rem;font-weight:800;color:#1a1a2e"><%= engMm %>m<span style="font-size:0.85rem;color:#aaa"><%= engSs %>s</span></div>
            <div style="font-size:0.7rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.4px">Tempo total</div>
          </div>
          <% const revisitCount = stats.slideStats ? stats.slideStats.filter(s => s.revisit_count > 0).length : 0; %>
          <div style="text-align:center">
            <div style="font-size:1.5rem;font-weight:800;color:#1a1a2e"><%= revisitCount %></div>
            <div style="font-size:0.7rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.4px">Slides revisitados</div>
          </div>
          <% if (proposal.leads && proposal.leads.length > 0) { %>
            <div style="text-align:center">
              <div style="font-size:1.5rem;font-weight:800;color:#1a1a2e"><%= proposal.leads.length %></div>
              <div style="font-size:0.7rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.4px">Lead(s)</div>
            </div>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- ══ EDITOR DA PROPOSTA ══ -->
      <form id="proposalForm" action="/admin/proposals/<%= proposal.id %>/edit" method="POST">

        <!-- Mode Selector -->
        <div class="form-card" style="margin-bottom:1.25rem;background:#fff;border-radius:12px;border:1px solid #eee;padding:1.25rem">
          <h3 style="font-size:0.85rem;font-weight:700;color:#1a1a2e;margin:0 0 1rem">🎛️ Tipo de Proposta</h3>
          <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <% const currentMode = proposal.proposal_mode || 'both'; %>
            <label style="display:flex;align-items:center;gap:0.6rem;cursor:pointer;padding:0.75rem 1rem;border:2px solid <%= currentMode === 'ready' ? '#E91E63' : '#eee' %>;border-radius:10px;flex:1;min-width:140px" id="mode-label-ready">
              <input type="radio" name="proposal_mode" value="ready" onchange="updateModeLabel()" style="accent-color:#E91E63" <%= currentMode === 'ready' ? 'checked' : '' %>>
              <div>
                <div style="font-size:0.83rem;font-weight:700;color:#1a1a2e">📋 Proposta Pronta</div>
                <div style="font-size:0.7rem;color:#888">Somente proposta configurada aqui</div>
              </div>
            </label>
            <label style="display:flex;align-items:center;gap:0.6rem;cursor:pointer;padding:0.75rem 1rem;border:2px solid <%= currentMode === 'build' ? '#E91E63' : '#eee' %>;border-radius:10px;flex:1;min-width:140px" id="mode-label-build">
              <input type="radio" name="proposal_mode" value="build" onchange="updateModeLabel()" <%= currentMode === 'build' ? 'checked' : '' %>>
              <div>
                <div style="font-size:0.83rem;font-weight:700;color:#1a1a2e">🔧 Montar Proposta</div>
                <div style="font-size:0.7rem;color:#888">Cliente monta o próprio orçamento</div>
              </div>
            </label>
            <label style="display:flex;align-items:center;gap:0.6rem;cursor:pointer;padding:0.75rem 1rem;border:2px solid <%= currentMode === 'both' ? '#E91E63' : '#eee' %>;border-radius:10px;flex:1;min-width:140px;background:<%= currentMode === 'both' ? 'rgba(233,30,99,0.04)' : '' %>" id="mode-label-both">
              <input type="radio" name="proposal_mode" value="both" onchange="updateModeLabel()" <%= currentMode === 'both' ? 'checked' : '' %>>
              <div>
                <div style="font-size:0.83rem;font-weight:700;color:#1a1a2e">✨ As 2 Opções</div>
                <div style="font-size:0.7rem;color:#888">Proposta pronta + opção de montar</div>
              </div>
            </label>
          </div>
        </div>

        <!-- Builder Grid -->
        <div class="proposal-builder-grid">
          <div>
            <div class="services-catalog">
              <div class="catalog-header">
                <h3>🛒 Serviços da Proposta</h3>
                <div class="catalog-filter">
                  <button type="button" class="filter-btn active" onclick="filterCatalog('all',this)">Todos</button>
                  <button type="button" class="filter-btn" onclick="filterCatalog('monthly',this)">Recorrentes</button>
                  <button type="button" class="filter-btn" onclick="filterCatalog('onetime',this)">Pontuais</button>
                </div>
              </div>
              <div class="catalog-body" id="catalogBody">
                <% const monthlyServices = services.filter(s => s.category === 'monthly' && s.active); %>
                <% const onetimeServices = services.filter(s => s.category === 'onetime' && s.active); %>

                <% if (monthlyServices.length > 0) { %>
                  <div class="catalog-category-label" data-cat="monthly">📅 Serviços Recorrentes</div>
                  <% monthlyServices.forEach(svc => {
                       const existingItem = proposalItems.find(i => i.service_id === svc.id);
                       const isChecked = !!existingItem;
                  %>
                  <div class="svc-row <%= isChecked ? 'selected' : '' %>" id="svc-row-<%= svc.id %>" data-id="<%= svc.id %>" data-cat="monthly">
                    <input type="checkbox" class="svc-check" id="svc-<%= svc.id %>"
                      onchange="onSvcToggle(<%= svc.id %>)"
                      data-name="<%= svc.name.replace(/"/g,'&quot;') %>"
                      data-desc="<%= (svc.description||'').replace(/"/g,'&quot;') %>"
                      data-default-price="<%= svc.price %>"
                      data-unit="<%= svc.unit || '/mês' %>"
                      data-cat="<%= svc.category %>"
                      <%= isChecked ? 'checked' : '' %>>
                    <div class="svc-info">
                      <div class="svc-name"><%= svc.name %></div>
                      <% if (svc.description) { %><div class="svc-desc"><%= svc.description %></div><% } %>
                    </div>
                    <span class="svc-badge monthly">mensal</span>
                    <input type="number" class="svc-qty-field" id="qty-<%= svc.id %>"
                      value="<%= existingItem ? existingItem.qty : 1 %>"
                      min="1" max="99" <%= isChecked ? '' : 'disabled' %>
                      onchange="updatePreview()" oninput="updatePreview()">
                    <input type="number" class="svc-price-field" id="price-<%= svc.id %>"
                      value="<%= existingItem ? existingItem.price : svc.price %>"
                      min="0" step="1" <%= isChecked ? '' : 'disabled' %>
                      onchange="updatePreview()" oninput="updatePreview()">
                  </div>
                  <% }) %>
                <% } %>

                <% if (onetimeServices.length > 0) { %>
                  <div class="catalog-category-label" data-cat="onetime">💳 Serviços Pontuais</div>
                  <% onetimeServices.forEach(svc => {
                       const existingItem = proposalItems.find(i => i.service_id === svc.id);
                       const isChecked = !!existingItem;
                  %>
                  <div class="svc-row <%= isChecked ? 'selected' : '' %>" id="svc-row-<%= svc.id %>" data-id="<%= svc.id %>" data-cat="onetime">
                    <input type="checkbox" class="svc-check" id="svc-<%= svc.id %>"
                      onchange="onSvcToggle(<%= svc.id %>)"
                      data-name="<%= svc.name.replace(/"/g,'&quot;') %>"
                      data-desc="<%= (svc.description||'').replace(/"/g,'&quot;') %>"
                      data-default-price="<%= svc.price %>"
                      data-unit="<%= svc.unit || 'único' %>"
                      data-cat="<%= svc.category %>"
                      <%= isChecked ? 'checked' : '' %>>
                    <div class="svc-info">
                      <div class="svc-name"><%= svc.name %></div>
                      <% if (svc.description) { %><div class="svc-desc"><%= svc.description %></div><% } %>
                    </div>
                    <span class="svc-badge onetime">único</span>
                    <input type="number" class="svc-qty-field" id="qty-<%= svc.id %>"
                      value="<%= existingItem ? existingItem.qty : 1 %>"
                      min="1" max="99" <%= isChecked ? '' : 'disabled' %>
                      onchange="updatePreview()" oninput="updatePreview()">
                    <input type="number" class="svc-price-field" id="price-<%= svc.id %>"
                      value="<%= existingItem ? existingItem.price : svc.price %>"
                      min="0" step="1" <%= isChecked ? '' : 'disabled' %>
                      onchange="updatePreview()" oninput="updatePreview()">
                  </div>
                  <% }) %>
                <% } %>
              </div>
            </div>

            <div class="content-sections-card">
              <h3>📝 Conteúdo da Proposta</h3>

              <!-- hidden inputs que o form envia -->
              <input type="hidden" id="edit_proposal_description" name="proposal_description">
              <input type="hidden" id="edit_proposal_scope"       name="proposal_scope">
              <input type="hidden" id="edit_proposal_timeline"    name="proposal_timeline">

              <div class="content-field">
                <label>📄 Descrição</label>
                <div id="editor-description"></div>
                <small style="font-size:0.7rem;color:#999">Aceita formatação colada do Word</small>
              </div>
              <div class="content-field">
                <label>🎯 Escopo</label>
                <div id="editor-scope"></div>
              </div>
              <div class="content-field">
                <label>📅 Cronograma</label>
                <div id="editor-timeline"></div>
              </div>
            </div>
          </div>

          <div class="budget-preview-anchor" id="budgetAnchor">
            <div class="budget-preview" id="budgetPreview">
              <div class="budget-preview-header">📊 Resumo do Orçamento</div>
              <div class="budget-preview-body" id="budgetPreviewBody">
                <p class="preview-empty">Selecione serviços para ver resumo</p>
              </div>

              <!-- ── Condição Especial + Formas de Pagamento (no sidebar) ── -->
              <div class="extras-panel-wrap">
                <button type="button" class="extras-toggle-btn" onclick="toggleExtrasPanel()" id="extrasToggleBtn">
                  <span>🏷️ Condição Especial & Pagamento</span>
                  <span id="extrasPanelChevron" style="font-size:0.65rem;transition:transform 0.2s">▼</span>
                </button>
                <div id="extrasPanel" style="display:none">
                  <div class="extras-panel-body">

                    <!-- Condição Especial -->
                    <div style="margin-bottom:0.85rem">
                      <label class="extras-label">🎁 Condição Especial</label>
                      <textarea id="specialConditionInput" class="extras-textarea"
                        placeholder="Ex: 15% off para contratos até 30/06..."
                        rows="3"
                      ><%= proposal.special_condition || '' %></textarea>
                    </div>

                    <!-- Condições de Pagamento -->
                    <div style="margin-bottom:0.75rem">
                      <label class="extras-label">💳 Condições de Pagamento</label>
                      <p style="font-size:0.7rem;color:#999;margin:0 0 0.5rem;line-height:1.4">Defina quantas parcelas + % de desconto. O valor final será calculado automaticamente na proposta do cliente.</p>
                      <div id="paymentRowsHeader" style="display:none;grid-template-columns:1fr 1fr 26px;gap:0.3rem;margin-bottom:0.2rem">
                        <span style="font-size:0.6rem;color:#aaa;font-weight:700;text-transform:uppercase;letter-spacing:0.3px">Meses</span>
                        <span style="font-size:0.6rem;color:#aaa;font-weight:700;text-transform:uppercase;letter-spacing:0.3px">Desconto %</span>
                        <span></span>
                      </div>
                      <div class="payment-rows-wrap" id="paymentConditionsContainer"></div>
                      <button type="button" class="extras-add-btn" onclick="addPaymentRow()">➕ Adicionar condição</button>
                    </div>

                    <!-- Salvar -->
                    <button type="button" class="extras-save-btn" onclick="saveExtras()" id="btnSaveExtras">💾 Salvar</button>
                    <div id="extrasSaveMsg" class="extras-save-msg"></div>
                  </div>
                </div>
              </div>
              <!-- /extras panel -->

            </div><!-- /budget-preview -->
            <div id="hiddenItemsContainer"></div>
          </div><!-- /anchor -->
        </div>

        <div class="form-actions-sticky">
          <a href="/admin/proposals" class="btn-outline">Cancelar</a>
          <button type="submit" class="btn-primary">💾 Salvar Alterações</button>
        </div>
      </form>

    </main>
  </div>

  <div id="toast" class="toast hidden">Copiado!</div>

  <script>
    const SERVICES_DATA = <%- JSON.stringify(services) %>;
    const PROPOSAL_ITEMS_DATA = <%- JSON.stringify(proposalItems) %>;

    // ── Proposal editor JS ────────────────────────────────────────────
    function updateModeLabel() {
      const radios = document.querySelectorAll('input[name="proposal_mode"]');
      radios.forEach(r => {
        const lbl = document.getElementById('mode-label-' + r.value);
        if (lbl) {
          lbl.style.borderColor = r.checked ? '#E91E63' : '#eee';
          lbl.style.background  = r.checked ? 'rgba(233,30,99,0.04)' : '';
        }
      });
    }

    function onSvcToggle(svcId) {
      const chk   = document.getElementById('svc-' + svcId);
      const row   = document.getElementById('svc-row-' + svcId);
      const priceF = document.getElementById('price-' + svcId);
      const qtyF   = document.getElementById('qty-' + svcId);
      const checked = chk.checked;
      row.classList.toggle('selected', checked);
      priceF.disabled = !checked;
      qtyF.disabled   = !checked;
      if (checked) { priceF.value = chk.dataset.defaultPrice; qtyF.value = 1; }
      updatePreview();
    }

    function filterCatalog(cat, btn) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.svc-row').forEach(row => {
        row.classList.toggle('hidden-filter', cat !== 'all' && row.dataset.cat !== cat);
      });
      document.querySelectorAll('.catalog-category-label').forEach(lbl => {
        lbl.style.display = (cat === 'all' || lbl.dataset.cat === cat) ? '' : 'none';
      });
    }

    function fmtBRL(v) { return 'R$ ' + Number(v).toLocaleString('pt-BR', { minimumFractionDigits:0, maximumFractionDigits:0 }); }

    function updatePreview() {
      const previewBody = document.getElementById('budgetPreviewBody');
      const checkedBoxes = document.querySelectorAll('.svc-check:checked');
      if (checkedBoxes.length === 0) {
        previewBody.innerHTML = '<p class="preview-empty">Selecione serviços ao lado</p>';
        return;
      }
      let monthlyTotal = 0, onetimeTotal = 0, html = '';
      checkedBoxes.forEach(chk => {
        const svcId = chk.id.replace('svc-', '');
        const price = parseFloat(document.getElementById('price-' + svcId)?.value) || 0;
        const qty   = parseInt(document.getElementById('qty-' + svcId)?.value) || 1;
        const total = price * qty;
        if (chk.dataset.cat === 'onetime') onetimeTotal += total;
        else monthlyTotal += total;
        html += `<div class="preview-item"><span class="preview-item-name">${chk.dataset.name}${qty>1?' ×'+qty:''}</span><span class="preview-item-price">${fmtBRL(total)}</span></div>`;
      });
      html += '<div class="preview-total-block">';
      if (monthlyTotal > 0) html += `<div class="preview-total-row main"><span>Mensal</span><span style="color:#E91E63">${fmtBRL(monthlyTotal)}/mês</span></div>`;
      if (onetimeTotal > 0) html += `<div class="preview-total-row main"><span>Único</span><span style="color:#1565c0">${fmtBRL(onetimeTotal)}</span></div>`;
      html += '</div>';
      previewBody.innerHTML = html;
    }

    document.getElementById('proposalForm').addEventListener('submit', function(e) {
      const items = [];
      document.querySelectorAll('.svc-check:checked').forEach(chk => {
        const svcId = chk.id.replace('svc-', '');
        items.push({
          service_id: parseInt(svcId),
          name: chk.dataset.name,
          description: chk.dataset.desc || '',
          price: parseFloat(document.getElementById('price-' + svcId)?.value) || 0,
          qty: parseInt(document.getElementById('qty-' + svcId)?.value) || 1,
          unit: chk.dataset.unit,
          category: chk.dataset.cat,
          sort_order: items.length
        });
      });

      // ── Proteção contra apagamento acidental de itens ──────────────────
      // Se nenhum serviço está marcado MAS a proposta já tinha itens salvos,
      // exige confirmação explícita antes de submeter sem itens.
      // O servidor também protege, mas este aviso previne o submit por engano.
      const existingCount = (typeof PROPOSAL_ITEMS_DATA !== 'undefined') ? PROPOSAL_ITEMS_DATA.length : 0;
      if (items.length === 0 && existingCount > 0) {
        const ok = confirm(
          '⚠️ Nenhum serviço está selecionado!\n\n' +
          'Esta proposta possui ' + existingCount + ' item(ns) atualmente salvos.\n\n' +
          'Se continuar, os itens NÃO serão alterados (proteção ativa).\n' +
          'Para remover todos os itens intencionalmente, use o botão de edição individual.\n\n' +
          'Deseja salvar mesmo assim (sem alterar os itens)?'
        );
        if (!ok) { e.preventDefault(); return; }
      }
      // ───────────────────────────────────────────────────────────────────

      const container = document.getElementById('hiddenItemsContainer');
      container.innerHTML = '';
      const input = document.createElement('input');
      input.type  = 'hidden';
      input.name  = 'proposal_items';
      input.value = JSON.stringify(items);
      container.appendChild(input);
    });

    // Init
    updatePreview();

    // ── Extras panel (Condição Especial & Formas de Pagamento) ───────────
    var SPECIAL_CONDITION_INIT = <%- JSON.stringify(proposal.special_condition || '') %>;
    var PAYMENT_CONDITIONS_INIT = (function() {
      try {
        var raw = <%- JSON.stringify(proposal.payment_conditions || null) %>;
        if (!raw) return [];
        return typeof raw === 'string' ? JSON.parse(raw) : raw;
      } catch(e) { return []; }
    })();

    function toggleExtrasPanel() {
      var panel   = document.getElementById('extrasPanel');
      var chevron = document.getElementById('extrasPanelChevron');
      var open    = panel.style.display === 'none';
      panel.style.display     = open ? '' : 'none';
      chevron.style.transform = open ? 'rotate(180deg)' : '';
    }

    /* ── Linhas de condição de pagamento ─────────────────────────── */
    function createPaymentRow(months, discount) {
      var wrap = document.createElement('div');
      wrap.style.cssText = 'display:grid;grid-template-columns:1fr 1fr 26px;gap:0.3rem;align-items:center;margin-bottom:0.35rem';
      wrap.innerHTML =
        '<input type="number" class="pc-months extras-textarea" placeholder="Meses ex: 3" min="1" max="120" value="' + (months || '') + '" style="padding:0.35rem 0.45rem;font-size:0.75rem">' +
        '<input type="number" class="pc-discount extras-textarea" placeholder="Desc % ex: 10" min="0" max="100" step="0.1" value="' + (discount !== undefined && discount !== '' ? discount : '') + '" style="padding:0.35rem 0.45rem;font-size:0.75rem">' +
        '<button type="button" onclick="removePaymentRow(this)" title="Remover" style="background:none;border:none;cursor:pointer;color:#bbb;font-size:1rem;padding:0;transition:color 0.15s" onmouseenter="this.style.color=\'#e53935\'" onmouseleave="this.style.color=\'#bbb\'">✕</button>';
      return wrap;
    }

    function renderPaymentRows() {
      var container = document.getElementById('paymentConditionsContainer');
      container.innerHTML = '';
      if (PAYMENT_CONDITIONS_INIT && PAYMENT_CONDITIONS_INIT.length > 0) {
        PAYMENT_CONDITIONS_INIT.forEach(function(c) {
          container.appendChild(createPaymentRow(c.months, c.discount));
        });
      }
      // header de colunas se houver linhas
      updatePaymentHeader();
    }

    function updatePaymentHeader() {
      var container = document.getElementById('paymentConditionsContainer');
      var existing  = container.querySelectorAll('div').length;
      var hdr = document.getElementById('paymentRowsHeader');
      if (!hdr) return;
      hdr.style.display = existing > 0 ? 'grid' : 'none';
    }

    function addPaymentRow() {
      var container = document.getElementById('paymentConditionsContainer');
      container.appendChild(createPaymentRow('', ''));
      updatePaymentHeader();
      var panel = document.getElementById('extrasPanel');
      if (panel.style.display === 'none') toggleExtrasPanel();
    }

    function removePaymentRow(btn) {
      btn.closest('div').remove();
      updatePaymentHeader();
    }

    function collectPaymentConditions() {
      var container = document.getElementById('paymentConditionsContainer');
      var rows = container.querySelectorAll('div');
      var result = [];
      rows.forEach(function(row) {
        var mInput = row.querySelector('.pc-months');
        var dInput = row.querySelector('.pc-discount');
        if (!mInput || !dInput) return;
        var months   = parseFloat(mInput.value);
        var discount = parseFloat(dInput.value);
        if (!isNaN(months) && months > 0 && !isNaN(discount) && discount >= 0) {
          result.push({ months: months, discount: discount });
        }
      });
      return result;
    }

    function saveExtras() {
      var btn = document.getElementById('btnSaveExtras');
      var msg = document.getElementById('extrasSaveMsg');
      var specialCondition  = document.getElementById('specialConditionInput').value.trim();
      var paymentConditions = collectPaymentConditions();

      btn.disabled    = true;
      btn.textContent = '⏳ Salvando...';
      msg.style.display = 'none';

      fetch('/admin/proposals/<%= proposal.id %>/extras', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          special_condition: specialCondition || null,
          payment_conditions_json: paymentConditions.length > 0 ? JSON.stringify(paymentConditions) : null
        })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        btn.disabled    = false;
        btn.textContent = '💾 Salvar';
        if (data.success) {
          PAYMENT_CONDITIONS_INIT = paymentConditions;
          msg.style.display = 'block';
          msg.style.color   = '#2e7d32';
          msg.textContent   = '✅ Salvo com sucesso!';
          setTimeout(function() { msg.style.display = 'none'; }, 2500);
        } else {
          msg.style.display = 'block';
          msg.style.color   = '#c62828';
          msg.textContent   = '❌ Erro: ' + (data.error || 'falha ao salvar');
        }
      })
      .catch(function() {
        btn.disabled    = false;
        btn.textContent = '💾 Salvar';
        msg.style.display = 'block';
        msg.style.color   = '#c62828';
        msg.textContent   = '❌ Erro de conexão';
      });
    }

    // Init extras
    renderPaymentRows();
    // ── Budget preview: fixed ao rolar ─────────────────────────
    (function() {
      const bp     = document.getElementById('budgetPreview');
      const anchor = document.getElementById('budgetAnchor');
      if (!bp || !anchor) return;

      let wasFixed = false;

      function syncFixed() {
        const ar = anchor.getBoundingClientRect();
        const shouldFix = ar.top < 24;

        if (shouldFix === wasFixed) return;
        wasFixed = shouldFix;

        if (shouldFix) {
          // fixa: posiciona exatamente onde o anchor está horizontalmente
          const left = ar.left;
          bp.style.left  = left + 'px';
          bp.style.width = ar.width + 'px';
          bp.classList.add('bp-fixed');
          // bounce ao entrar no fixed
          bp.classList.remove('float-bounce');
          void bp.offsetWidth;
          bp.classList.add('float-bounce');
        } else {
          bp.classList.remove('bp-fixed', 'float-bounce');
          bp.style.left  = '';
          bp.style.width = '';
        }
      }

      window.addEventListener('scroll',  syncFixed, { passive: true });
      window.addEventListener('resize',  syncFixed, { passive: true });
      syncFixed();
    })();
  </script>

  <!-- Quill rich text editors -->
  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
  <script>
    (function () {
      const TOOLBAR = [
        [{ header: [1, 2, 3, false] }],
        ['bold', 'italic', 'underline'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['clean']
      ];

      const quillDesc     = new Quill('#editor-description', { theme: 'snow', modules: { toolbar: TOOLBAR }, placeholder: 'Descreva a proposta de forma geral...' });
      const quillScope    = new Quill('#editor-scope',       { theme: 'snow', modules: { toolbar: TOOLBAR }, placeholder: 'Liste o que está incluído no escopo...' });
      const quillTimeline = new Quill('#editor-timeline',    { theme: 'snow', modules: { toolbar: TOOLBAR }, placeholder: 'Descreva o cronograma ou prazos...' });

      // Populate editors with existing server-side content
      const initDesc     = <%- JSON.stringify(proposal.proposal_description || '') %>;
      const initScope    = <%- JSON.stringify(proposal.proposal_scope       || '') %>;
      const initTimeline = <%- JSON.stringify(proposal.proposal_timeline    || '') %>;

      if (initDesc)     quillDesc.clipboard.dangerouslyPasteHTML(initDesc);
      if (initScope)    quillScope.clipboard.dangerouslyPasteHTML(initScope);
      if (initTimeline) quillTimeline.clipboard.dangerouslyPasteHTML(initTimeline);

      // Sync Quill HTML → hidden inputs before any form submit (capture phase)
      document.querySelectorAll('form').forEach(function (form) {
        form.addEventListener('submit', function () {
          document.getElementById('edit_proposal_description').value = quillDesc.getSemanticHTML();
          document.getElementById('edit_proposal_scope').value       = quillScope.getSemanticHTML();
          document.getElementById('edit_proposal_timeline').value    = quillTimeline.getSemanticHTML();
        }, true);
      });
    })();
  </script>
</body>
</html>
