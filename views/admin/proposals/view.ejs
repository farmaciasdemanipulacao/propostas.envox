<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ver Proposta #<%= proposal.id %> — Envox Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    /* ── Layout geral ─────────────────────────────────────── */
    html, body { height: 100%; margin: 0; overflow: hidden; }

    .view-shell {
      display: grid;
      grid-template-columns: 260px 1fr;
      grid-template-rows: 52px 1fr;
      height: 100vh;
      background: #f0f2f5;
    }

    /* ── Top bar ──────────────────────────────────────────── */
    .view-topbar {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0 1.25rem;
      background: #1a1a2e;
      color: #fff;
      font-family: Poppins, sans-serif;
      font-size: 0.82rem;
      z-index: 100;
      box-shadow: 0 2px 8px rgba(0,0,0,0.18);
    }
    .view-topbar .tb-logo {
      font-weight: 800;
      font-size: 0.92rem;
      color: #E91E63;
      letter-spacing: -0.5px;
      margin-right: 0.25rem;
      white-space: nowrap;
    }
    .view-topbar .tb-sep {
      color: #444;
      font-size: 1rem;
    }
    .view-topbar .tb-title {
      font-weight: 600;
      color: #eee;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 260px;
    }
    .view-topbar .tb-subtitle {
      font-size: 0.72rem;
      color: #888;
      white-space: nowrap;
    }
    .view-topbar .tb-spacer { flex: 1; }
    .view-topbar .tb-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem 0.85rem;
      border-radius: 20px;
      border: 1.5px solid #444;
      background: transparent;
      color: #ccc;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: Poppins, sans-serif;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.15s;
      white-space: nowrap;
    }
    .view-topbar .tb-btn:hover { border-color: #E91E63; color: #E91E63; }
    .view-topbar .tb-btn.primary {
      background: #E91E63;
      border-color: #E91E63;
      color: #fff;
    }
    .view-topbar .tb-btn.primary:hover { background: #c2185b; }

    /* ── Painel lateral ───────────────────────────────────── */
    .view-sidebar {
      background: #fff;
      border-right: 1px solid #eee;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .vs-section {
      padding: 1rem 1.1rem;
      border-bottom: 1px solid #f0f0f0;
    }
    .vs-section:last-child { border-bottom: none; }

    .vs-label {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #aaa;
      margin-bottom: 0.5rem;
    }

    /* Seletor de lead */
    .lead-selector-list { display: flex; flex-direction: column; gap: 0.35rem; }
    .lead-selector-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.7rem;
      border-radius: 8px;
      border: 1.5px solid #eee;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.12s;
      font-family: Poppins, sans-serif;
    }
    .lead-selector-item:hover { border-color: #E91E63; background: #fff0f5; }
    .lead-selector-item.active { border-color: #E91E63; background: #fff0f5; }
    .lsi-avatar {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: linear-gradient(135deg, #E91E63, #9c27b0);
      color: #fff;
      font-size: 0.7rem;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .lsi-info { flex: 1; min-width: 0; }
    .lsi-name {
      font-size: 0.78rem;
      font-weight: 700;
      color: #1a1a2e;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .lsi-company {
      font-size: 0.65rem;
      color: #888;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .lsi-badge {
      font-size: 0.6rem;
      background: rgba(233,30,99,0.1);
      color: #E91E63;
      font-weight: 700;
      padding: 1px 5px;
      border-radius: 10px;
      flex-shrink: 0;
    }

    /* Métricas resumidas */
    .vs-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem; }
    .vs-metric {
      background: #f8f9fa;
      border-radius: 8px;
      padding: 0.5rem 0.6rem;
      text-align: center;
    }
    .vs-metric-val {
      font-size: 1.05rem;
      font-weight: 800;
      color: #1a1a2e;
    }
    .vs-metric-lbl {
      font-size: 0.58rem;
      color: #999;
      font-weight: 500;
      margin-top: 1px;
    }

    /* Status da proposta */
    .vs-status-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
    }
    .status-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .status-dot.active { background: #4caf50; }
    .status-dot.archived { background: #bbb; }
    .status-dot.rejected { background: #dc2626; }

    /* Token copy */
    .token-row {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .token-chip {
      font-family: monospace;
      font-size: 0.78rem;
      background: #f5f5f5;
      padding: 3px 8px;
      border-radius: 5px;
      color: #555;
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .copy-btn {
      padding: 3px 8px;
      border: 1px solid #ddd;
      border-radius: 6px;
      background: #fff;
      font-size: 0.7rem;
      cursor: pointer;
      font-family: Poppins, sans-serif;
      color: #555;
      transition: all 0.12s;
    }
    .copy-btn:hover { border-color: #E91E63; color: #E91E63; }

    /* Quick actions */
    .vs-actions { display: flex; flex-direction: column; gap: 0.4rem; }
    .vs-action-btn {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
      border-radius: 8px;
      border: 1.5px solid #eee;
      background: #fff;
      font-size: 0.78rem;
      font-weight: 600;
      color: #333;
      cursor: pointer;
      text-decoration: none;
      font-family: Poppins, sans-serif;
      transition: all 0.12s;
    }
    .vs-action-btn:hover { border-color: #1a1a2e; color: #1a1a2e; background: #f8f9fa; }
    .vs-action-btn.danger:hover { border-color: #dc2626; color: #dc2626; background: rgba(220,38,38,0.04); }

    /* ── Área do iframe ───────────────────────────────────── */
    .view-iframe-area {
      position: relative;
      overflow: hidden;
      background: #1a1a2e;
    }

    .device-bar {
      position: absolute;
      top: 12px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 0.35rem;
      z-index: 10;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(8px);
      padding: 5px 10px;
      border-radius: 20px;
    }
    .device-btn {
      padding: 4px 10px;
      border-radius: 14px;
      border: none;
      background: transparent;
      color: #aaa;
      font-size: 0.72rem;
      font-weight: 600;
      font-family: Poppins, sans-serif;
      cursor: pointer;
      transition: all 0.15s;
    }
    .device-btn.active { background: #E91E63; color: #fff; }
    .device-btn:hover:not(.active) { color: #fff; }

    .iframe-wrapper {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 52px 0 12px;
      box-sizing: border-box;
      transition: all 0.3s ease;
    }

    /* Desktop — full width */
    .iframe-wrapper.device-desktop .iframe-shell {
      width: 100%;
      height: 100%;
      border-radius: 0;
      box-shadow: none;
    }

    /* Tablet */
    .iframe-wrapper.device-tablet .iframe-shell {
      width: min(820px, calc(100% - 24px));
      height: 100%;
      border-radius: 12px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.4);
      overflow: hidden;
    }

    /* Mobile */
    .iframe-wrapper.device-mobile .iframe-shell {
      width: 390px;
      height: min(844px, calc(100% - 16px));
      border-radius: 40px;
      box-shadow: 0 12px 50px rgba(0,0,0,0.5);
      border: 8px solid #2a2a3a;
      overflow: hidden;
    }

    .iframe-shell { background: #fff; flex-shrink: 0; }

    .proposal-iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    /* Loading overlay */
    .iframe-loading {
      position: absolute;
      inset: 0;
      background: #1a1a2e;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #888;
      font-family: Poppins, sans-serif;
      font-size: 0.82rem;
      z-index: 5;
      gap: 0.75rem;
      transition: opacity 0.3s;
    }
    .iframe-loading.hidden { opacity: 0; pointer-events: none; }
    .spinner {
      width: 36px; height: 36px;
      border: 3px solid #333;
      border-top-color: #E91E63;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Toast */
    .toast-admin {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(0);
      background: #1a1a2e;
      color: #fff;
      padding: 0.5rem 1.25rem;
      border-radius: 20px;
      font-size: 0.78rem;
      font-family: Poppins, sans-serif;
      font-weight: 600;
      opacity: 1;
      transition: opacity 0.3s;
      z-index: 9999;
      pointer-events: none;
    }
    .toast-admin.hidden { opacity: 0; }

    /* Responsive — esconder sidebar em telas pequenas */
    @media (max-width: 780px) {
      .view-shell { grid-template-columns: 1fr; }
      .view-sidebar { display: none; }
    }
  </style>
</head>
<body>

<div class="view-shell">

  <!-- ── Top bar ──────────────────────────────────────── -->
  <div class="view-topbar">
    <span class="tb-logo">Envox</span>
    <span class="tb-sep">/</span>
    <div>
      <div class="tb-title">Proposta #<%= proposal.id %>
        <% if (proposal.leads && proposal.leads.length > 0) { %>
          — <%= proposal.leads.map(l => l.company_name || l.name).filter(Boolean).join(' · ') %>
        <% } %>
      </div>
    </div>
    <div class="tb-spacer"></div>

    <!-- Selector de lead na top bar (quando há múltiplos leads) -->
    <% if (leads.length > 1) { %>
      <select id="leadSwitcher" onchange="switchLead(this.value)"
        style="padding:0.3rem 0.7rem;border-radius:20px;border:1.5px solid #444;background:transparent;color:#ccc;font-size:0.75rem;font-family:Poppins,sans-serif;outline:none;cursor:pointer">
        <% leads.forEach(lead => { %>
          <option value="<%= lead.id %>" <%= (selectedLeadId === lead.id) ? 'selected' : '' %>>
            <%= lead.name %><% if (lead.is_primary) { %> ⭐<% } %>
          </option>
        <% }) %>
      </select>
    <% } %>

    <a href="/admin/proposals/<%= proposal.id %>/edit" class="tb-btn">✏️ Editar</a>
    <a href="<%= baseUrl %>/proposta/<%= proposal.token %>" class="tb-btn" target="_blank" title="Abrir em nova aba">↗ Nova aba</a>
    <a href="/admin/proposals" class="tb-btn">← Propostas</a>
  </div>

  <!-- ── Sidebar ───────────────────────────────────────── -->
  <aside class="view-sidebar">

    <!-- Leads vinculados -->
    <div class="vs-section">
      <div class="vs-label">👥 Leads vinculados</div>
      <div class="lead-selector-list">
        <% leads.forEach(lead => { %>
          <a href="/admin/proposals/<%= proposal.id %>/view?lead_id=<%= lead.id %>"
             class="lead-selector-item <%= (selectedLeadId === lead.id) ? 'active' : '' %>">
            <div class="lsi-avatar"><%= lead.name.charAt(0).toUpperCase() %></div>
            <div class="lsi-info">
              <div class="lsi-name"><%= lead.name %></div>
              <% if (lead.company_name) { %>
                <div class="lsi-company"><%= lead.company_name %></div>
              <% } else if (lead.email) { %>
                <div class="lsi-company"><%= lead.email %></div>
              <% } %>
            </div>
            <% if (lead.is_primary) { %><span class="lsi-badge">Principal</span><% } %>
          </a>
        <% }) %>
      </div>
    </div>

    <!-- Métricas resumidas -->
    <div class="vs-section">
      <div class="vs-label">📊 Engajamento</div>
      <div class="vs-metrics">
        <div class="vs-metric">
          <div class="vs-metric-val"><%= stats ? stats.totalAccesses : 0 %></div>
          <div class="vs-metric-lbl">Acessos</div>
        </div>
        <div class="vs-metric">
          <div class="vs-metric-val"><%= stats ? stats.totalSlidesSeen : 0 %>/12</div>
          <div class="vs-metric-lbl">Slides vistos</div>
        </div>
        <div class="vs-metric">
          <%
            const dur = stats ? (stats.totalDuration || 0) : 0;
            const mm = Math.floor(dur / 60);
            const ss = dur % 60;
          %>
          <div class="vs-metric-val"><%= mm %>m<%= ss %>s</div>
          <div class="vs-metric-lbl">Tempo total</div>
        </div>
        <div class="vs-metric">
          <% const rev = stats && stats.slideStats ? stats.slideStats.filter(s => s.revisit_count > 0).length : 0; %>
          <div class="vs-metric-val"><%= rev %></div>
          <div class="vs-metric-lbl">Revisitas</div>
        </div>
      </div>
    </div>

    <!-- Status e token -->
    <div class="vs-section">
      <div class="vs-label">ℹ️ Informações</div>
      <div style="display:flex;flex-direction:column;gap:0.5rem">
        <div class="vs-status-row">
          <span class="status-dot <%= proposal.proposal_status || 'active' %>"></span>
          <span style="font-size:0.78rem;color:#555">
            <% if (proposal.proposal_status === 'archived') { %>Arquivada
            <% } else if (proposal.proposal_status === 'rejected') { %>Rejeitada
            <% } else { %>Ativa<% } %>
          </span>
          <span style="font-size:0.72rem;color:#bbb;margin-left:auto">
            <% const modeLabels = { ready: 'Pronta', build: 'Montar', both: 'Ambas' }; %>
            <%= modeLabels[proposal.proposal_mode || 'both'] %>
          </span>
        </div>
        <div>
          <div class="vs-label" style="margin-bottom:0.3rem">Token</div>
          <div class="token-row">
            <span class="token-chip" id="proposalToken"><%= proposal.token %></span>
            <button class="copy-btn" onclick="copyToken()">📋</button>
          </div>
        </div>
        <div style="font-size:0.72rem;color:#aaa">
          Criada em <%= new Date(proposal.created_at).toLocaleDateString('pt-BR') %>
        </div>
      </div>
    </div>

    <!-- Ações rápidas -->
    <div class="vs-section">
      <div class="vs-label">⚡ Ações rápidas</div>
      <div class="vs-actions">
        <a href="/admin/proposals/<%= proposal.id %>/edit" class="vs-action-btn">
          ✏️ Editar proposta
        </a>
        <form action="/admin/proposals/<%= proposal.id %>/resend-emails" method="POST" style="display:contents">
          <button type="submit" class="vs-action-btn">
            📧 Reenviar emails
          </button>
        </form>
        <a href="<%= baseUrl %>/proposta/<%= proposal.token %>" class="vs-action-btn" target="_blank">
          ↗ Link do cliente
        </a>
        <button class="vs-action-btn" onclick="copyLink()">
          📋 Copiar link
        </button>
        <% if (proposal.proposal_status !== 'archived') { %>
          <form action="/admin/proposals/<%= proposal.id %>/archive" method="POST" style="display:contents"
                onsubmit="return confirm('Arquivar esta proposta?')">
            <input type="hidden" name="archived" value="1">
            <button type="submit" class="vs-action-btn danger">🗃️ Arquivar</button>
          </form>
        <% } else { %>
          <form action="/admin/proposals/<%= proposal.id %>/archive" method="POST" style="display:contents">
            <input type="hidden" name="archived" value="0">
            <button type="submit" class="vs-action-btn">♻️ Reativar</button>
          </form>
        <% } %>
      </div>
    </div>

  </aside>

  <!-- ── Área do iframe ────────────────────────────────── -->
  <div class="view-iframe-area">

    <!-- Seletor de dispositivo -->
    <div class="device-bar">
      <button class="device-btn active" id="btn-desktop" onclick="setDevice('desktop')">🖥 Desktop</button>
      <button class="device-btn" id="btn-tablet" onclick="setDevice('tablet')">📱 Tablet</button>
      <button class="device-btn" id="btn-mobile" onclick="setDevice('mobile')">📲 Mobile</button>
    </div>

    <!-- Loading spinner -->
    <div class="iframe-loading" id="iframeLoading">
      <div class="spinner"></div>
      <span>Carregando proposta...</span>
    </div>

    <!-- Wrapper com o iframe -->
    <div class="iframe-wrapper device-desktop" id="iframeWrapper">
      <div class="iframe-shell" id="iframeShell">
        <iframe
          id="proposalIframe"
          class="proposal-iframe"
          src="/proposta/<%= proposal.token %>/view"
          title="Visualização da Proposta"
          onload="onIframeLoad()"
          sandbox="allow-scripts allow-same-origin allow-forms allow-popups">
        </iframe>
      </div>
    </div>

  </div>

</div>

<div class="toast-admin hidden" id="toastAdmin"></div>

<script>
  // ── Device switcher ────────────────────────────────────────────────
  function setDevice(device) {
    const wrapper = document.getElementById('iframeWrapper');
    wrapper.className = 'iframe-wrapper device-' + device;
    document.querySelectorAll('.device-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('btn-' + device).classList.add('active');
  }

  // ── Lead switcher (dropdown na topbar) ────────────────────────────
  function switchLead(leadId) {
    showLoading();
    window.location.href = '/admin/proposals/<%= proposal.id %>/view?lead_id=' + leadId;
  }

  // ── Iframe load ───────────────────────────────────────────────────
  function onIframeLoad() {
    document.getElementById('iframeLoading').classList.add('hidden');
  }

  function showLoading() {
    document.getElementById('iframeLoading').classList.remove('hidden');
  }

  // ── Copy helpers ──────────────────────────────────────────────────
  const PROPOSAL_LINK = '<%= baseUrl %>/proposta/<%= proposal.token %>';
  const PROPOSAL_TOKEN = '<%= proposal.token %>';

  function copyLink() {
    navigator.clipboard.writeText(PROPOSAL_LINK).then(() => showToast('🔗 Link copiado!'));
  }

  function copyToken() {
    navigator.clipboard.writeText(PROPOSAL_TOKEN).then(() => showToast('📋 Token copiado!'));
  }

  function showToast(msg) {
    const t = document.getElementById('toastAdmin');
    t.textContent = msg;
    t.classList.remove('hidden');
    clearTimeout(t._timer);
    t._timer = setTimeout(() => t.classList.add('hidden'), 2500);
  }

  // ── Teclado: Escape → voltar para edição ─────────────────────────
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') window.location.href = '/admin/proposals/<%= proposal.id %>/edit';
  });

  // ── Reload iframe sem recarregar a página ─────────────────────────
  // O iframe recebe o token autenticado via session — reload é seguro
  function reloadIframe() {
    showLoading();
    const iframe = document.getElementById('proposalIframe');
    iframe.src = iframe.src;
  }
</script>
</body>
</html>
