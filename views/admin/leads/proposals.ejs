<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Propostas de <%= lead.name %> — Envox Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="top-bar"></div>
  <div class="admin-layout">
    <%- include('../_sidebar', { active: 'proposals' }) %>
    <main class="main-content">

      <!-- Page header -->
      <div class="page-header">
        <div>
          <div style="font-size:0.75rem;color:#888;margin-bottom:0.2rem">
            <a href="/admin/leads" style="color:#888;text-decoration:none">Leads</a>
            &rsaquo; <a href="/admin/leads/<%= lead.id %>" style="color:#888;text-decoration:none"><%= lead.name %></a>
            &rsaquo; Propostas
          </div>
          <h1>Propostas de <%= lead.name %></h1>
          <p class="page-subtitle">
            <%= lead.company_name ? lead.company_name + ' · ' : '' %><%= lead.email %> · <%= lead.whatsapp %>
          </p>
        </div>
        <div class="header-actions">
          <a href="/admin/leads/<%= lead.id %>" class="btn-outline" style="padding:8px 16px;font-size:0.82rem;border-radius:8px;text-decoration:none;border:1px solid #ddd;color:#555">← Voltar</a>
          <a href="/admin/proposals/new?lead_id=<%= lead.id %>" class="btn-primary">➕ Nova Proposta</a>
        </div>
      </div>

      <% if (success) { %><div class="alert alert-success"><span>✅</span> <%= success %></div><% } %>
      <% if (error) { %><div class="alert alert-error"><span>⚠️</span> <%= error %></div><% } %>

      <% if (!proposals || proposals.length === 0) { %>
        <div style="text-align:center;padding:4rem 2rem;background:#fff;border-radius:16px;border:1px solid #eee">
          <div style="font-size:3rem;margin-bottom:1rem">📭</div>
          <h3 style="color:#1a1a2e;margin-bottom:0.5rem">Nenhuma proposta encontrada</h3>
          <p style="color:#888;font-size:0.88rem;margin-bottom:1.5rem">Este lead ainda não possui propostas vinculadas.</p>
          <a href="/admin/proposals/new?lead_id=<%= lead.id %>" class="btn-primary">➕ Criar Proposta</a>
        </div>
      <% } else { %>

        <div style="display:flex;flex-direction:column;gap:1.25rem">

          <% proposals.forEach((p, idx) => {
            // Totais
            let rawMonthly = 0, rawOnetime = 0;
            (p.items || []).forEach(it => {
              const total = (parseFloat(it.price) || 0) * (parseInt(it.qty) || 1);
              if (it.category === 'onetime') rawOnetime += total;
              else rawMonthly += total;
            });
            const discM = parseFloat(p.admin_discount_monthly || 0);
            const discO = parseFloat(p.admin_discount_onetime || 0);
            const finalMonthly = rawMonthly * (1 - discM / 100);
            const finalOnetime = rawOnetime * (1 - discO / 100);

            // Status
            const statusMap = {
              active:   { cls: 'status-active',   label: '✅ Ativa' },
              awaiting: { cls: 'status-awaiting',  label: '⏳ Aguardando' },
              rejected: { cls: 'status-rejected',  label: '❌ Rejeitada' },
              archived: { cls: 'status-archived',  label: '🗃️ Arquivada' },
            };
            const hasAccept = p.latest_action === 'accept';
            const st = hasAccept ? { cls: 'status-accepted', label: '🎉 Aceita' }
                                 : (statusMap[p.proposal_status] || statusMap.active);

            // Decisão
            const actionMap = {
              accept:     '✅ Aceita',
              counter:    '🔄 Contraproposta',
              reject:     '❌ Rejeitada',
              email_sent: '🔥 Email enviado',
            };

            const dateStr = new Date(p.created_at).toLocaleDateString('pt-BR', { day:'2-digit', month:'short', year:'numeric' });
          %>

          <div class="proposal-row-card" id="card-<%= p.id %>">

            <!-- Header da proposta -->
            <div class="prc-header">
              <div class="prc-header-left">
                <div class="prc-meta">
                  <span>📅 <%= dateStr %></span>
                  <% if (p.created_by_client) { %>
                    <span class="pill pill-client">👤 Criada pelo cliente</span>
                  <% } %>
                  <% if (p.client_locked) { %>
                    <span class="pill pill-locked">🔒 Bloqueada</span>
                  <% } %>
                  <span class="pill pill-mode">
                    <% const modeLabels = { ready: '📋 Pronta', build: '🔧 Montar', both: '✨ Ambas' }; %>
                    <%= modeLabels[p.proposal_mode || 'both'] %>
                  </span>
                </div>
                <div class="prc-id">Proposta #<%= p.id %> — <span style="font-weight:400;color:#888">token: <code style="font-size:0.75rem;background:#f3f4f6;padding:1px 5px;border-radius:4px"><%= p.token %></code></span></div>
              </div>
              <div class="prc-header-right">
                <span class="status-pill <%= st.cls %>"><%= st.label %></span>
                <% if (p.latest_action) { %>
                  <span style="font-size:0.72rem;color:#888"><%= actionMap[p.latest_action] || p.latest_action %></span>
                <% } %>
              </div>
            </div>

            <!-- Corpo: serviços + totais -->
            <div class="prc-body">

              <!-- Serviços -->
              <% if (p.items && p.items.length > 0) { %>
                <div class="prc-items">
                  <div class="prc-label">Serviços</div>
                  <div class="items-chips">
                    <% p.items.forEach(it => { %>
                      <span class="chip <%= it.category === 'onetime' ? 'chip-onetime' : 'chip-monthly' %>">
                        <%= it.name %>
                        <% if (parseInt(it.qty) > 1) { %> ×<%= it.qty %><% } %>
                        — R$ <%= ((parseFloat(it.price)||0)*(parseInt(it.qty)||1)).toLocaleString('pt-BR',{minimumFractionDigits:0,maximumFractionDigits:0}) %>
                      </span>
                    <% }); %>
                  </div>
                </div>
              <% } %>

              <!-- Totais + descontos -->
              <div class="prc-totals">
                <% if (rawMonthly > 0) { %>
                  <div class="total-block">
                    <span class="total-label">Mensal (bruto)</span>
                    <span class="total-val">R$ <%= rawMonthly.toLocaleString('pt-BR',{minimumFractionDigits:0,maximumFractionDigits:0}) %></span>
                  </div>
                  <% if (discM > 0) { %>
                    <div class="total-block">
                      <span class="total-label">Desconto mensal</span>
                      <span class="total-val discount">−<%= discM %>% → R$ <%= finalMonthly.toLocaleString('pt-BR',{minimumFractionDigits:0,maximumFractionDigits:0}) %></span>
                    </div>
                  <% } %>
                <% } %>
                <% if (rawOnetime > 0) { %>
                  <div class="total-block">
                    <span class="total-label">Implantação (bruto)</span>
                    <span class="total-val">R$ <%= rawOnetime.toLocaleString('pt-BR',{minimumFractionDigits:0,maximumFractionDigits:0}) %></span>
                  </div>
                  <% if (discO > 0) { %>
                    <div class="total-block">
                      <span class="total-label">Desconto implantação</span>
                      <span class="total-val discount">−<%= discO %>% → R$ <%= finalOnetime.toLocaleString('pt-BR',{minimumFractionDigits:0,maximumFractionDigits:0}) %></span>
                    </div>
                  <% } %>
                <% } %>
                <% if (rawMonthly === 0 && rawOnetime === 0) { %>
                  <span style="font-size:0.8rem;color:#bbb">Sem itens de cobrança</span>
                <% } %>
              </div>

              <!-- Nota admin -->
              <% if (p.admin_notes && p.admin_notes.trim()) { %>
                <div class="prc-note">
                  <strong>📝 Nota interna:</strong> <%= p.admin_notes %>
                </div>
              <% } %>

              <!-- Histórico de ações -->
              <% if (p.actions && p.actions.length > 0) { %>
                <div class="prc-actions-block">
                  <div class="prc-label">Histórico de decisões</div>
                  <% p.actions.forEach(ac => { %>
                    <div class="action-row">
                      <span class="action-icon"><%= ac.action_type === 'accept' ? '✅' : ac.action_type === 'counter' ? '🔄' : ac.action_type === 'reject' ? '❌' : ac.action_type === 'email_sent' ? '🔥' : '📌' %></span>
                      <span class="action-type"><%= actionMap[ac.action_type] || ac.action_type %></span>
                      <span class="action-date"><%= new Date(ac.created_at).toLocaleDateString('pt-BR') %> <%= new Date(ac.created_at).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %></span>
                      <% if (ac.comment) { %>
                        <span class="action-comment">"<%= ac.comment %>"</span>
                      <% } %>
                    </div>
                  <% }); %>
                </div>
              <% } %>

            </div>

            <!-- Footer: ações admin -->
            <div class="prc-footer">
              <div class="prc-footer-left">
                <a href="/admin/proposals/<%= p.id %>/edit" class="btn-sm btn-outline">✏️ Editar</a>
                <a href="/admin/proposals/<%= p.id %>/heat" class="btn-sm btn-heat">🌡️ Calor</a>
                <button class="btn-sm btn-copy" onclick="copyLink('<%= p.token %>', this)">🔗 Copiar link</button>
                <% if (p.created_by_client && !p.client_locked) { %>
                  <button class="btn-sm" style="background:rgba(124,58,237,0.1);color:#7c3aed;border:1px solid rgba(124,58,237,0.3);border-radius:6px;padding:4px 10px;font-size:0.75rem;cursor:pointer"
                          onclick="toggleLock(<%= p.id %>, 1, this)">🔒 Bloquear</button>
                <% } else if (p.client_locked) { %>
                  <button class="btn-sm" style="background:rgba(16,185,129,0.1);color:#059669;border:1px solid rgba(16,185,129,0.3);border-radius:6px;padding:4px 10px;font-size:0.75rem;cursor:pointer"
                          onclick="toggleLock(<%= p.id %>, 0, this)">🔓 Desbloquear</button>
                <% } %>
              </div>
              <% if (p.created_by_client || p.proposal_status === 'awaiting') { %>
                <button class="btn-sm btn-discount"
                        onclick="openDiscountPanel(<%= p.id %>, <%= discM %>, <%= discO %>, `<%= (p.admin_notes || '').replace(/`/g, "'") %>`)">
                  💰 Ajustar Valores
                </button>
              <% } %>
            </div>

          </div>

          <% }); %>
        </div>
      <% } %>

    </main>
  </div>

  <!-- ── Modal: Ajustar Valores / Descontos ────────────────────────── -->
  <div id="discount-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center" onclick="closeDiscountModal(event)">
    <div style="background:#fff;border-radius:16px;padding:2rem;width:100%;max-width:460px;box-shadow:0 20px 60px rgba(0,0,0,0.2)" onclick="event.stopPropagation()">
      <h3 style="font-size:1.1rem;font-weight:700;color:#1a1a2e;margin-bottom:0.25rem">💰 Ajustar Valores</h3>
      <p style="font-size:0.8rem;color:#888;margin-bottom:1.5rem">Aplique descontos percentuais e deixe uma mensagem para o cliente.</p>

      <input type="hidden" id="dm-proposal-id">

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
        <label style="display:flex;flex-direction:column;gap:0.3rem">
          <span style="font-size:0.72rem;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:0.05em">Desconto Mensal (%)</span>
          <input type="number" id="dm-disc-monthly" min="0" max="100" step="0.5" value="0"
                 style="border:1px solid #ddd;border-radius:8px;padding:8px 12px;font-size:0.9rem;font-family:Poppins,sans-serif;outline:none">
        </label>
        <label style="display:flex;flex-direction:column;gap:0.3rem">
          <span style="font-size:0.72rem;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:0.05em">Desconto Implantação (%)</span>
          <input type="number" id="dm-disc-onetime" min="0" max="100" step="0.5" value="0"
                 style="border:1px solid #ddd;border-radius:8px;padding:8px 12px;font-size:0.9rem;font-family:Poppins,sans-serif;outline:none">
        </label>
      </div>

      <label style="display:flex;flex-direction:column;gap:0.3rem;margin-bottom:1.5rem">
        <span style="font-size:0.72rem;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:0.05em">Mensagem para o cliente (opcional)</span>
        <textarea id="dm-notes" rows="3" placeholder="Ex: Aplicamos 10% de desconto especial para você!"
                  style="border:1px solid #ddd;border-radius:8px;padding:8px 12px;font-size:0.85rem;font-family:Poppins,sans-serif;resize:vertical;outline:none"></textarea>
      </label>

      <div style="display:flex;gap:0.75rem;justify-content:flex-end">
        <button onclick="closeDiscountModal()" style="padding:9px 20px;background:#f3f4f6;border:none;border-radius:8px;font-family:Poppins,sans-serif;font-size:0.82rem;cursor:pointer;color:#555">Cancelar</button>
        <button onclick="saveDiscounts()" style="padding:9px 20px;background:#E91E63;color:#fff;border:none;border-radius:8px;font-family:Poppins,sans-serif;font-size:0.82rem;font-weight:700;cursor:pointer">💾 Salvar</button>
      </div>
    </div>
  </div>

  <div id="copy-toast" style="position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%) translateY(20px);background:#1a1a2e;color:#fff;padding:0.6rem 1.4rem;border-radius:24px;font-size:0.82rem;font-weight:600;font-family:Poppins,sans-serif;opacity:0;transition:all 0.25s;pointer-events:none;z-index:9999">🔗 Link copiado!</div>

  <style>
    .proposal-row-card {
      background: #fff;
      border-radius: 14px;
      border: 1px solid #e5e7eb;
      overflow: hidden;
      transition: box-shadow 0.2s;
    }
    .proposal-row-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.07); }

    .prc-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid #f0f0f0;
      background: #fafafa;
    }
    .prc-header-left { flex: 1; }
    .prc-header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; }
    .prc-meta { display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; font-size: 0.72rem; color: #888; margin-bottom: 0.3rem; }
    .prc-id { font-size: 0.82rem; font-weight: 700; color: #1a1a2e; }

    .pill { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 12px; font-size: 0.68rem; font-weight: 700; }
    .pill-client { background: rgba(233,30,99,0.09); color: #E91E63; }
    .pill-locked { background: rgba(124,58,237,0.1); color: #7c3aed; }
    .pill-mode   { background: rgba(21,101,192,0.08); color: #1565c0; }

    .status-pill { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; }
    .status-active   { background: rgba(46,125,50,0.1);    color: #2e7d32; }
    .status-awaiting { background: rgba(217,119,6,0.12);   color: #d97706; }
    .status-rejected { background: rgba(220,38,38,0.1);    color: #dc2626; }
    .status-archived { background: #f5f5f5;                color: #999; }
    .status-accepted { background: rgba(16,185,129,0.12);  color: #059669; }

    .prc-body { padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
    .prc-label { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #aaa; margin-bottom: 0.4rem; }

    .items-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .chip { padding: 3px 10px; border-radius: 7px; font-size: 0.72rem; font-weight: 600; border: 1px solid #e5e7eb; color: #444; background: #f9fafb; }
    .chip-monthly { border-color: #bfdbfe; background: #eff6ff; color: #1e40af; }
    .chip-onetime { border-color: #d9f99d; background: #f7fee7; color: #3f6212; }

    .prc-totals { display: flex; flex-wrap: wrap; gap: 1rem; background: #f8fafc; border-radius: 10px; padding: 0.75rem 1rem; }
    .total-block { display: flex; flex-direction: column; gap: 0.1rem; }
    .total-label { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #aaa; }
    .total-val { font-size: 0.95rem; font-weight: 700; color: #1a1a2e; }
    .total-val.discount { color: #10b981; }

    .prc-note { background: rgba(255,193,7,0.08); border: 1px solid rgba(255,193,7,0.3); border-radius: 9px; padding: 0.65rem 1rem; font-size: 0.82rem; color: #92400e; }

    .prc-actions-block { display: flex; flex-direction: column; gap: 0.4rem; }
    .action-row { display: flex; align-items: center; gap: 0.6rem; font-size: 0.78rem; flex-wrap: wrap; }
    .action-icon { font-size: 0.9rem; }
    .action-type { font-weight: 600; color: #1a1a2e; }
    .action-date { color: #aaa; font-size: 0.7rem; }
    .action-comment { color: #555; font-style: italic; font-size: 0.76rem; flex-basis: 100%; padding-left: 1.6rem; }

    .prc-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1.5rem;
      border-top: 1px solid #f0f0f0;
      background: #fafafa;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .prc-footer-left { display: flex; gap: 0.4rem; flex-wrap: wrap; }

    .btn-discount { background: linear-gradient(135deg,#E91E63,#c2185b); color: #fff; border: none; border-radius: 8px; padding: 6px 14px; font-size: 0.78rem; font-weight: 700; font-family: Poppins,sans-serif; cursor: pointer; transition: opacity 0.15s; }
    .btn-discount:hover { opacity: 0.88; }

    @media (max-width: 600px) {
      .prc-header { flex-direction: column; }
      .prc-header-right { align-items: flex-start; }
      .prc-footer { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <script>
    function copyLink(token, btn) {
      const link = window.location.origin + '/proposta/' + token;
      navigator.clipboard.writeText(link).then(() => {
        btn.textContent = '✅ Copiado';
        const toast = document.getElementById('copy-toast');
        toast.style.opacity = '1'; toast.style.transform = 'translateX(-50%) translateY(0)';
        setTimeout(() => {
          btn.textContent = '🔗 Copiar link';
          toast.style.opacity = '0'; toast.style.transform = 'translateX(-50%) translateY(20px)';
        }, 2000);
      }).catch(() => alert('Não foi possível copiar'));
    }

    function toggleLock(proposalId, lock, btn) {
      btn.disabled = true;
      btn.textContent = '…';
      fetch('/admin/proposals/' + proposalId + '/toggle-lock', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ locked: lock })
      })
      .then(r => r.json())
      .then(d => {
        if (d.success) location.reload();
        else { alert('Erro: ' + (d.error || 'tente novamente')); btn.disabled = false; btn.textContent = lock ? '🔒 Bloquear' : '🔓 Desbloquear'; }
      })
      .catch(() => { btn.disabled = false; btn.textContent = lock ? '🔒 Bloquear' : '🔓 Desbloquear'; });
    }

    function openDiscountPanel(proposalId, discMonthly, discOnetime, notes) {
      document.getElementById('dm-proposal-id').value = proposalId;
      document.getElementById('dm-disc-monthly').value = discMonthly || 0;
      document.getElementById('dm-disc-onetime').value = discOnetime || 0;
      document.getElementById('dm-notes').value = notes || '';
      document.getElementById('discount-modal').style.display = 'flex';
    }

    function closeDiscountModal(e) {
      if (!e || e.target === document.getElementById('discount-modal')) {
        document.getElementById('discount-modal').style.display = 'none';
      }
    }

    function saveDiscounts() {
      const proposalId = document.getElementById('dm-proposal-id').value;
      const discM = parseFloat(document.getElementById('dm-disc-monthly').value) || 0;
      const discO = parseFloat(document.getElementById('dm-disc-onetime').value) || 0;
      const notes = document.getElementById('dm-notes').value.trim();

      fetch('/admin/proposals/' + proposalId + '/discounts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ discount_monthly: discM, discount_onetime: discO, admin_notes: notes })
      })
      .then(r => r.json())
      .then(d => {
        if (d.success) location.reload();
        else alert('Erro: ' + (d.error || 'tente novamente'));
      })
      .catch(() => alert('Erro de conexão'));
    }
  </script>
</body>
</html>
