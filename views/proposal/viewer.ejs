<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Proposta Envox — <%= lead.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/proposal.css">
</head>
<body class="proposal-body">
  <!-- Progress Bar Top -->
  <div class="progress-bar-top">
    <div class="progress-fill" id="progressFill"></div>
  </div>
  
  <!-- Header -->
  <header class="proposal-header">
    <div class="header-brand">
      <span class="brand-env">env</span><span class="brand-ox">ox</span>
    </div>
    <div class="header-info">
      <span class="header-lead">Proposta para: <strong><%= lead.name %></strong></span>
    </div>
    <div class="header-slide-counter">
      <span id="currentSlideNum">1</span> / <%= slides.length %>
    </div>
  </header>
  
  <!-- Slides Container -->
  <div class="slides-container" id="slidesContainer">
    <% slides.forEach((slide, index) => { %>
      <div class="slide" 
           id="slide-<%= slide.number %>" 
           data-slide="<%= slide.number %>"
           data-index="<%= index %>"
           style="display: <%= index === 0 ? 'flex' : 'none' %>">
        <%- slide.html %>
      </div>
    <% }) %>
  </div>
  
  <!-- Navigation -->
  <div class="proposal-nav">
    <button class="nav-btn nav-prev" id="btnPrev" disabled>
      <span>←</span>
    </button>
    
    <!-- Dots -->
    <div class="nav-dots" id="navDots">
      <% slides.forEach((slide, index) => { %>
        <button class="dot <%= index === 0 ? 'dot-active' : '' %>" 
                data-index="<%= index %>"
                title="<%= slide.title %>">
        </button>
      <% }) %>
    </div>
    
    <button class="nav-btn nav-next" id="btnNext">
      <span>→</span>
    </button>
  </div>
  
  <!-- Slide Title Bar -->
  <div class="slide-title-bar">
    <span id="slideTitleText"><%= slides[0].title %></span>
  </div>

  <!-- Data attrs for JS -->
  <script>
    window.PROPOSAL_TOKEN = '<%= token %>';
    window.PROPOSAL_LEAD_ID = '<%= lead.id %>';
    window.TOTAL_SLIDES = <%= slides.length %>;
    window.SLIDE_TITLES = <%- JSON.stringify(slides.map(s => s.title)) %>;
    window.LEAD_DISCOUNT_MONTHLY = <%= lead.discount_monthly || 0 %>;
    window.LEAD_DISCOUNT_ONETIME = <%= lead.discount_onetime || 0 %>;
    window.LEAD_DISCOUNT_EXPIRES = '<%= lead.discount_expires || "" %>';
  </script>
  <script src="/js/tracking.js"></script>
  <script src="/js/proposal.js"></script>
  <script src="/js/builder.js"></script>
</body>
</html>
