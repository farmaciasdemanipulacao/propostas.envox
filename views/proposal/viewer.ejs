<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Proposta Envox — <%= lead.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/proposal.css">
</head>
<body class="proposal-body">

  <!-- ── FIXED HEADER ── -->
  <header class="proposal-header" id="proposalHeader">
    <div class="header-brand">
      <span class="brand-env">env</span><span class="brand-ox">ox</span>
    </div>
    <div class="header-info">
      <span class="header-lead">Proposta para: <strong><%= lead.name %></strong></span>
    </div>
    <div class="header-right">
      <div class="header-slide-counter">
        <span id="currentSlideNum">1</span>&nbsp;/&nbsp;<%= slides.length %>
      </div>
    </div>
  </header>

  <!-- ── PROGRESS BAR ── -->
  <div class="progress-bar-top" id="progressBarTop">
    <div class="progress-fill" id="progressFill" style="width:0%"></div>
  </div>

  <!-- ── STEP NAV SIDEBAR (floating) ── -->
  <nav class="step-nav" id="stepNav">
    <% slides.forEach((slide, index) => { %>
      <button class="step-dot <%= index === 0 ? 'step-dot-active' : '' %>"
              data-index="<%= index %>"
              title="<%= slide.title %>"
              onclick="scrollToSlide(<%= index %>)">
        <span class="step-dot-num"><%= index + 1 %></span>
      </button>
    <% }) %>
  </nav>

  <!-- ── PAGES CONTAINER ── -->
  <main class="pages-container" id="pagesContainer">
    <% slides.forEach((slide, index) => { %>
      <section class="page-section" 
               id="page-<%= index %>"
               data-index="<%= index %>"
               data-slide="<%= slide.number %>">
        <%- slide.html %>
      </section>
    <% }) %>
  </main>

  <!-- ── PREV / NEXT FLOATING BUTTONS ── -->
  <div class="page-nav-btns" id="pageNavBtns">
    <button class="page-nav-btn page-nav-prev" id="btnPrev" onclick="navigatePage(-1)" disabled title="Seção anterior">
      <span>↑</span>
    </button>
    <button class="page-nav-btn page-nav-next" id="btnNext" onclick="navigatePage(1)" title="Próxima seção">
      <span>↓</span>
    </button>
  </div>

  <!-- ── SLIDE TITLE TOAST ── -->
  <div class="slide-title-toast" id="slideTitleToast">
    <span id="slideTitleText"><%= slides[0].title %></span>
  </div>

  <!-- ── JS GLOBALS ── -->
  <script>
    window.PROPOSAL_TOKEN   = '<%= token %>';
    window.PROPOSAL_LEAD_ID = '<%= lead.id %>';
    window.TOTAL_SLIDES     = <%= slides.length %>;
    window.SLIDE_TITLES     = <%- JSON.stringify(slides.map(s => s.title)) %>;
    window.LEAD_DISCOUNT_MONTHLY  = <%= lead.discount_monthly || 0 %>;
    window.LEAD_DISCOUNT_ONETIME  = <%= lead.discount_onetime || 0 %>;
    window.LEAD_DISCOUNT_EXPIRES  = '<%= lead.discount_expires || "" %>';
    window.PROPOSAL_MODE = '<%= lead.proposal_mode || "both" %>';
    <% if (lead.proposal_items) { %>
    window.PROPOSAL_ITEMS = <%- JSON.stringify(lead.proposal_items || []) %>;
    window.PROPOSAL_DESC  = <%- JSON.stringify(lead.proposal_description || '') %>;
    window.PROPOSAL_SCOPE = <%- JSON.stringify(lead.proposal_scope || '') %>;
    window.PROPOSAL_TIMELINE = <%- JSON.stringify(lead.proposal_timeline || '') %>;
    <% } else { %>
    window.PROPOSAL_ITEMS = [];
    window.PROPOSAL_DESC  = '';
    window.PROPOSAL_SCOPE = '';
    window.PROPOSAL_TIMELINE = '';
    <% } %>
  </script>

  <!-- ── DECISION WIDGET (floating right) ── -->
  <div class="decision-widget hidden" id="decisionWidget">
    <div class="decision-widget-header">
      <span class="decision-widget-title">📋 Sua Decisão</span>
      <span class="decision-widget-page" id="dwPageLabel">Slide 1</span>
      <button class="decision-widget-close" onclick="toggleDecisionWidget()" title="Fechar">✕</button>
    </div>
    <div class="decision-widget-body" id="dwBody">
      <button class="dw-btn dw-btn-accept" onclick="dwSelectAction('accept')">✅ Aceitar Proposta</button>
      <button class="dw-btn dw-btn-counter" onclick="dwSelectAction('counter')">🔄 Fazer Contra Proposta</button>
      <button class="dw-btn dw-btn-reject" onclick="dwSelectAction('reject')">❌ Rejeitar Proposta</button>
    </div>
    <div class="dw-form" id="dwForm">
      <div id="dwFormCounter" style="display:none">
        <div class="dw-form-row">
          <label>Valor que faz sentido para você (R$)</label>
          <input type="number" id="dwCounterValue" placeholder="Ex: 2500" min="0" step="50">
        </div>
        <div class="dw-form-row">
          <label>Comentário (opcional)</label>
          <textarea id="dwComment" placeholder="Descreva sua proposta..."></textarea>
        </div>
      </div>
      <div id="dwFormReject" style="display:none">
        <div class="dw-form-row">
          <label>Por que você está rejeitando? (opcional)</label>
          <textarea id="dwRejectComment" placeholder="Nos ajude a entender..."></textarea>
        </div>
      </div>
      <button class="dw-submit" id="dwSubmitBtn" onclick="dwSubmit()">Enviar Decisão</button>
    </div>
    <div class="dw-success" id="dwSuccess">
      <span id="dwSuccessMsg">✅ Sua decisão foi registrada!</span><br>
      <small style="color:#888;font-size:0.72rem">Nossa equipe entrará em contato em breve.</small>
    </div>
  </div>
  <button class="decision-widget-toggle show" id="decisionToggle" onclick="toggleDecisionWidget()">
    📋 Decisão
  </button>

  <!-- ── SHARE WIDGET (floating left) ── -->
  <div class="share-widget hidden" id="shareWidget">
    <div class="share-widget-header">
      <span class="share-widget-title">📤 Compartilhar Proposta</span>
      <button class="share-widget-close" onclick="toggleShareWidget()" title="Fechar">✕</button>
    </div>
    <div class="share-widget-body">
      <p class="sw-hint">Envie esta proposta para outra pessoa da sua empresa. Ela receberá um link de acesso exclusivo.</p>
      <div class="sw-form-row">
        <label>Nome</label>
        <input type="text" id="swName" placeholder="Nome da pessoa">
      </div>
      <div class="sw-form-row">
        <label>WhatsApp</label>
        <input type="text" id="swWhatsapp" placeholder="(41) 99999-9999">
      </div>
      <div class="sw-form-row">
        <label>E-mail</label>
        <input type="email" id="swEmail" placeholder="email@empresa.com">
      </div>
      <button class="sw-submit" onclick="swSubmit()">📤 Enviar Acesso</button>
      <div class="sw-success" id="swSuccess">
        ✅ Acesso enviado com sucesso!<br>
        <small style="color:#777">A pessoa receberá um link personalizado.</small>
      </div>
    </div>
  </div>
  <button class="share-widget-toggle" id="shareToggle" onclick="toggleShareWidget()">
    📤 Compartilhar
  </button>

  <script src="/js/tracking.js"></script>
  <script src="/js/proposal.js"></script>
  <script src="/js/builder.js"></script>
  <script src="/js/widgets.js"></script>
</body>
</html>
