<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Proposta Envox<% if (lead.company_name) { %> — <%= lead.company_name %><% } else { %> — <%= lead.name %><% } %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/proposal.css">
  <style>
    /* ── Decision Widget: PF/PJ tipo toggle buttons ── */
    .dw-tipo-btn {
      flex: 1;
      padding: 0.45rem 0.5rem;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      background: #f9fafb;
      color: #374151;
      font-size: 0.78rem;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
      text-align: center;
    }
    .dw-tipo-btn:hover {
      background: #f0f4ff;
      border-color: #6366f1;
    }
    .dw-tipo-btn.active {
      background: #6366f1;
      border-color: #6366f1;
      color: #fff;
      font-weight: 600;
    }
    /* ── Decision Widget: form rows inside accept form ── */
    #dwFormAccept .dw-form-row {
      margin-bottom: 0.55rem;
    }
    #dwFormAccept .dw-form-row label {
      display: block;
      font-size: 0.72rem;
      font-weight: 600;
      color: #6b7280;
      margin-bottom: 0.2rem;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    #dwFormAccept .dw-form-row input {
      width: 100%;
      padding: 0.4rem 0.55rem;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 0.82rem;
      color: #111;
      background: #fff;
      box-sizing: border-box;
      transition: border-color 0.15s;
    }
    #dwFormAccept .dw-form-row input:focus {
      outline: none;
      border-color: #6366f1;
      box-shadow: 0 0 0 2px rgba(99,102,241,0.15);
    }
  </style>
</head>
<body class="proposal-body">

  <!-- ── FIXED HEADER ── -->
  <header class="proposal-header" id="proposalHeader">
    <div class="header-brand">
      <span class="brand-env">env</span><span class="brand-ox">ox</span>
    </div>
    <div class="header-info">
      <% if (lead.company_name) { %>
        <span class="header-lead">Proposta para: <strong><%= lead.company_name %></strong><% if (lead.name) { %> · <span style="font-weight:400;opacity:0.75"><%= lead.name %></span><% } %></span>
      <% } else { %>
        <span class="header-lead">Proposta para: <strong><%= lead.name %></strong></span>
      <% } %>
    </div>
    <div class="header-right">
      <div class="header-slide-counter">
        <span id="currentSlideNum">1</span>&nbsp;/&nbsp;<%= slides.length %>
      </div>
    </div>
  </header>

  <!-- ── PROGRESS BAR ── -->
  <div class="progress-bar-top" id="progressBarTop">
    <div class="progress-fill" id="progressFill" style="width:0%"></div>
  </div>

  <!-- ── STEP NAV SIDEBAR (floating) ── -->
  <nav class="step-nav" id="stepNav">
    <% slides.forEach((slide, index) => { %>
      <button class="step-dot <%= index === 0 ? 'step-dot-active' : '' %>"
              data-index="<%= index %>"
              title="<%= slide.title %>"
              onclick="scrollToSlide(<%= index %>)">
        <span class="step-dot-num"><%= index + 1 %></span>
      </button>
    <% }) %>
  </nav>

  <!-- ── PAGES CONTAINER ── -->
  <main class="pages-container" id="pagesContainer">
    <% slides.forEach((slide, index) => { %>
      <section class="page-section"
               id="page-<%= index %>"
               data-index="<%= index %>"
               data-slide="<%= slide.number %>">
        <%- slide.html %>
      </section>
    <% }) %>
  </main>

  <!-- ── PREV / NEXT FLOATING BUTTONS ── -->
  <div class="page-nav-btns" id="pageNavBtns">
    <button class="page-nav-btn page-nav-prev" id="btnPrev" onclick="navigatePage(-1)" disabled title="Seção anterior">
      <span>↑</span>
    </button>
    <button class="page-nav-btn page-nav-next" id="btnNext" onclick="navigatePage(1)" title="Próxima seção">
      <span>↓</span>
    </button>
  </div>

  <!-- ── SLIDE TITLE TOAST ── -->
  <div class="slide-title-toast" id="slideTitleToast">
    <span id="slideTitleText"><%= slides[0].title %></span>
  </div>

  <!-- ── JS GLOBALS ── -->
  <script>
    window.PROPOSAL_TOKEN    = '<%= token %>';
    window.PROPOSAL_ID       = <%= proposal.id %>;
    window.PROPOSAL_LEAD_ID  = <%= lead.id %>;
    window.TOTAL_SLIDES      = <%= slides.length %>;
    window.SLIDE_TITLES      = <%- JSON.stringify(slides.map(s => s.title)) %>;
    window.LEAD_DISCOUNT_MONTHLY  = 0;
    window.LEAD_DISCOUNT_ONETIME  = 0;
    window.LEAD_DISCOUNT_EXPIRES  = '';
    window.PROPOSAL_MODE     = '<%= proposal.proposal_mode || "both" %>';
    window.COMPANY_NAME      = <%- JSON.stringify(lead.company_name || '') %>;
    window.LEAD_NAME         = <%- JSON.stringify(lead.name || '') %>;
    window.LEAD_CARGO        = <%- JSON.stringify(lead.cargo || '') %>;
    window.WHATSAPP_URL      = 'https://wa.me/554133000404';
    <% if (proposal.proposal_items) { %>
    window.PROPOSAL_ITEMS    = <%- JSON.stringify(proposal.proposal_items || []) %>;
    window.PROPOSAL_DESC     = <%- JSON.stringify(proposal.proposal_description || '') %>;
    window.PROPOSAL_SCOPE    = <%- JSON.stringify(proposal.proposal_scope || '') %>;
    window.PROPOSAL_TIMELINE = <%- JSON.stringify(proposal.proposal_timeline || '') %>;
    <% } else { %>
    window.PROPOSAL_ITEMS    = [];
    window.PROPOSAL_DESC     = '';
    window.PROPOSAL_SCOPE    = '';
    window.PROPOSAL_TIMELINE = '';
    <% } %>
    window.PROPOSAL_SPECIAL_CONDITION = <%- JSON.stringify(proposal.special_condition || '') %>;
    window.PROPOSAL_PAYMENT_CONDITIONS = (function() {
      try {
        var raw = <%- JSON.stringify(proposal.payment_conditions || null) %>;
        if (!raw) return [];
        return typeof raw === 'string' ? JSON.parse(raw) : raw;
      } catch(e) { return []; }
    })();
    // Sinaliza ao tracking.js que este acesso é do administrador — NUNCA registrar dados
    window.IS_ADMIN_PREVIEW = <%= isAdminPreview ? 'true' : 'false' %>;
  </script>

  <!-- ── DECISION WIDGET (floating right) ── -->
  <div class="decision-widget hidden" id="decisionWidget">
    <div class="decision-widget-header">
      <span class="decision-widget-title">⚖️ Decidir sobre a Proposta</span>
      <span class="decision-widget-page" id="dwPageLabel">Slide 1</span>
      <button class="decision-widget-close" onclick="toggleDecisionWidget()" title="Fechar">✕</button>
    </div>
    <div class="decision-widget-body" id="dwBody">
      <button class="dw-btn dw-btn-accept" onclick="dwSelectAction('accept')">✅ Aceitar Proposta</button>
      <button class="dw-btn dw-btn-counter" onclick="dwSelectAction('counter')">🔄 Fazer Contra Proposta</button>
      <button class="dw-btn dw-btn-reject" onclick="dwSelectAction('reject')">❌ Rejeitar Proposta</button>
      <a class="dw-btn dw-btn-whatsapp" id="dwWaBtn"
         href="https://wa.me/554133000404?text=Ol%C3%A1!%20Estou%20analisando%20a%20proposta%20da%20Envox%20e%20gostaria%20de%20conversar."
         target="_blank">💬 Falar sobre esta Proposta</a>
    </div>
    <div class="dw-form" id="dwForm">

      <!-- ── Aceitar: formulário de dados cadastrais ── -->
      <div id="dwFormAccept" style="display:none">
        <p style="font-size:0.78rem;color:#555;margin-bottom:0.85rem;line-height:1.5">
          Ótimo! Precisamos de alguns dados para iniciar o processo de contratação.<br>
          Selecione o tipo:
        </p>
        <div style="display:flex;gap:0.5rem;margin-bottom:1rem">
          <button type="button" class="dw-tipo-btn active" id="dw-btn-pf" onclick="dwSwitchTipo('pf')">🧑 Pessoa Física</button>
          <button type="button" class="dw-tipo-btn" id="dw-btn-pj" onclick="dwSwitchTipo('pj')">🏢 Pessoa Jurídica</button>
        </div>
        <input type="hidden" id="dwTipoPessoa" value="pf">

        <!-- Pessoa Física -->
        <div id="dw-section-pf">
          <div class="dw-form-row"><label>Nome completo *</label><input type="text" id="dw-nome_completo" placeholder="Seu nome completo"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem">
            <div class="dw-form-row"><label>CPF *</label><input type="text" id="dw-cpf" placeholder="000.000.000-00"></div>
            <div class="dw-form-row"><label>RG *</label><input type="text" id="dw-rg" placeholder="00.000.000-0"></div>
          </div>
          <div class="dw-form-row"><label>Data de Nascimento *</label><input type="date" id="dw-data_nascimento"></div>
          <div class="dw-form-row"><label>Endereço Residencial *</label><input type="text" id="dw-endereco_residencial" placeholder="Rua, número, bairro, cidade — Estado"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem">
            <div class="dw-form-row"><label>E-mail assinatura *</label><input type="email" id="dw-email_assinatura" placeholder="assinatura@empresa.com"></div>
            <div class="dw-form-row"><label>E-mail financeiro *</label><input type="email" id="dw-email_financeiro" placeholder="financeiro@empresa.com"></div>
          </div>
        </div>

        <!-- Pessoa Jurídica -->
        <div id="dw-section-pj" style="display:none">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem">
            <div class="dw-form-row"><label>CNPJ *</label><input type="text" id="dw-cnpj" placeholder="00.000.000/0000-00"></div>
            <div class="dw-form-row"><label>Razão Social *</label><input type="text" id="dw-razao_social" placeholder="Nome empresarial"></div>
          </div>
          <div class="dw-form-row"><label>Endereço da Sede *</label><input type="text" id="dw-endereco_sede" placeholder="Rua, número, bairro, cidade — Estado"></div>
          <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:#aaa;letter-spacing:.4px;margin:0.6rem 0 0.25rem">Sócio Representante Legal</div>
          <div class="dw-form-row"><label>Nome completo *</label><input type="text" id="dw-nome_socio" placeholder="Nome completo"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem">
            <div class="dw-form-row"><label>CPF *</label><input type="text" id="dw-cpf_socio" placeholder="000.000.000-00"></div>
            <div class="dw-form-row"><label>RG *</label><input type="text" id="dw-rg_socio" placeholder="00.000.000-0"></div>
          </div>
          <div class="dw-form-row"><label>Data de Nascimento *</label><input type="date" id="dw-data_nascimento_socio"></div>
          <div class="dw-form-row"><label>Endereço Residencial do Sócio *</label><input type="text" id="dw-endereco_residencial_socio" placeholder="Rua, número, bairro, cidade — Estado"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem">
            <div class="dw-form-row"><label>E-mail assinatura *</label><input type="email" id="dw-email_assinatura-pj" placeholder="assinatura@empresa.com"></div>
            <div class="dw-form-row"><label>E-mail financeiro *</label><input type="email" id="dw-email_financeiro-pj" placeholder="financeiro@empresa.com"></div>
          </div>
        </div>
        <div id="dw-accept-error" style="display:none;background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:0.5rem 0.75rem;color:#b91c1c;font-size:0.78rem;margin-top:0.5rem"></div>
      </div>

      <!-- ── Contraproposta ── -->
      <div id="dwFormCounter" style="display:none">
        <div class="dw-form-row">
          <label>Valor que faz sentido para você (R$)</label>
          <input type="number" id="dwCounterValue" placeholder="Ex: 2500" min="0" step="50">
        </div>
        <div class="dw-form-row">
          <label>Comentário (opcional)</label>
          <textarea id="dwComment" placeholder="Descreva sua proposta..."></textarea>
        </div>
      </div>

      <!-- ── Rejeitar ── -->
      <div id="dwFormReject" style="display:none">
        <div class="dw-form-row">
          <label>Por que você está rejeitando? (opcional)</label>
          <textarea id="dwRejectComment" placeholder="Nos ajude a entender..."></textarea>
        </div>
      </div>

      <button class="dw-submit" id="dwSubmitBtn" onclick="dwSubmit()">Enviar Decisão</button>
    </div>
    <div class="dw-success" id="dwSuccess">
      <span id="dwSuccessMsg">✅ Sua decisão foi registrada!</span><br>
      <small style="color:#888;font-size:0.72rem">Nossa equipe entrará em contato em breve.</small>
    </div>
  </div>

  <!-- Botão flutuante de decisão com quick-actions visíveis -->
  <div class="decision-widget-toggle" id="decisionToggle">
    <span class="dw-toggle-label">⚖️ Decidir</span>
    <div class="dw-quick-btns">
      <button class="dw-quick-btn dw-quick-accept" onclick="dwQuickAction('accept')" title="Aceitar Proposta">✅ Aceitar</button>
      <button class="dw-quick-btn dw-quick-counter" onclick="dwQuickAction('counter')" title="Fazer Contra Proposta">🔄 Contraproposta</button>
      <button class="dw-quick-btn dw-quick-reject" onclick="dwQuickAction('reject')" title="Rejeitar Proposta">❌ Rejeitar</button>
      <a class="dw-quick-btn dw-quick-whatsapp" id="dwQuickWa"
         href="https://wa.me/554133000404?text=Ol%C3%A1!%20Estou%20analisando%20a%20proposta%20da%20Envox%20e%20gostaria%20de%20conversar."
         target="_blank" title="Falar sobre esta Proposta">💬 Falar</a>
    </div>
  </div>

  <!-- ── SHARE WIDGET (floating left) ── -->
  <div class="share-widget hidden" id="shareWidget">
    <div class="share-widget-header">
      <span class="share-widget-title">📤 Compartilhar Proposta</span>
      <button class="share-widget-close" onclick="toggleShareWidget()" title="Fechar">✕</button>
    </div>
    <div class="share-widget-body">
      <p class="sw-hint">Quer que um sócio, diretor ou responsável também analise esta proposta? Envie um link exclusivo — a pessoa receberá por e-mail e ficará registrada no sistema.</p>
      <div class="sw-form-row">
        <label>Nome *</label>
        <input type="text" id="swName" placeholder="Nome da pessoa">
      </div>
      <div class="sw-form-row">
        <label>Cargo / Função</label>
        <input type="text" id="swCargo" placeholder="Ex: Sócio, Diretor, Gerente...">
      </div>
      <div class="sw-form-row">
        <label>WhatsApp *</label>
        <input type="text" id="swWhatsapp" placeholder="(41) 99999-9999">
      </div>
      <div class="sw-form-row">
        <label>E-mail * (receberá o link)</label>
        <input type="email" id="swEmail" placeholder="email@empresa.com">
      </div>
      <button class="sw-submit" id="swSubmitBtn" onclick="swSubmit()">📤 Enviar Link de Acesso</button>
      <div class="sw-success" id="swSuccess">
        ✅ Link enviado com sucesso!<br>
        <small style="color:#555;font-size:0.72rem">A pessoa receberá o e-mail com o link exclusivo em instantes e será cadastrada automaticamente.</small>
      </div>
    </div>
  </div>
  <button class="share-widget-toggle" id="shareToggle" onclick="toggleShareWidget()">
    📤 Enviar para Analisar
  </button>

  <script src="/js/tracking.js"></script>
  <script src="/js/proposal.js"></script>
  <script src="/js/builder.js"></script>
  <script src="/js/widgets.js"></script>

  <!-- ── Bounced tracker: registra que o lead viu o slide sem preencher proposta ── -->
  <% if (!isAdminPreview && (proposal.proposal_mode === 'build' || proposal.proposal_mode === 'both')) { %>
  <script>
    (function() {
      const mode = window.PROPOSAL_MODE;
      if (mode !== 'build' && mode !== 'both') return;
      // Marca bounced após 8s na página (lead viu mas não agiu)
      setTimeout(function() {
        fetch('/proposta/mark-viewer-bounced', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: window.PROPOSAL_TOKEN })
        }).catch(function() {});
      }, 8000);
    })();
  </script>
  <% } %>
</body>
</html>
