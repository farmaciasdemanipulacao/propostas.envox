            <span class="mcard-desc">Converse com um especialista antes de tomar sua decisão.</span>
            <span class="mcard-cta">Abrir WhatsApp ↗</span>
          </a>
        </div>

        <!-- ── ACCEPT panel (modal) ── -->
        <div class="modal-panel" id="mpanel-accept">
          <div class="modal-panel-head">
            <span style="font-size:1.5rem">✅</span>
            <div class="modal-panel-title">Aceitar Proposta — Dados Cadastrais</div>
          </div>
          <p style="font-size:0.8rem;color:#475569;margin-bottom:1rem;line-height:1.55">Informe seus dados para formalização:</p>
