            <label style="display:block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:#475569;margin-bottom:0.35rem">Orçamento estimado (opcional)</label>
            <input type="text" id="np-budget"
              placeholder="Ex: R$ 2.000/mês"
