  <!-- ═══════════════════════════════════════════
       JAVASCRIPT
  ════════════════════════════════════════════ -->
  <script>
    function fmtBRL(v) {
      return 'R$ ' + Number(v).toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    // ── Inline panels (inside card) ─────────────────────────────────────────

    function openInlinePanel(pid, type) {
      // Close all other panels for this proposal
      ['accept','counter','reject'].forEach(t => {
        const el = document.getElementById('ipanel-' + t + '-' + pid);
        if (el) el.classList.remove('visible');
      });
      // Highlight card
      document.querySelectorAll('#card-' + pid + ' .act-card').forEach(c => c.classList.remove('active'));
      const activeCard = document.querySelector('#card-' + pid + ' .' + type + '-card');
      if (activeCard) activeCard.classList.add('active');
      // Show panel
      const panel = document.getElementById('ipanel-' + type + '-' + pid);
      if (panel) {
        panel.classList.add('visible');
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }

    function closeInlinePanel(pid) {
      ['accept','counter','reject'].forEach(t => {
        const el = document.getElementById('ipanel-' + t + '-' + pid);
        if (el) el.classList.remove('visible');
      });
      document.querySelectorAll('#card-' + pid + ' .act-card').forEach(c => c.classList.remove('active'));
    }

    // PF / CNPJ toggle (inline)
    function iSwitchTipo(pid, tipo) {
      document.getElementById('iinput-tipo-' + pid).value = tipo;
      document.getElementById('ibtn-pf-' + pid).classList.toggle('active', tipo === 'pf');
      document.getElementById('ibtn-cnpj-' + pid).classList.toggle('active', tipo === 'cnpj');
      document.getElementById('isec-pf-' + pid).classList.toggle('visible', tipo === 'pf');
      document.getElementById('isec-cnpj-' + pid).classList.toggle('visible', tipo === 'cnpj');
      document.querySelectorAll('#isec-pf-' + pid + ' input').forEach(el => { el.required = (tipo === 'pf'); });
      document.querySelectorAll('#isec-cnpj-' + pid + ' input').forEach(el => { el.required = (tipo === 'cnpj'); });
    }

    function iSubmitAceite(e, pid) {
      e.preventDefault();
      const form  = document.getElementById('iform-accept-' + pid);
      const btn   = document.getElementById('ibtn-aceite-' + pid);
      const errEl = document.getElementById('ierr-accept-' + pid);
      errEl.classList.remove('visible');
      const data  = Object.fromEntries(new FormData(form).entries());
      data.token   = _getTokenForCard(pid);
      data.lead_id = window._LEAD_ID;
      btn.disabled = true; btn.textContent = '⏳ Enviando...';
      fetch('/proposta/finalizar-aceitar', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(r => r.json()).then(res => {
        if (res.success) {
          document.getElementById('ipanel-accept-' + pid).classList.remove('visible');
          document.getElementById('actions-' + pid).style.display = 'none';
          document.getElementById('isuc-accept-' + pid).classList.add('visible');
          document.getElementById('isuc-accept-' + pid).scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          errEl.textContent = res.error || 'Erro ao processar.';
          errEl.classList.add('visible');
          btn.disabled = false; btn.textContent = '✅ Confirmar Aceite';
        }
      }).catch(() => {
        errEl.textContent = 'Erro de conexão.';
        errEl.classList.add('visible');
        btn.disabled = false; btn.textContent = '✅ Confirmar Aceite';
      });
    }

    function _getTokenForCard(pid) {
      // We need to look up token for inline card actions
      // Token is stored in data attribute set by modal opener
      return window._cardTokenMap && window._cardTokenMap[pid];
    }

    function iSubmitCounter(pid) {
      const text  = (document.getElementById('icounter-' + pid).value || '').trim();
      const errEl = document.getElementById('ierr-counter-' + pid);
      errEl.classList.remove('visible');
      if (!text) { errEl.textContent = 'Descreva sua contraproposta.'; errEl.classList.add('visible'); return; }
      const token = _getTokenForCard(pid);
      fetch('/proposta/action', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, lead_id: window._LEAD_ID, action_type: 'counter', comment: text })
      }).then(r => r.json()).then(res => {
        if (res.success) {
          document.getElementById('ipanel-counter-' + pid).classList.remove('visible');
          document.getElementById('actions-' + pid).style.display = 'none';
          document.getElementById('isuc-counter-' + pid).classList.add('visible');
        } else { errEl.textContent = res.error || 'Erro.'; errEl.classList.add('visible'); }
      }).catch(() => { errEl.textContent = 'Erro de conexão.'; errEl.classList.add('visible'); });
    }

    function iSubmitRejeitar(pid) {
      const motivo = (document.getElementById('ireject-' + pid).value || '').trim();
      const errEl  = document.getElementById('ierr-reject-' + pid);
      errEl.classList.remove('visible');
      const token = _getTokenForCard(pid);
      fetch('/proposta/action', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, lead_id: window._LEAD_ID, action_type: 'reject', comment: motivo })
      }).then(r => r.json()).then(res => {
        if (res.success) {
          document.getElementById('ipanel-reject-' + pid).classList.remove('visible');
          document.getElementById('actions-' + pid).style.display = 'none';
          document.getElementById('isuc-reject-' + pid).classList.add('visible');
        } else { errEl.textContent = res.error || 'Erro.'; errEl.classList.add('visible'); }
      }).catch(() => { errEl.textContent = 'Erro de conexão.'; errEl.classList.add('visible'); });
    }

    // ── Share ────────────────────────────────────────────────────────────────

    function toggleShare(pid) {
      const form = document.getElementById('share-form-' + pid);
      if (form) form.classList.toggle('open');
    }

    function submitShare(pid, token) {
      const name  = (document.getElementById('sw-name-' + pid).value || '').trim();
      const cargo = (document.getElementById('sw-cargo-' + pid).value || '').trim();
      const wapp  = (document.getElementById('sw-wapp-' + pid).value || '').replace(/\D/g, '');
      const email = (document.getElementById('sw-email-' + pid).value || '').trim();
      if (!name || !wapp || !email) { alert('Preencha Nome, WhatsApp e E-mail.'); return; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { alert('E-mail inválido.'); return; }
      const btn = document.getElementById('sw-btn-' + pid);
      btn.disabled = true; btn.textContent = '📨 Enviando...';
      fetch('/proposta/share', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, lead_id: window._LEAD_ID, name, cargo, whatsapp: wapp, email })
      }).then(r => r.json()).then(d => {
        if (d.success) {
          document.getElementById('sw-suc-' + pid).classList.add('show');
          btn.style.display = 'none';
        } else { alert('Erro: ' + (d.error || 'tente novamente.')); btn.disabled = false; btn.textContent = '📤 Enviar Link de Acesso'; }
      }).catch(() => { btn.disabled = false; btn.textContent = '📤 Enviar Link de Acesso'; });
    }

    // ── Detail Modal ─────────────────────────────────────────────────────────

    let _currentModalToken   = null;
    let _currentModalPid     = null;
    // _cardTokenMap is pre-initialized from EJS globals above

    function openDetailModal(pid) {
      const pd = window._proposalData && window._proposalData[pid];
      const items    = pd ? pd.items    : [];
      const discInfo = pd ? pd.discInfo : null;
      const token    = pd ? pd.token    : (_getTokenForCard(pid) || '');
      const adminNotes = pd ? pd.adminNotes : '';
      _currentModalToken = token;
      _currentModalPid   = pid;
      window._cardTokenMap[pid] = token;

      // Show/hide admin note
      const noteEl = document.getElementById('modal-admin-note');
      const noteTxt = document.getElementById('modal-admin-note-text');
      if (noteEl && noteTxt) {
        if (adminNotes && adminNotes.trim()) {
          noteTxt.textContent = adminNotes;
          noteEl.style.display = '';
        } else {
          noteEl.style.display = 'none';
        }
      }

      // Reset modal state
      ['accept','counter','reject'].forEach(t => {
        const p = document.getElementById('mpanel-' + t);
        if (p) p.classList.remove('visible');
        const s = document.getElementById('msuc-' + t);
        if (s) s.classList.remove('visible');
      });
      document.getElementById('modal-cards-grid').style.display = '';
      document.getElementById('modal-cards-label').style.display = '';
      // Reset forms
      const mf = document.getElementById('mform-accept');
      if (mf) mf.reset();
      document.getElementById('mcounter-text').value = '';
      document.getElementById('mreject-text').value  = '';
      ['merr-accept','merr-counter','merr-reject'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.remove('visible');
      });
      // Tipo reset
      mSwitchTipo('pf');

      // WhatsApp link
      const company = window._COMPANY || window._LEAD_NAME || '';
      const waMsg   = encodeURIComponent('Olá! Tenho dúvidas sobre minha proposta' + (company ? ' da ' + company : '') + ' e gostaria de conversar.');
      document.getElementById('modal-wa-link').href = window._WHATSAPP + '?text=' + waMsg;

      // Render summary
      renderModalSummary(items, discInfo);

      // Open overlay
      document.getElementById('detail-modal-overlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeDetailModal() {
      document.getElementById('detail-modal-overlay').classList.remove('open');
      document.body.style.overflow = '';
    }

    function maybeCloseModal(e) {
      if (e.target === document.getElementById('detail-modal-overlay')) closeDetailModal();
    }

    function renderModalSummary(items, discInfo) {
      const box = document.getElementById('modal-summary-content');
      if (!box) return;
      if (!items || items.length === 0) {
        box.innerHTML = '<p style="color:#94a3b8;font-size:0.82rem">Nenhum serviço listado.</p>';
        return;
      }
      const monthly = items.filter(i => i.category !== 'onetime');
      const onetime = items.filter(i => i.category === 'onetime');
      const rawM = monthly.reduce((s,i) => s + (parseFloat(i.price)||0)*(parseInt(i.qty)||1), 0);
      const rawO = onetime.reduce((s,i) => s + (parseFloat(i.price)||0)*(parseInt(i.qty)||1), 0);
      const discM  = discInfo ? discInfo.discM : 0;
      const discO  = discInfo ? discInfo.discO : 0;
      const finM   = rawM * (1 - discM / 100);
      const finO   = rawO * (1 - discO / 100);

      let html = '<ul class="fin-items-list">';
      items.forEach(i => {
        const qty   = parseInt(i.qty) || 1;
        const total = (parseFloat(i.price)||0) * qty;
        const unit  = i.category === 'onetime' ? ' (único)' : '/mês';
        html += `<li><span class="fin-item-name">${i.name}${qty > 1 ? ' × ' + qty : ''}</span><span class="fin-item-price">${fmtBRL(total)}${unit}</span></li>`;
      });
      html += '</ul><div class="fin-totals">';
      if (rawM > 0) {
        if (discM > 0) {
          html += `<div class="fin-total-row"><span>Mensal original</span><span>${fmtBRL(rawM)}/mês</span></div>`;
          html += `<div class="fin-total-row disc"><span>Com desconto (${discM}%)</span><span class="fin-total-val">${fmtBRL(finM)}/mês</span></div>`;
        } else {
          html += `<div class="fin-total-row main"><span>Total mensal</span><span class="fin-total-val">${fmtBRL(finM)}/mês</span></div>`;
        }
      }
      if (rawO > 0) {
        if (discO > 0) {
          html += `<div class="fin-total-row"><span>Implantação original</span><span>${fmtBRL(rawO)}</span></div>`;
          html += `<div class="fin-total-row disc"><span>Com desconto (${discO}%)</span><span class="fin-total-val">${fmtBRL(finO)}</span></div>`;
        } else {
          html += `<div class="fin-total-row main" style="margin-top:0.25rem"><span>Total implantação</span><span class="fin-total-val">${fmtBRL(finO)}</span></div>`;
        }
      }
      html += '</div>';
      box.innerHTML = html;
    }

    // ── Modal panel control ──────────────────────────────────────────────────

    function openModalPanel(type) {
      ['accept','counter','reject'].forEach(t => {
        document.getElementById('mpanel-' + t).classList.remove('visible');
      });
      const p = document.getElementById('mpanel-' + type);
      if (p) {
        p.classList.add('visible');
        p.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }

    function closeModalPanel() {
      ['accept','counter','reject'].forEach(t => {
        document.getElementById('mpanel-' + t).classList.remove('visible');
      });
    }

    // PF / CNPJ toggle (modal)
    function mSwitchTipo(tipo) {
      document.getElementById('minput-tipo').value = tipo;
      document.getElementById('mbtn-pf').classList.toggle('active', tipo === 'pf');
      document.getElementById('mbtn-cnpj').classList.toggle('active', tipo === 'cnpj');
      document.getElementById('msec-pf').classList.toggle('visible', tipo === 'pf');
      document.getElementById('msec-cnpj').classList.toggle('visible', tipo === 'cnpj');
      document.querySelectorAll('#msec-pf input').forEach(el => { el.required = (tipo === 'pf'); });
      document.querySelectorAll('#msec-cnpj input').forEach(el => { el.required = (tipo === 'cnpj'); });
    }

    function _hideModalCards() {
      document.getElementById('modal-cards-grid').style.display  = 'none';
      document.getElementById('modal-cards-label').style.display = 'none';
    }

    function mSubmitAceite(e) {
      e.preventDefault();
      const form  = document.getElementById('mform-accept');
      const btn   = document.getElementById('mbtn-submit-aceite');
      const errEl = document.getElementById('merr-accept');
      errEl.classList.remove('visible');
      const data = Object.fromEntries(new FormData(form).entries());
      data.token   = _currentModalToken;
      data.lead_id = window._LEAD_ID;
      btn.disabled = true; btn.textContent = '⏳ Enviando...';
      fetch('/proposta/finalizar-aceitar', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      }).then(r => r.json()).then(res => {
        if (res.success) {
          document.getElementById('mpanel-accept').classList.remove('visible');
          _hideModalCards();
          document.getElementById('msuc-accept').classList.add('visible');
        } else {
          errEl.textContent = res.error || 'Erro ao processar.';
          errEl.classList.add('visible');
          btn.disabled = false; btn.textContent = '✅ Confirmar Aceite';
        }
      }).catch(() => {
        errEl.textContent = 'Erro de conexão.';
        errEl.classList.add('visible');
        btn.disabled = false; btn.textContent = '✅ Confirmar Aceite';
      });
    }

    function mSubmitCounter() {
      const text  = (document.getElementById('mcounter-text').value || '').trim();
      const errEl = document.getElementById('merr-counter');
      errEl.classList.remove('visible');
      if (!text) { errEl.textContent = 'Descreva sua contraproposta.'; errEl.classList.add('visible'); return; }
      fetch('/proposta/action', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: _currentModalToken, lead_id: window._LEAD_ID, action_type: 'counter', comment: text })
      }).then(r => r.json()).then(res => {
        if (res.success) {
          document.getElementById('mpanel-counter').classList.remove('visible');
          _hideModalCards();
          document.getElementById('msuc-counter').classList.add('visible');
        } else { errEl.textContent = res.error || 'Erro.'; errEl.classList.add('visible'); }
      }).catch(() => { errEl.textContent = 'Erro de conexão.'; errEl.classList.add('visible'); });
    }

    function mSubmitRejeitar() {
      const motivo = (document.getElementById('mreject-text').value || '').trim();
      const errEl  = document.getElementById('merr-reject');
      errEl.classList.remove('visible');
      fetch('/proposta/action', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: _currentModalToken, lead_id: window._LEAD_ID, action_type: 'reject', comment: motivo })
      }).then(r => r.json()).then(res => {
        if (res.success) {
          document.getElementById('mpanel-reject').classList.remove('visible');
          _hideModalCards();
          document.getElementById('msuc-reject').classList.add('visible');
        } else { errEl.textContent = res.error || 'Erro.'; errEl.classList.add('visible'); }
      }).catch(() => { errEl.textContent = 'Erro de conexão.'; errEl.classList.add('visible'); });
    }


    // ── Nova Proposta Modal ────────────────────────────────────────────────────

    function openNovaPropostaModal() {
      document.getElementById('nova-proposta-form').style.display = '';
      document.getElementById('nova-proposta-success').style.display = 'none';
      document.getElementById('np-servicos').value = '';
      document.getElementById('np-contexto').value = '';
      document.getElementById('np-budget').value = '';
      const err = document.getElementById('np-err');
      if (err) err.classList.remove('visible');
      document.getElementById('nova-proposta-overlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeNovaPropostaModal() {
      document.getElementById('nova-proposta-overlay').classList.remove('open');
      document.body.style.overflow = '';
    }

    function maybeCloseNovaModal(e) {
      if (e.target === document.getElementById('nova-proposta-overlay')) closeNovaPropostaModal();
    }

    function submitNovaProposta() {
      const servicos = (document.getElementById('np-servicos').value || '').trim();
      const contexto = (document.getElementById('np-contexto').value || '').trim();
      const budget   = (document.getElementById('np-budget').value || '').trim();
      const errEl    = document.getElementById('np-err');
      errEl.classList.remove('visible');
      if (!servicos) {
        errEl.textContent = 'Descreva os serviços de interesse.';
        errEl.classList.add('visible');
        return;
      }
      const btn = document.querySelector('#nova-proposta-form .btn-green');
      if (btn) { btn.disabled = true; btn.textContent = '⏳ Enviando...'; }
      fetch('/proposta/solicitar-nova', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lead_id: window._LEAD_ID, servicos, contexto, budget })
      }).then(r => r.json()).then(res => {
        if (res.success) {
          document.getElementById('nova-proposta-form').style.display = 'none';
          document.getElementById('nova-proposta-success').style.display = '';
        } else {
          errEl.textContent = res.error || 'Erro ao enviar. Tente novamente.';
          errEl.classList.add('visible');
          if (btn) { btn.disabled = false; btn.textContent = '✨ Enviar Solicitação'; }
        }
      }).catch(() => {
        errEl.textContent = 'Erro de conexão.';
        errEl.classList.add('visible');
        if (btn) { btn.disabled = false; btn.textContent = '✨ Enviar Solicitação'; }
      });
    }

    // ── ESC to close modal ──────────────────────────────────────────────────
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') { closeDetailModal(); closeNovaPropostaModal(); }
    });
  </script>

</body>
</html>
