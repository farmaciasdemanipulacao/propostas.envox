        <div id="nova-proposta-form">
          <div style="margin-bottom:0.85rem">
            <label style="display:block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:#475569;margin-bottom:0.35rem">Serviços de interesse *</label>
            <textarea class="fin-textarea" id="np-servicos" rows="3"
              placeholder="Ex: Gestão de tráfego pago, criação de site, automação de marketing..."></textarea>
          </div>
          <div style="margin-bottom:0.85rem">
            <label style="display:block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:#475569;margin-bottom:0.35rem">Objetivo / Contexto</label>
            <textarea class="fin-textarea" id="np-contexto" rows="3"
              placeholder="Ex: Quero aumentar vendas online, lançar novo produto, melhorar presença digital..."></textarea>
          </div>
